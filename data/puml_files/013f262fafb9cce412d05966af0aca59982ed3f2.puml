enum TEtatDel {
    ' La DEL est allumée
    edAllume
    ' La DEL est éteinte
    edEteinte
    ' La DEL clignotte
    edClignotte
    ' La DEL est inactive. Son état ne sera pas modifié par
    ' TDelIsr lors de la prochaine interruption. Utiliser ceci
    ' lorsque vous voulez avoir le contrôle total sur la DEL
    ' pendant une période donnée.
    edInactive

    edPremier
    edDernier
    ---
    Représente l'état
    d'une DEL pour TDelIsr
}

class TGestionnaireDels {
    ' Dernière DEL de la liste chaînée de DELs
    {static} -FDerniereDel: *TDel

