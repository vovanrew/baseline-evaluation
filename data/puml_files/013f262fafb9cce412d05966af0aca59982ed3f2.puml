class TCapteurObstruction {
    ' Broche du capteur
    -FBroche: int
    ' Niveau à partir duquel le capteur d'obstruction considère qu'il est
    ' obstrué
    -FNiveauObstruction: uint8_t
    ' Délai entre le moment ou on a capter que le capteur n'était pas obstrué
    ' et celui où.
    -FDelaiSansObstructions: uint32_t

    ' Heure du début du moment à partir duquel il n'était pas obstrué.
    -FDebutNonObstrue: uint32_t
    ' Dernière lecture du capteur
    -FDerniereLecture: bool

    ' Valeur retournée par Obstrue et ObstrueImmediatement lorsque le
    ' capteur est obstrué.
    {static} +OBSTRUE: const bool = true;
    ' Valeur retournée par Obstrue et ObstrueImmediatement lorsque le
    ' capteur n'est pas obstrué.
    {static} +NON_OBSTRUE: const bool = false;
    ---

    +TCapteurObstruction(broche: int, niveauObstruction: uint8_t,
                        delaiSansObstructions: uint32_t);
    +TCapteurObstruction();

    +ChangerBroche(broche: int)
    +ChangerNiveauObstruction(niveauObstruction: uint8_t)
    +ChangerDelaiSansObstructions(delaiSansObstructions: uint32_t)

    +begin();
    +Lire();

    +Obstrue(): bool
    +ObstrueImmediatement(): bool

    +DelaiSansObstruction(): uint32_t
    ---
    Permet de lire la valeur d'un capteur
    d'obstruction analogique. Il utilise
    un délai configurable pour s'assurer
    que le capteur d'obstruction est
    bien découvert.
}

class TGroupeCapteursObstruction {
    -FCapteurs: TCapteurObstruction*
    -FNbCapteurs: const size_t

    ---
    ' Initialise un groupe de capteurs dont chaque capteur a une broche différente, mais tous ont le même niveau d'obstruction et délai sans obstructions
    +TGroupeCapteursObstruction(brochesCapteurs: const int*, nbCapteurs: int,
                               niveauObstruction: uint8_t,
                               delaiSansObstructions: uint32_t)
    ' Détruit le groupe de capteurs
    + ~TGroupeCapteursObstruction()

    ' Initialise chaque capteur du groupe
    +begin()
    ' À appeler dans loop
    ' Effectue une lecture de chaque capteur
    +Lire()

    ' Retourne si au moins un capteur est immédiatement obstrué
    +ObstruesImmediatement(): bool
    ' Retourne si au moins un capteur est obstrué
    +Obstrues(): bool

    ' Délai depuis que le capteur n'est plus obstrué
    +DelaiSansObstruction(): uint32_t

    ' Retourne la liste de capteurs du groupe
    +Capteurs(): TCapteurObstruction *
    ' Retourne le nombre de capteurs dans le groupe
    +NbCapteurs(): size_t
    ---
    Groupe de capteurs d'obstructions.
    Tant qu'un des capteurs du groupe est obstrué,
    le groupe de capteurs est considéré comme obstrué.
}

TGroupeCapteursObstruction *- TCapteurObstruction

