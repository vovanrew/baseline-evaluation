class TDel {
    ' Broche de la DEL
    -FBroche: const int
    ' État de la DEL
    -FEtat: TEtatDel

    ' Nombre de TRefDel possédant une référence de cette DEL.
    ' Lorsque ce nombre atteint 0, la DEL devrait être détruite.
    -FNbReferences: uint8_t

    ' DEL précédente dans la liste chaînée.
    FDelPrecedente: TDel*
    ' DEL suivante dans la list chaînée.
    FDelSuivante: TDel*
    ---
    ' Initialise une DEL éteinte et l'ajoute à l'ISR
    #TDel(broche: int)
    ' Supprimer le constructeur de copies
    -TDel(del: TDel&) = delete
    ' Supprime la DEL de la liste chaînée de DELs
    {abstract} +~TDel()

    ' Change l'état de la DEL
    +Etat(etat: TEtatDel): int
    ' Retourne l'état de la DEL
    +Etat(): TEtatDel

    ' Méthode appelée dans l'ISR pour permettre à la DEL de mettre à jour son état.
    ' Ceci permet de créer des états supplémentaires.
    {abstract} #MaJEtat()

    ' friend class TGestionnaireDels
    ---
    DEL gérée par TGestionnaireDels
}
TGestionnaireDels o-- TDel
TGestionnaireDels <-- TDel
TDel -> TEtatDel

