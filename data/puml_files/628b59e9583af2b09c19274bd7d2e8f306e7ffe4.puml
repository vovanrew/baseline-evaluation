@startuml
actor Player
box Portal Service
participant "Telnet Server" as server
participant "Connection Manager" as manager
participant Middleware
endbox
participant "World Service" as world

Player -> server: 1. connects to server
server -> manager: 2. passes connection to manager
activate manager
manager -> manager: 3. calls configured OnConnect callbacks
manager -> Middleware: 4. calls all Middleware OnConnect callbacks
manager -> manager: 5. start main Connection loop
manager -> world: 6. initialize World session
deactivate manager
@enduml
