@startuml

title Scheduler


class Scheduler {
 +isMaster
}

class Task {
  +lastStartTime
  +lastCompleteTime
}

class Schedule
class ScheduleRecord {
 +timeout
}

Schedule -right-> "*" ScheduleRecord
ScheduleRecord -right-> Task : list

Scheduler -right-> Scheduler : watchdog
Scheduler --|> Task
Scheduler --> Task : run
Scheduler -right-> Schedule

Schedule -right-> "*" Task


@enduml
