*@startuml
'https://plantuml.com/sequence-diagram

skinparam style strictuml
skinparam responseMessageBelowArrow true
hide footbox
'autonumber

participant Control as ctrl
participant Graph as grp
participant "nodes[i]:Node" as nd
participant "ants[i]:Ant" as frms

[o-> ctrl ++

ctrl -> grp ++ : getNodes()
return nodes

loop nodes
        opt nodes[i].getContent() instanceof FreeNode
            ctrl -> nd ++ : getAnts()
            return frms

            loop fourmis
                opt ants[i] instanceof MovableAnt
                    frms -> frms ++ : move()
                    deactivate
                end
            end
        end
end


@enduml
