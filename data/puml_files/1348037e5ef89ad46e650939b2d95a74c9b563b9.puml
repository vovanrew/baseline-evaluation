@startuml

package Hugobot {

    package time_intervals_adapter <<Node>> {

        class TimeIntervalsAdapter {
            -max_gap
            -connect_timestamps(df, epsilon=1)
            +create_time_intervals(symbolic_time_series)
        }
    }

    package preprocessing <<Node>> {
        class Transformation {
            {abstract} +transform(dataset)
        }

        class PAA {
            -window_size
            +transform(dataset)
        }

        class OutliersRemover {
            -std_coef
            +transform(dataset)
        }

        PAA -up-|> Transformation
        OutliersRemover -up-|> Transformation
    }

    package temporal_abstraction <<Node>> {

        abstract class TemporalAbstraction {
            {abstract} +discretize_property(prop_df)
            {static} +discretize_to_bins(cutpoints, values)
            {static} +create_symbolic_time_series(states, time_point_series)
            {static} +extract_cutpoints_from_states(states)
        }


        class Gradient <<Node>> {
            - window_size
            - states
            +discretize_property(prop_df)
            {static} +gradient(df, window_size, states)
            {static} +derivative(df, gradient_window_size)
        }

        class KnowledgeBased <<Node>> {
            -states
            +discretize_property(prop_df)
            {static} +knowledge_based(states, prop_df)
        }

        package discretization <<Node>> {
            abstract class Discretization {
                ~nb_bins
                {abstract} ~generate_cutpoints(prop_df)
                +discretize_property(prop_df)
                {static} +create_prop_states(prop_id, cutpoints, scores)
            }

            abstract class Unsupervised {
            }

            abstract class Supervised {
                ~entity_class_relations
            }

            package methods <<Node>> {
                class "Equal Width" {
                    +generate_cutpoints(...) : List[cutpoints]
                    {static} -equal_width(...)
                }

                class "Equal Frequency" {
                    +generate_cutpoints(...) : List[cutpoints]
                    {static} -equal_frequency(...)
                }

                class KMeans {
                    +generate_cutpoints(...) : List[cutpoints]
                    {static} -kmeans_adapter(...)
                }

                Class SAX {
                    +generate_cutpoints(...) : List[cutpoints]
                    {static} -sax(...)
                }

                package "td4c_persist" <<Node>> {
                    class Persist {
                        {static} -persist(...)
                        -all_states_persistance()
                        -single_state_persistence()
                        -calc_state_probabilities()
                        -calc_marginal_probabilities()
                    }

                    abstract class TD4C {
                        -DDM_scoring_function(df, cutoffs, entity_class_relations)
                        {abstract} -distance_measure(p, q)
                    }

                    class "TD4C Cosine" {
                        -distance_measure(p, q)
                    }

                    class "TD4C Kullback-Leibler" {
                        -distance_measure(p, q)
                    }

                    class "TD4C Entropy" {
                        -distance_measure(p, q)
                    }

                    class "TD4C Entropy IG" {
                        -distance_measure(p, q)
                    }

                    class "shared functions" {
                        ~candidate_selection()
                        ~generate_candidate_cutpoints()
                        ~symmetric_kullback_leibler()
                    }

                    "shared functions" -right- TD4C
                    "shared functions" -left- Persist
                    TD4C <|-- "TD4C Kullback-Leibler"
                    TD4C <|--  "TD4C Entropy"
                    TD4C <|--  "TD4C Entropy IG"
                    TD4C <|--  "TD4C Cosine"
                }
            }


            Discretization <|-- Supervised
            Discretization <|-- Unsupervised
            Unsupervised <|-- "Equal Width"
            Unsupervised <|-- "Equal Frequency"
            Unsupervised <|-- KMeans
            Unsupervised <|-- SAX
            Unsupervised <|-- "Persist"
            Supervised <|-- TD4C

        }

        Discretization -up-|> TemporalAbstraction
        Gradient -up-|> TemporalAbstraction
        KnowledgeBased -up-|> TemporalAbstraction
    }

    package kfold <<Node>> {
        class KFold {
            -nb_folds
            -entity_class_relations
            +divide_dataset(dataset)
        }
    }

    methods -[hidden]down- time_intervals_adapter
    time_intervals_adapter -[hidden]right- temporal_abstraction

    package abstraction_per_property <<Node>> {
        class AbstractionPerProperty {
            -preprocessing_params_df
            -temporal_abstraction_params_df
            +preprocessing_per_property(dataset)
            +temporal_abstraction_per_property(dataset, entity_class_relations=None, states=None)
            +intervalization_per_property(symbolic_time_series)
            -generate_preprocessing_by_name(params_row)
            -generate_abstraction_by_name(params_row, entity_class_relations=None, states=None)
        }
    }

    abstraction_per_property -down-> preprocessing
    abstraction_per_property -down-> temporal_abstraction
    abstraction_per_property -down-> time_intervals_adapter

    kfold --> abstraction_per_property
}
@enduml
