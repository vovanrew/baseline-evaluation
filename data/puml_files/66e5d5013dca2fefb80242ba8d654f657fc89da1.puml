@startuml
scale 3.25
hide circle
hide empty methods
left to right direction

class NewsOverview {
    news: List<News>
    nextPageLink: FernUniInternalLink
    previousPageLink: FernUniInternalLink
}

class News {
    date: Date
    headline: Headline
    sections: List<String>
}

class Headline {
    text: String
    link: FernUniInternalLink
}

class Section {
    text: String
    links: List<FernUniInternalLink>
}

NewsOverview "1" --> "0..n" News
News "1" --> "1" Headline
News "1" --> "0..n" Section
@enduml
