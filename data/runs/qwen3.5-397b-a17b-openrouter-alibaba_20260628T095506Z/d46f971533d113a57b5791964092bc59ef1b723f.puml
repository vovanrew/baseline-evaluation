@startuml
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor #333333
  FontName Arial
  FontSize 14
}
skinparam stereotypeCBackgroundColor #C8E6C9
skinparam stereotypeCBorderColor #333333

class Account {
  + userdata11
  + admindata11
}

class User {
  + name
  + password
  + IDcard
  + getprice()
  + getdate()
  + getnumber()
  + getplace()
  + bookingtecket()
  + changebooking()
  + returnticket()
}

class Admin {
  + name
  + password
  + changeticket()
}

class TicketSystem {
  + cancel()
  + display()
  + recordticket()
  + recordorder()
  + displayticket()
  + displayorder()
  + update()
  + searchticket()
  + searchorder()
}

class Order {
  + username
  + userId
  + bookingtecket
}

class Ticket {
  + price
  + date
  + number
  + price
}

Account <|-- User
Account <|-- Admin
User --> TicketSystem
Admin --> TicketSystem
TicketSystem --> Order
TicketSystem --> Ticket

