@startuml
package "org" {
    package "accordproject" {
        package "empty" {
            class "EmptyClause" as EmptyClause << (A,green) >>
            class "EmptyRequest" as EmptyRequest << (T,yellow) >>
            class "EmptyResponse" as EmptyResponse << (T,yellow) >>
        }
        package "contract" {
            class "Clause" as Clause << (C,lightgreen) >>
        }
        package "runtime" {
            class "Request" as Request << (C,lightgreen) >>
            class "Response" as Response << (C,lightgreen) >>
        }
    }
}
EmptyClause --|> Clause
EmptyRequest --|> Request
EmptyResponse --|> Response
@enduml