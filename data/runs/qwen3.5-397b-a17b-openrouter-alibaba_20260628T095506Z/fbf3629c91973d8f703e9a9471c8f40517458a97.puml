@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classHeaderBackgroundColor #E0E0E0
skinparam classHeaderFontColor black
skinparam classHeaderBorderThickness 1
skinparam classHeaderAlignment left
skinparam classAttributeFontStyle normal
skinparam classAttributeFontColor black
skinparam classMethodFontStyle normal
skinparam classMethodFontColor black
skinparam classMethodAlignment left
skinparam classAttributeAlignment left
skinparam classMethodAlignment left
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classHeaderBackgroundColor #E0E0E0
skinparam classHeaderFontColor black
skinparam classHeaderBorderThickness 1
skinparam classHeaderAlignment left
skinparam classAttributeFontStyle normal
skinparam classAttributeFontColor black
skinparam classMethodFontStyle normal
skinparam classMethodFontColor black
skinparam classMethodAlignment left
skinparam classAttributeAlignment left
skinparam classMethodAlignment left

class "Handler" as Handler {
    + next
    + handle()
}

class "ConcreteHandler1" as ConcreteHandler1 {
    + handle()
}

class "ConcreteHandler2" as ConcreteHandler2 {
    + handle()
}

class "ConcreteHandler3" as ConcreteHandler3 {
    + handle()
}

Handler o-- "*" Handler : next
ConcreteHandler1 --|> Handler
ConcreteHandler2 --|> Handler
ConcreteHandler3 --|> Handler

note top of Handler
    <b>A</b> Handler
end note

note top of ConcreteHandler1
    <b>C</b> ConcreteHandler1
end note

note top of ConcreteHandler2
    <b>C</b> ConcreteHandler2
end note

note top of ConcreteHandler3
    <b>C</b> ConcreteHandler3
end note

actor client
client -> Handler : handle()

@enduml