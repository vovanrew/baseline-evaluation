@startuml
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #f5f5f5
  BorderColor #333333
  FontName Arial
  FontSize 12
}
skinparam stereotypeCBackgroundColor #d4edda
skinparam stereotypeCBorderColor #28a745

class Artist {
  + id : VARCHAR
  --
  + name : VARCHAR
  + instagram : VARCHAR
  + facebook : VARCHAR
  + twitter : VARCHAR
  + wikipedia : VARCHAR
  + bio : TEXT
}

class Album {
  + id : VARCHAR
  --
  + title : VARCHAR
  + release : VARCHAR
  + image : VARCHAR
}

class Song {
  + id : VARCHAR
  --
  + album_id : VARCHAR
  + title : VARCHAR
  + duration : INT
}

class PlaylistCategory {
  + id : VARCHAR
  --
  + name : VARCHAR
  + image : VARCHAR
  + icon : VARCHAR
}

class Playlist {
  + id : VARCHAR
  --
  + name : VARCHAR
  + description : TEXT
  + image : VARCHAR
  + category_id : VARCHAR
  + user_id : VARCHAR
}

class PodcastCategory {
  + id : VARCHAR
  --
  + name : VARCHAR
  + image : VARCHAR
  + icon : VARCHAR
}

class Podcast {
  + id : VARCHAR
  --
  + name : VARCHAR
  + about : TEXT
  + image : VARCHAR
  + category_id : VARCHAR
  + user_id : VARCHAR
}

class Episode {
  + id : VARCHAR
  --
  + podcast_id : VARCHAR
  + title : VARCHAR
  + description : TEXT
  + published_at : DATE
  + duration : INT
}

class User {
}

class Concert {
}

