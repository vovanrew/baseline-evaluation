@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle italic
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classHeaderBackgroundColor #E0E0E0

class Duck {
    +public abstract void display()
    +void quack()
    +void swim()
    +void fly()
}

class WildDuck {
    +void display()
}

class PekingDuck {
    +void display()
    +void fly()
}

class ToyDuck {
    +void display()
    +void quack()
    +void swim()
    +void fly()
}

Duck <|-- WildDuck
Duck <|-- PekingDuck
Duck <|-- ToyDuck

note top of Duck
    <b>A</b>
end note

note top of WildDuck
    <b>C</b>
end note

note top of PekingDuck
    <b>C</b>
end note

note top of ToyDuck
    <b>C</b>
end note

@enduml