@startuml
skinparam classAttributeIconSize 0
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam classBorderColor black
skinparam stereotypeCBackgroundColor #C8E6C9
skinparam stereotypeCBorderColor #81C784

class Account {
    + AccountID : int
    + FirstName : string
    + LastName : string
    + EmailAddressUsername : string
    + password : string
    + AccountCreatedDatetime : datetime
    + isArchived : boolean
    --
    + createAccount()
    + deleteAccount()
    + editAccount()
    + forgotPassword()
}

class Recipe {
    + recipeID : int
    + recipeName : string
    + servings : int
    + prepTime : time
    + cookTime : time
    + totalTime : time
    + isFavorite : boolean
    --
    + createRecipe()
    + editRecipe()
    + deleteRecipe()
    + saveRecipe()
}

class RecipeImage {
    + RecipeImageID : int
    + RecipeImagePath : int
    + isArchived : boolean
    --
    + AddPhoto()
    + DeletePhoto()
}

class Ingredient {
    + IngredientID : int
    + IngredientText : string
    + IngredientAmount : int
    + isArchived : boolean
    --
    + AddIngredient()
    + EditIngredient()
    + DeleteIngredient()
}

class Measurement {
    + MeasurementID : int
    + MeasurementText : string
    --
    + getMeasurement()
}

class Instructions {
    --
    + getSteps()
}

class Step {
    + StepID : int
    + InstructionStepText : string
    + StepNumberOrder : int
    + isArchived : boolean
    --
    + AddStep()
    + EditStep()
    + RemoveStep()
}

Account "0..*" -- "1" Recipe : owns
Recipe "1" o-- "1" RecipeImage : has
Recipe "1" *-- "*" Ingredient : contains
Recipe "1" *-- "1" Instructions : has
Ingredient "1" *-- "1" Measurement : uses
Instructions "1" *-- "*" Step : consists of

note top of Account
    <b>C</b>
end note

note top of Recipe
    <b>C</b>
end note

note top of RecipeImage
    <b>C</b>
end note

note top of Ingredient
    <b>C</b>
end note

note top of Measurement
    <b>C</b>
end note

note top of Instructions
    <b>C</b>
end note

note top of Step
    <b>C</b>
end note

@enduml