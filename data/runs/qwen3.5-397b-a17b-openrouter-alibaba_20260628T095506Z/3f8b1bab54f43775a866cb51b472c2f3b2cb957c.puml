```plantuml
@startuml
skinparam classAttributeIconSize 0
skinparam noteBackgroundColor #FFFFCC
skinparam noteBorderColor #CCCCCC
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor #CCCCCC
  HeaderBackgroundColor #E8E8E8
  ArrowColor #666666
}
skinparam classHeaderBackgroundColor #E8E8E8

class "Brain" as Brain {
  pythons = []
  pips = []
  python_default
  python2_default
  python3_default
  pip_default
  pip2_default
  pip3_default
  visualisation = ""
  verbose = true
  report_obj = {}
  sites = {}
}

class "Pip" as Pip {
  site_package_path
  pythons = []
  analyse()
  analyse_version()
  report()
}

class "Python" as Python {
  result_shell_site_info
  result_shell_run_pip_as_module
  sys_path = []
  pip_module_version
  pip_module_site_package_path
  pips = []
  analyse()
}

class "Site" as Site {
  path = path
  pythons = Set
  pips = Set
}

class "Base" as Base {
  path = path
  paths_all = Set
  is_default = false
  is_default2 = false
  is_default3 = false
  result_shell_ls
  result_shell_version
  result_shell_file_size
  version
  size
  warnings = []
  report_obj = {}
  get exists()
  analyse()
  report()
}

note top of Brain
  Brain's attributes
  python_default, python2_default, python3_default
  pip_default, pip2_default, pip3_default
  get stored into the Brain's report objects'
  defaults = {}
  defaults.python
  defaults.python2
  defaults.python3
  defaults.pip
  defaults.pip2
  defaults.pip3
  attributes, respectively.
end note

Brain --> Pip : pips *
Brain --> Python : pythons
Brain --> Site : sites
Pip --|> Base
Python --|> Base

@enduml
```