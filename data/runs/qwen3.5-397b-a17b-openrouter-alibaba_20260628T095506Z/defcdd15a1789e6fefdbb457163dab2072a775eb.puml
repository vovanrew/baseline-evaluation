@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle italic
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor #333333
skinparam classFontColor #333333
skinparam interfaceBackgroundColor #E6E6FA
skinparam interfaceBorderColor #333333
skinparam interfaceFontColor #333333

interface "LogCollector" as LogCollector {
    + collect()
}

class "FtpLogFileDownloader" as FtpLogFileDownloader {
}

class "SockerLogReader" as SockerLogReader {
}

class "DbTableLogGateway" as DbTableLogGateway {
}

FtpLogFileDownloader ..|> LogCollector
SockerLogReader ..|> LogCollector
DbTableLogGateway ..|> LogCollector

@enduml