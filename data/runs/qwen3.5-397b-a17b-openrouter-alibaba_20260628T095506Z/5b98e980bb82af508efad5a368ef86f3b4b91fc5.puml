@startuml
class "MonoBehaviour" as MonoBehaviour {
}

class "SwordAttack" as SwordAttack {
  + animator : Animator
  + attackDamage : float = 50f
  + staminaCost : float = 15f
  - «readonly» hIsAttacking : int
  + playerStats : Stats.Stats
  noOfClicks : int
  - canClick : bool
  - «readonly» hAttackNo : int
  Start() : void
  Update() : void
  - OnTriggerEnter(other:Collider) : void
  - ComboStarter() : void
  + ComboCheck() : void
}

SwordAttack --|> MonoBehaviour
@enduml