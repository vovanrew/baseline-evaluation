@startuml
title 基于GitHub的实验管理平台--学生列表用例的顺序图
actor users
participant "首页" as Home
participant "登录" as Login
participant "选择登录身份" as SelectIdentity

users -> Home: 查看所有学生列表

alt [如果users是老师]
    Home -> Login
    Login -> SelectIdentity
else [如果users是students]
    Home -> Login
    Login -> SelectIdentity
end

@enduml