@startuml
skinparam packageStyle rectangle
skinparam rectangle {
  BackgroundColor white
  BorderColor black
  BorderThickness 2
}
skinparam class {
  BackgroundColor #f0f0f0
  BorderColor black
  BorderThickness 1
}
skinparam note {
  BackgroundColor #e0e0e0
  BorderColor black
  BorderThickness 1
}
skinparam stereotypeCBackgroundColor #c0e0c0
skinparam stereotypeCBorderColor black
skinparam stereotypeCBorderThickness 1

package "РегистрСведений" {
  class "«РегистрыСведений»\nЗначения разовых показателей расчета зарплаты (для сотрудников)" as C {
    -- Измерения --
    ПериодДействия : Дата
    Сотрудник : Справочник.Сотрудник
    Показатель : Справочник.Показатель
    Организация : Справочник.Организация
    ФизическоеЛицо : Справочник.Физическое лицо
    -- Ресурсы --
    Значение : Число 15, 5
  }
}

note right of C
  <b>С</b>
end note

@enduml