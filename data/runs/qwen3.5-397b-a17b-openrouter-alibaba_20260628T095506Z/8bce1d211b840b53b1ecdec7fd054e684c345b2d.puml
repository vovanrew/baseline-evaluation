@startuml
participant "s:ObjectStructure" as s
participant "a:CroncreteElementA" as a
participant "b:CroncreteElementB" as b
participant "v1:ConcreteVisitor1" as v1

s -> a : accept(v1)
activate a
a -> v1 : visit(this)
activate v1
v1 -> a : operationA()
deactivate v1
a --> v1
deactivate a
s --> a

s -> b : accept(v1)
activate b
b -> v1 : visit(this)
activate v1
v1 --> b : do nothing
deactivate v1
deactivate b
s --> b
@enduml