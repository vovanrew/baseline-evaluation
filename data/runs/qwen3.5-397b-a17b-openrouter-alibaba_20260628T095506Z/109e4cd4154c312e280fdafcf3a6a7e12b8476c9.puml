@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle italic
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classHeaderBackgroundColor #E0E0E0
skinparam classHeaderFontColor black
skinparam classHeaderAlignment center
skinparam classAttributeFontColor black
skinparam classMethodFontColor black
skinparam classAttributeIconSize 0
skinparam classMethodIconSize 0
skinparam classAttributeIconSize 0
skinparam classMethodIconSize 0
skinparam classAttributeIconSize 0
skinparam classMethodIconSize 0

class "ConcreteDecorateA" as ConcreteDecorateA {
  + addState
  + operation()
}

class "ConcreteDecorateB" as ConcreteDecorateB {
  + operation() ~ {super.operation(); addBehavior();}
  + addBehavior()
}

class "Decorator" as Decorator {
  + component: Component
  + operation() ~ component.operation();
}

class "ConcreteComponent" as ConcreteComponent {
  + operation()
}

interface "Component" as Component {
  + operation()
}

ConcreteDecorateA --|> Decorator
ConcreteDecorateB --|> Decorator
Decorator o-- Component
ConcreteComponent ..|> Component
Decorator ..|> Component

note top of ConcreteDecorateA
  <b>C</b>
end note

note top of ConcreteDecorateB
  <b>C</b>
end note

note top of Decorator
  <b>A</b>
end note

note top of ConcreteComponent
  <b>C</b>
end note

note top of Component
  <b>I</b>
end note

@enduml