class MainActivity {
    + camera
    + duration
    --
    + showActiveMeasurement()
    + hideActiveMeasurement()
    + createMeasurement()
    + showResult()
}

class ResultActivity {
    + Measurement
    --
    + displayResult()
    + backToMainActivity()
    + onCreate()
}

class Measurement {
    + camera
    + int[] redValues
    + int imgPerSecond
    --
    + captureImage() : ImageFile
    + start() : void
    + analyzeImage(imageFile) : int
    + calculateResult() : int
}

class File {
}

class ImageFile {
    + File image
    --
    + cropImage() : void
    + toValue() : float[]
}

MainActivity --> Measurement : creates
ResultActivity --> Measurement : uses
ImageFile --|> File : extends
@enduml