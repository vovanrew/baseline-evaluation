@startuml
skinparam classAttributeIconSize 0
skinparam noteBackgroundColor #FFFFE0
skinparam noteBorderColor #000000

class "ConcreteStrategy" as ConcreteStrategy {
    + algorithm()
}

class "Strategy" as Strategy {
    + algorithm()
}

class "Context" as Context {
    - strategy
    + operation()
}

ConcreteStrategy ..|> Strategy
Strategy --o Context : -strategy
note right of Context.operation()
    strategy.algorithm();
end note

@enduml