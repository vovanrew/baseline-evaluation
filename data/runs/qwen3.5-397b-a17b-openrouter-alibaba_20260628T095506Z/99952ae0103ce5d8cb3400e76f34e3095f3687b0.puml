@startuml
title SOURCE's Class Diagram
package "model" {
  package "data" {
    package "source" {
      class "Collector" as A {
        + Collector()
        + getDatumLinkListByTree()
        + getEntityDescription()
        + getEntityName()
        + getQualifiers()
        + getReferences()
        + getSingleStatement()
        + getStatementList()
        + triggerLoad()
        + triggerSave()
      }
      class "WebCollector" as C {
        + loaded : Entities
        + gson : Gson
        + seen : ArrayList<Entities>
        + WebCollector()
        + getDatumLinkListByTree()
        + getEntityDescription()
        + getEntityName()
        + getQualifiers()
        + getReferences()
        + getSingleStatement()
        + getStatementList()
        + triggerLoad()
        + triggerSave()
        + getJson()
        + formatURL()
        + iterateSnaks()
        + tryGetQualifiers()
      }
      class "LocalCollector" as C {
        + LocalCollector()
        + triggerSave()
        + getJson()
      }
      class "LocalRepository" as C {
        + file : File
        + LocalRepository()
        + load()
        + save()
      }
      A <|-- C
      C <|-- C
      A o-- C : repository
    }
  }
}
@enduml