@startuml
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor Black
  ArrowColor Black
}
skinparam stereotypeCBackgroundColor #C8E6C9
skinparam stereotypeCBorderColor Black

class "PropertyValueList" as PVList {
  + lookupLabel
  + propertyValuePair
}

class "NumericalProperty" as NumProp
class "StringProperty" as StrProp

PVList --> NumProp : propertyValuePair
PVList --> StrProp : propertyValuePair

note right of PVList
  <b>Class</b>
  <i>PropertyValueList</i>
  <hr/>
  <b>Attributes:</b>
  - lookupLabel
  - propertyValuePair
end note

note right of NumProp
  <b>Class</b>
  <i>NumericalProperty</i>
end note

note right of StrProp
  <b>Class</b>
  <i>StringProperty</i>
end note

@enduml