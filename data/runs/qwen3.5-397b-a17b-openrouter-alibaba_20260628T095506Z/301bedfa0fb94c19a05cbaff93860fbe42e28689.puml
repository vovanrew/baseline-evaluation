@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor #000000
skinparam classArrowColor #000000
skinparam classStereotypeBackgroundColor #C1E1C1
skinparam classStereotypeBorderColor #000000
skinparam classStereotypeFontStyle italic

class "FantasticFactory" as FantasticFactory {
    -_page
    -_author
    +FantasticFactory()
}

class "FantasticBook" as FantasticBook {
    -_bookCategory
    -_page
    -_author
    +FantasticBook()
}

class "BookFactory" as BookFactory {
    +GetBook()
}

class "Book" as Book {
    +BookCategory
    +Page
    +Author
}

class "ScienceFictionFactory" as ScienceFictionFactory {
    -_page
    -_author
    +ScienceFictionFactory()
}

class "ScienceFictionBook" as ScienceFictionBook {
    -_bookCategory
    -_page
    -_author
    +ScienceFictionBook()
}

FantasticFactory --|> BookFactory
ScienceFictionFactory --|> BookFactory
FantasticBook --|> Book
ScienceFictionBook --|> Book
FantasticFactory ..> FantasticBook
ScienceFictionFactory ..> ScienceFictionBook

note top of FantasticFactory
    <b>C</b>
end note

note top of FantasticBook
    <b>C</b>
end note

note top of BookFactory
    <b>A</b>
end note

note top of Book
    <b>A</b>
end note

note top of ScienceFictionFactory
    <b>C</b>
end note

note top of ScienceFictionBook
    <b>C</b>
end note

@enduml