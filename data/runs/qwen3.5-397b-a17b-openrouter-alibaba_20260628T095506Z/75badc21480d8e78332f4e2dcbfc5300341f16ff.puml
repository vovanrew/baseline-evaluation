@startuml
title UTIL's Class Diagram
package "Twitter" {
  package "Util" {
    interface "AccessModifiers" {
      + value()
    }
    interface "Attributes" {
      + value()
    }
    interface "Constructor" {
      + value()
    }
    class "MessageHandler" {
      - messageHandler : MessageHandler
      - fadeIn : FadeTransition
      - fadeOut : FadeTransition
      + getMessageHandler()
      + initTransitions()
      + displayMessage()
    }
    interface "Methods" {
      + value()
    }
    interface "Singleton" {
      + value()
    }
    interface "WindowSizer" {
      + anchorSize()
    }
  }
}
@enduml