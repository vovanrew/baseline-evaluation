package "Factory Method Persona" {
    class PersonaFactoryMethod {
        + crearPersona(id)
    }
    
    class PersonaFactory {
    }
    
    class Cliente {
    }
    
    class Mecanico {
    }
    
    class Oficinista {
    }
    
    class Persona {
    }
    
    class Empleado {
    }
    
    PersonaFactoryMethod <|-- PersonaFactory
    PersonaFactory ..> Cliente : «instancia»
    PersonaFactory ..> Mecanico : «instancia»
    PersonaFactory ..> Oficinista : «instancia»
    Cliente --|> Persona
    Mecanico --|> Empleado
    Oficinista --|> Empleado
    Empleado --|> Persona
}

