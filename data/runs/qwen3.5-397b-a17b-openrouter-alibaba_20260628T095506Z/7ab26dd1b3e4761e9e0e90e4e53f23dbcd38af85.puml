```plantuml
@startuml
package "com" {
    package "Iluwatar" {
        package "prototype" {
            interface Prototype {
                + Prototype()
                + clone() : Object
            }
            interface Beast {
                + Beast()
                + clone() : Beast
            }
            interface Warlord {
                + Warlord()
                + clone() : Warlord
            }
            interface Mage {
                + Mage()
                + clone() : Mage
            }
            class ElfBeast {
                + ElfBeast()
                + clone() : Beast
                + toString() : String
            }
            class OrcBeast {
                + OrcBeast()
                + clone() : Beast
                + toString() : String
            }
            class ElfWarlord {
                + ElfWarlord()
                + clone() : Warlord
                + toString() : String
            }
            class OrcWarlord {
                + OrcWarlord()
                + clone() : Warlord
                + toString() : String
            }
            class ElfMage {
                + ElfMage()
                + clone() : Mage
                + toString() : String
            }
            class OrcMage {
                + OrcMage()
                + clone() : Mage
                + toString() : String
            }
            interface HeroFactory {
                + createBeast() : Beast
                + createMage() : Mage
                + createWarlord() : Warlord
            }
            class HeroFactoryImpl {
                - beast : Beast
                - mage : Mage
                - warlord : Warlord
                + HeroFactoryImpl(mage : Mage, warlord : Warlord, beast : Beast)
                + createBeast() : Beast
                + createMage() : Mage
                + createWarlord() : Warlord
            }
            class App {
                + App()
                + main(args : String[])
            }
            Prototype <|-- Beast
            Prototype <|-- Warlord
            Prototype <|-- Mage
            Beast <|-- ElfBeast
            Beast <|-- OrcBeast
            Warlord <|-- ElfWarlord
            Warlord <|-- OrcWarlord
            Mage <|-- ElfMage
            Mage <|-- OrcMage
            HeroFactory <.. HeroFactoryImpl
            HeroFactoryImpl --> Beast : -beast
            HeroFactoryImpl --> Warlord : -warlord
            HeroFactoryImpl --> Mage : -mage
        }
    }
}
@enduml
