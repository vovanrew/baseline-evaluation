@startuml
actor "消费者" as Consumer
participant "监管消费者服务端" as Server
database "db" as DB1
participant "数字人民币" as DigitalRMB
database "DB" as DB2

Consumer -> Server: 购买课程
Server -> DB1: 生成订单号并保存
Server -> DigitalRMB: 获取付款二维码
Server --> Consumer: 返回订单号和付款二维码
Consumer -> DigitalRMB: 支付
Server -> DigitalRMB: 轮询查询支付状况

alt [查询到成功支付]
    Server -> DB2: 修改订单状态，划拨
    Server --> Consumer: 通知页面跳转
else [到达最大等待时间仍未查询到成功支付]
    Server -> DB2: 修改订单状态为关闭
end

@enduml