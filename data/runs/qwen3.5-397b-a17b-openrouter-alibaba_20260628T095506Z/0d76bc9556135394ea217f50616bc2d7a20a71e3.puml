@startuml
package "sandbox" {
  package "design" {
    package "template" {
      class "App" as App {
      }
      class "GeradorPropriedadesCriptografado" as GeradorPropriedadesCriptografado {
      }
      class "GeradorXMLCompactado" as GeradorXMLCompactado {
      }
      class "GeradorArquivo" as GeradorArquivo {
      }
      App ..> GeradorPropriedadesCriptografado
      App ..> GeradorXMLCompactado
      App ..> GeradorArquivo
      GeradorPropriedadesCriptografado --|> GeradorArquivo
      GeradorXMLCompactado --|> GeradorArquivo
    }
  }
}
@enduml