@startuml
title Ski Championships Management
footer "Ski Championships Management Class Diagram"
footer "Bertrand C"
header "Last updated 15/10/2020"

package "Scm" {
    class Event {
        + id: int
        + location: string
        + startDate: Date
        + endDate: Date
        + create(): Event
        + update()
        + delete(): bool
        + list(): Event[]
        + export(): bool
        + import(): bool
    }

    class Competitor {
        + id: int
        + lastName: string
        + firstName: string
        + birthDate: Date
        + bibNumber: int
        + email: string
        + photo: resource
        + create(): Competitor
        + update()
        + delete(): bool
        + list(): Competitor[]
    }

    class Result {
        + time: Time
        + create(): Result
        + delete(): bool
        + list(): Result[]
    }

    class Run {
        + number: int
        + time: Time
        + getId()
        --
        Other methods
        + create(): Run
        + delete(): bool
    }

    class Metadata {
        + id: int
        + name: string
        + description: string
        + create()
        + update()
        + delete(): bool
        + list(): Metadata
    }

    class Category {
    }

    class Profile {
    }

    Event "1" *-- "0..n" Competitor : takes part
    Competitor "0..n" *-- "1" Result : obtains
    Competitor "0..n" *-- "1" Run : runs
    Competitor "0..n" -- "1" Metadata : belongs to
    Competitor "0..n" -- "1" Metadata : has
    Category --|> Metadata
    Profile --|> Metadata
}

@enduml