class Ginasio {
    + nome: String
    + quadra: List<Quadra>
}

class Pessoa {
    + nome: String
}

class Quadra {
    + numero: Int
    + aluguel: Aluguel
    + ginasio: Ginasio
}

class Clients {
    + id: Int
    + nome: String
    + locaçao: List<Aluguel>
}

class Aluguel {
    + cliente: Client
    + tempo: Int
    + quadra: Quadra
}

Ginasio "1" *-- "1..*" Quadra
Pessoa <|-- Clients
Pessoa <|-- Aluguel
Clients "1" *-- "0..*" Aluguel
Aluguel "1" -- "1" Quadra

