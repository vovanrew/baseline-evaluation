class Display {
    +getColumns(): int
    +getRows(): int
    +getRowText(row: int): String
    +show(): void
}

class StringDisplay {
    -string: String
    +getColumns(): int
    +getRows(): int
    +getRowText(row: int): String
}

class Border {
    #display: Display
    +Border(display: Display)
}

class SideBorder {
    -borderChar: char
    +SideBorder(display: Display, ch: char)
    +getColumns(): int
    +getRows(): int
    +getRowText(row: int): String
}

class FullBorder {
    +FullBorder(display: Display)
    +getColumns(): int
    +getRows(): int
    +getRowText(row: int): String
    -makeLine(ch: char, count: int): void
}

Display <|-- StringDisplay
Display <|-- Border
Border <|-- SideBorder
Border <|-- FullBorder

note top of Display
    <b>A</b>
end note

note top of StringDisplay
    <b>C</b>
end note

note top of Border
    <b>A</b>
end note

note top of SideBorder
    <b>C</b>
end note

note top of FullBorder
    <b>C</b>
end note

@enduml