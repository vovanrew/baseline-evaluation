@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle italic
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor #000000
skinparam classFontColor #000000
skinparam classStereotypeFontStyle normal
skinparam classStereotypeFontColor #000000
skinparam classStereotypeBackgroundColor #E0E0E0
skinparam classStereotypeBorderColor #000000

class "Collection" as Collection {
}
class "List" as List {
}
class "AbstractCollection" as AbstractCollection {
}
class "AbstractList" as AbstractList {
}
class "ArrayList" as ArrayList {
    Object[] elementData
    int a
    --
    size()
}
class "TimeUnit" as TimeUnit {
    DAYS
    HOURS
    MINUTES
}

Collection <|-- List
AbstractCollection <|-- Collection
AbstractList <|-- AbstractCollection
ArrayList <|-- AbstractList
List <|-- AbstractList

note right of Collection
    <i>I</i>
end note
note right of List
    <i>I</i>
end note
note right of AbstractCollection
    <i>A</i>
end note
note right of AbstractList
    <i>A</i>
end note
note right of ArrayList
    <i>C</i>
end note
note right of TimeUnit
    <i>E</i>
end note

@enduml