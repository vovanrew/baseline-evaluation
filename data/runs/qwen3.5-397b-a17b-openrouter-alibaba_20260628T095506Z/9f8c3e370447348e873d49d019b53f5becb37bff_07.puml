@startuml
title Scheduler

class "Scheduler" as Scheduler {
  + isMaster
}

class "Schedule" as Schedule {
}

class "ScheduleRecord" as ScheduleRecord {
  + timeout
}

class "Task" as Task {
  + lastStartTime
  + lastCompleteTime
}

Scheduler --> Schedule
Scheduler --> Task : run
Schedule --> ScheduleRecord : *
ScheduleRecord --> Task : list
Scheduler --> Scheduler : watchdog
Schedule --> Task : *

@enduml