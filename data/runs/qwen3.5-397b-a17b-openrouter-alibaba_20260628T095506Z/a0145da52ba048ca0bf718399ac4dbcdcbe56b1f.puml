title Modulo-matrícula/Informática

class "Matrícula" as M {
  -id: Int
  -cliente: Client
  -tempo: Int
  -quadra: Turma
  +registraMatrícula(): Int
}

class "Aluno" as A {
  -id: Int
  -nome: String
  -locação: List<Matrícula>
}

class "ControleNúmeroMatrícula" as CNM <<interface>> {
  #quantidadeDeMatrícula: Int
  +registraMatrícula(): Int
}

class "Turma" as T {
  -numero: Int
  -aluguel: Matrícula
  -ginasio: Curso
  +getcontroleNúmeroMatrícula()
}

class "Curso" as C {
  -nome: String
  -profesor: String
  -quadra: List<Turma>
}

M "0..*" --* "1" A : composição
M ..|> CNM : realização
T "1" --* "1..*" M : composição
T ..> CNM : dependência
C "1" --* "1..*" T : composição

note right of M
  <b>composição >
end note

@enduml