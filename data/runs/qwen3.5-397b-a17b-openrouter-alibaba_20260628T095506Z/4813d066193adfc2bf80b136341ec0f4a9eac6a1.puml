class Customer {
    + numberOfRentalsWithDifferentOffices(CalculateNumberOfRentalsDO ca): Integer
}

class Rental {
}

interface CalculateNumberOfRentalsDO {
    + calculate(rentals: Rental[]): Integer
}

class ImplCalculate {
    + calculate(rentals: Rental[]): Integer
}

Customer "1" -- "*" Rental : makes
Customer ..> CalculateNumberOfRentalsDO
ImplCalculate ..|> CalculateNumberOfRentalsDO

note top of Customer
    <b>C</b>
end note

note top of Rental
    <b>A</b>
end note

note top of CalculateNumberOfRentalsDO
    <b>I</b>
end note

note top of ImplCalculate
    <b>C</b>
end note

