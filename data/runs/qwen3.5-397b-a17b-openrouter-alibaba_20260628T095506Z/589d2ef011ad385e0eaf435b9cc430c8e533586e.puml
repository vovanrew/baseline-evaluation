@startuml
actor user
participant "Wrapper" as Wrapper
participant "wrapped" as wrapped

user -> Wrapper: 1 predict(X)
activate Wrapper
Wrapper -> Wrapper: 2 validate; strip
Wrapper -> wrapped: 3 predict(Xt)
activate wrapped
wrapped --> Wrapper: 4 yt
deactivate wrapped
Wrapper -> Wrapper: 5 add metadata
Wrapper --> user: 6 y
deactivate Wrapper
@enduml