@startuml
actor "./zbox sp-pay-interests" as zbox
participant "gosdk" as sdk

zbox -> sdk: StakePoolPayInterests(blobberID)
activate sdk
sdk -> sdk: check initialized sdk
deactivate sdk

alt [empty blobber id]
    sdk -> sdk: get client id
end

sdk -> sdk: create stake pool request
sdk -> sdk: create smart contract txn data
sdk -> sdk: send smart contract txn value fee

@enduml