@startuml
actor "actorName" as actor1
actor "actorName" as actor2

package "Manage-Pipeline" {
    participant "CLI" as cli1
    participant "Web" as web1
    participant "caade" as caade1
    participant "CLI" as cli2
    participant "Web" as web2
