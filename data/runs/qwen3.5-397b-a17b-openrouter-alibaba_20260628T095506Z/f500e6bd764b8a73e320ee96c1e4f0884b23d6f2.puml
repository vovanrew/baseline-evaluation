@startuml
skinparam classAttributeIconSize 0
skinparam classFontName Arial
skinparam classFontSize 14
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classFontColor black
skinparam classStereotypeFontName Arial
skinparam classStereotypeFontSize 14
skinparam classStereotypeFontColor black
skinparam classStereotypeBackgroundColor #B0E0E6
skinparam classStereotypeBorderColor black

class "Flyweight" as Flyweight {
  +opreate()
}

class "FlyweightImpl" as FlyweightImpl {
  +operate()
}

class "FlyweightFactory" as FlyweightFactory {
  -HashMap pool;
  +getFlyweight(String key)
}

FlyweightImpl --|> Flyweight
FlyweightFactory --|> Flyweight

note top of Flyweight
  <b>A</b>
end note

note top of FlyweightImpl
  <b>C</b>
end note

note top of FlyweightFactory
  <b>C</b>
end note

@enduml