@startuml
title Tennis Court Booking System
actor users
participant "SystemAdministrator" as SA
actor siteManager

users -> SA: 1 bookSite()
activate SA
SA -> siteManager: 2 deliverUserRequirements()
activate siteManager
siteManager -> siteManager: 3 queryUnoccupiedSite()
siteManager --> SA: 4 returnUnoccupiedSiteInfo()
deactivate siteManager
SA -> SA: 5 decidedSite()
SA --> users: 6 noticeSiteInfo()
deactivate SA
@enduml