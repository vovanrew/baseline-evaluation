@startuml
actor "张三" as A
actor "李四" as B

alt [借钱案例]
    A -> B: 我要借钱
    loop [循环借钱100次]
        rect rgb(255, 255, 255)
            note over A,B
            <b>成功案例</b>
            end note
            B --> A: 借给你
        end
        A -> B: 我要还钱
        B --> A: 收到欠款
    end
else [借钱失败]
    A -> B: 我还要借钱
    B --> A: 不借了
end
@enduml