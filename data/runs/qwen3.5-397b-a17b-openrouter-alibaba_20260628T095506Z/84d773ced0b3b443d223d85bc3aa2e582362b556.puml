@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor #CCCCCC
skinparam classFontColor #333333
skinparam interfaceBackgroundColor #F5F5F5
skinparam interfaceBorderColor #CCCCCC
skinparam interfaceFontColor #333333
skinparam stereotypeCBackgroundColor #C8E6C9
skinparam stereotypeCBorderColor #81C784
skinparam stereotypeABackgroundColor #B3E5FC
skinparam stereotypeABorderColor #4FC3F7
skinparam stereotypeIBackgroundColor #D1C4E9
skinparam stereotypeIBorderColor #9575CD

class JuniorExperienceManager {
}
class PrimaryExperienceManager {
}
class SeniorExperienceManager {
}
class AbstractExperienceManager {
    + next: LevelManager
}
interface LevelManager {
    + handleExperience(): void
    + forName(): String
}

JuniorExperienceManager --|> AbstractExperienceManager
PrimaryExperienceManager --|> AbstractExperienceManager
SeniorExperienceManager --|> AbstractExperienceManager
AbstractExperienceManager o-- "1" LevelManager
AbstractExperienceManager --|> LevelManager

note right of AbstractExperienceManager
    <b>Abstract Class</b>
    Defines the chain structure
end note

note right of LevelManager
    <b>Interface</b>
    Defines the handler contract
end note

@enduml