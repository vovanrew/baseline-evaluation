class "InMemoryDomainRepository" as InMemoryDomainRepository {
    + InMemoryDomainRepository()
    + InMemoryDomainRepository(Function<?, I> identityGenerator)
    + Optional<T> ofIdentity(Comparable id)
    + void deleteOfIdentity(Comparable id)
}

class "InMemoryRepository<T, I>" as InMemoryRepository
class "AggregateRoot" as AggregateRoot
