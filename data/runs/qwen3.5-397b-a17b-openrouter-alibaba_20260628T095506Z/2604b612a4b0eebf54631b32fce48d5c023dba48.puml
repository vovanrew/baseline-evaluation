@startuml
actor "PackageManager" as PM
participant "ApplicationPackageManager" as APM
participant "PackageManagerService" as PMS
participant "ActivityIntentResolver" as AIR
participant "IntentResolver" as IR

PM -> PM: queryIntentActivities
PM -> APM: queryIntentActivitiesAsUser
APM -> PMS: queryIntentActivities
PMS -> PMS: queryIntentActivitiesInternal
PMS -> AIR: queryIntent
AIR -> IR: queryIntent
@enduml