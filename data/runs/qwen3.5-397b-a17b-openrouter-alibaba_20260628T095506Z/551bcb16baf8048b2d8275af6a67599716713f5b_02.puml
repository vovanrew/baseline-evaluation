@startuml
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor Black
  ArrowColor Black
}

class Message {
  + topic : string
  + hdr : Header
  + data : Frame
  --
  getters / setters
  + version()
  + len()
  + data()
  + topic()
}

class Frame {
  + data
  + len
  --
  + Frame(len)
  + Frame(len, data)
  + ~Frame()
  ....
  getters / setters
  + len()
  + get()
  + set(data, len)
}

class Header {
  + version : uint32_t
  + len : uint32_t
  --
}

Message *-- Frame
Message *-- Header

@enduml