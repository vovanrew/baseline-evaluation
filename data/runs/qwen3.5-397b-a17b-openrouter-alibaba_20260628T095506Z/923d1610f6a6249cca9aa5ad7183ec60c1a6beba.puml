@startuml
skinparam classAttributeIconSize 0
skinparam roundcorner 10
skinparam backgroundColor #FFFFFF
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor #000000
  FontName Arial
  FontSize 14
}

class "Client" as Client {
  + anOperation()
}

class "DialectSpeaker" as DialectSpeaker {
  + sayWelcome()
  + sayThanks()
}

Client -- DialectSpeaker

note top of Client
  <b>C</b>
end note

note top of DialectSpeaker
  <b>C</b>
end note

@enduml