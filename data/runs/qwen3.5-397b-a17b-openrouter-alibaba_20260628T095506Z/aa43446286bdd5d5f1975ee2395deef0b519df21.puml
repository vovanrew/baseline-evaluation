@startuml
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classFontName Arial
skinparam classFontSize 14

class App {
  + NameSorter sorter
  + App prog
  + getInput()
}

class NameSorter {
  + ArrayList names
  + addToList()
  + sortList()
  + printList()
}

note right of App
  <b>App</b>
  - Main application class
  - Contains a NameSorter instance
  - Has a static main method (prog)
  - Provides input handling via getInput()
end note

note right of NameSorter
  <b>NameSorter</b>
  - Manages a list of names
  - Supports adding, sorting, and printing names
  - Uses ArrayList for storage
end note

@enduml