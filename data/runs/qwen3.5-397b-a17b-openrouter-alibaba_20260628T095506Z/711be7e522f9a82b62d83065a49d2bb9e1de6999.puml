@startuml
skinparam classAttributeIconSize 0
skinparam classFontColor black
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor black
skinparam classHeaderBackgroundColor #E8E8E8
skinparam classHeaderFontColor black
skinparam classHeaderBorderThickness 1
skinparam classAttributeFontColor black
skinparam classMethodFontColor black
skinparam classMethodIconColor #4CAF50
skinparam classAttributeIconColor #FF5722

class Storage {
    + compressor: Compressor
    + encryptor: Encryptor
    + cacheEngine: CacheEngine
    + useCompression: boolean
    + useEncryption: boolean
    + useCache: boolean
}

class Compressor {
    + compress()
}

class Encryptor {
    + encrypt()
}

class CacheEngine {
    + put()
}

Storage --> Compressor
Storage --> Encryptor
Storage --> CacheEngine

note top of Storage
    <b>C</b>
end note

note top of Compressor
    <b>C</b>
end note

note top of Encryptor
    <b>C</b>
end note

note top of CacheEngine
    <b>C</b>
end note

@enduml