@startuml

abstract class Handler {
  next
  handle()
}

class ConcreteHandler1 {
  handle()
}

class ConcreteHandler2 {
  handle()
}

class ConcreteHandler3 {
  handle()
}

circle client

client --> Handler : handle()

Handler o--> Handler : "*"

ConcreteHandler1 --|> Handler
ConcreteHandler2 --|> Handler
ConcreteHandler3 --|> Handler

@enduml