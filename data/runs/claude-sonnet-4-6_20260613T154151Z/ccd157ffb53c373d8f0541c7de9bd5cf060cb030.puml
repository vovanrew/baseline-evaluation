@startuml

class Starfsmaður {
  nafn string [1]
  kennitala
  heimilisfang
  heimasími
  gsmsími
  netfang
  --
  addEmployee(info)
}

class Bókari {
  recurringVoyage()
  addVoyage()
  addDestination()
  staffVoyage()
}

class Flugbjónn {
}

class Flugmaður {
}

class Vinnuferð {
  Flugstjóri
  aðalflugþjónn
  Flugferð út
  Flugferð inn
  áfangastaður
  dags og tími brottfarar frá Íslandi
  dags og tíma brottfarar til Íslands
  --
  updateVoyage()
  checkPilotsAndAtten()
  staffVoyage()
}

class Áfangastaður {
  land
  flugvöllur
  flugtími
  fjarlægð frá Íslandi
  nafn tengiliðar
  neyðarsímanúmer tengiliðar
}

Flugbjónn -|> Starfsmaður : 1. Flugþjón
Flugmaður -|> Starfsmaður : 2. Flugmenn

Bókari o-- Starfsmaður
Bókari o-- Vinnuferð

Vinnuferð --> Áfangastaður : 1

Bókari ..> Vinnuferð

@enduml