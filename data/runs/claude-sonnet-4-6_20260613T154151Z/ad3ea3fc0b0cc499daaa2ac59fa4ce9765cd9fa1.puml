  + {method} <color:red>IsTileFull(row : int, column: int) : bool</color>
  + ToString() : string
}

class Player {
  # color : char
  + Player(i: int)
  + Put(board : Board)
  + Move(board : Board)
  + Win()
}

class Turn {
  # value : int = 0
  + Turn()
  + Current() «Take»
  + Next() «NotTake»
  + Change()
}

class IO <<static>> {
  + {static} ReadString(title : string) : string
  + {static} ReadInt(title : string) : int
  + {static} Write(title : string)
  + {static} WriteLn()
  + {static} WriteError(format : string)
}

