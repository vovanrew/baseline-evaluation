N1 --> Creature

N2 --> Level_master

Tile --> Level_map : " "
Interactible --> Level_map : " "

Level_master --> Level_map : "friend to"

Creature ..> Creature_AI : "indirect ref."

Level_master ..> Creature_AI

Simple_AI --|> Creature_AI
Ground_melee_AI --|> Creature_AI
Ground_ranged_AI --|> Creature_AI
Flying_melee_AI --|> Creature_AI
Flying_ranged_AI --|> Creature_AI

Level_map o-- Creature
Level_map o-- Tile
Level_map o-- Interactible

@enduml
