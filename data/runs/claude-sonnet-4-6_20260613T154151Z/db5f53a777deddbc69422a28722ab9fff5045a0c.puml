@startuml

class Main {
}

abstract class Target {
  + void printWeak()
  + void printStrong()
}

class Adapter {
  - Banner banner;
  + void printWeak();
  + void printStrong();
}

class Adaptee {
  + void showWithParen()
  + void showWithAster()
}

Main --> Target : Uses
Target <|-- Adapter
Adapter o-- Adaptee

@enduml