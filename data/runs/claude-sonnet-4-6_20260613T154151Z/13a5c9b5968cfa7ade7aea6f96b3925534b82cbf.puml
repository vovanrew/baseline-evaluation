```plantuml
@startuml

interface CarPart {
  + PrintPart()
  + AddPart(v interface{})
  + RemovePart(v interface{})
}

class CylinderBlock
class Sump
class Crankshaft
class Rod

class Engine {
  Container: list.List
}

class Car {
  Container: list.List
}

class Absorber
class Damping
class Stabilizer
class Rack
class Lever
class Spring

class Suspenston {
  Container: list.List
}

CylinderBlock --> Engine
Sump --> Engine
Crankshaft --> Engine
Rod --> Engine

Absorber --> Suspenston
Damping --> Suspenston
Stabilizer --> Suspenston
Rack --> Suspenston
Lever --> Suspenston
Spring --> Suspenston

Engine ..|> CarPart
Suspenston ..|> CarPart

Engine --> Car
Suspenston --> Car

Car ..|> CarPart

@enduml
```