@startuml
title <u>ABSTRACTS's Class Diagram</u>

package "Prototype_AbstractFactory" {
  package "Boxes" {
    package "Abstracts" {
      abstract class Pizza_Box {
        o ID : int
        o address : String
        --
        {abstract} Clone()
        {abstract} FinishBoxing()
        + getAddress()
        + setAddress()
        + setID_order()
        + setLogo()
      }
    }
  }
}

@enduml