@startuml
title カレンダー表示機能

actor ユーザー as user
participant "カレンダー表示機能" as calendar
database "画像DB" as db

ref over user, db : 画像取得 from Locix

user -> calendar : カレンダー表示

group 画像取得
  calendar -> db : 日付単位で画像取得
  db --> calendar : レスポンス
end

group カレンダー表示
  alt [画像取得中]
    calendar --> user : ローディングインジケーター表示
  else [画像取得完了]
    calendar --> user : カレンダーを表示
  end
end

group 一覧表示
  user -> calendar : 撮影日付選択
  calendar --> user : 画像一覧を撮影時間の降順で表示
end

@enduml