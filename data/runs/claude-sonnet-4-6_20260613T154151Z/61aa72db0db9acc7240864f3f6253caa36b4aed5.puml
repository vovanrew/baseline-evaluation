@startuml

title PLAYER's Class Diagram

package "cz" {
  package "kksffn" {
    package "player" {

      interface IPlayer {
        +getCoordinatesOfShips()
        +getGuess()
        +getName()
        +isHuman()
        +updateGuesses()
        +updateGuesses()
      }

      abstract class APlayer {
        {abstract} #coordinatesOfShips : HashMap<ShipName, ArrayList<Integer>>
        {abstract} #isHuman : boolean
        {abstract} #name : String
        +getCoordinatesOfShips()
        +getGuess()
        +getName()
        +isHuman()
        +updateGuesses()
        +updateGuesses()
      }

      class AI {
        +AI()
        +getCoordinatesOfShips()
        +getGuess()
        +updateGuesses()
        +updateGuesses()
        -setName()
      }

      class Human {
        +Human()
        +getCoordinatesOfShips()
        +getGuess()
        -setName()
        -setShips()
      }

      interface IStrategy {
        +findCoordinates()
        +updateGuesses()
        +updateGuesses()
      }

      class Strategy {
        -allGuesses : ArrayList<Integer>
        -allHits : ArrayList<Integer>
        -lastHit : int
        -lastHits : ArrayList<Integer>
        -myChances : int
        -myGuess : int
        -numberOfNotRandomMoves : int
        -rand : Random
        -sunkShips : ArrayList<ShipName>
        +findCoordinates()
        +updateGuesses()
        +updateGuesses()
        -addTheRightCells()
        -addToGuesses()
        -alreadyGuessed()
        -doNotGuessFourth()
        -doNotGuessThird()
        -isNotOnBottom()
        -isNotOnTheLeftEdge()
        -isNotOnTheRightEdge()
        -isNotOnTheTop()
        -shootNextToFirstHitAgain()
        -thinkOfWhatNotToGuess()
        -tryNearestCells()
        -tryToSinkCarrier()
        -updateGuesses()
      }

    }

    package "prepare" {
      class ISetShips {
      }
    }

  }
}

IPlayer <|.. APlayer
APlayer <|-- AI
APlayer <|-- Human
APlayer <-- ISetShips : sea
AI o-- IStrategy : think
IStrategy <|.. Strategy

@enduml