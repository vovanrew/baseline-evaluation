@startuml
class Module {
  EL_metadata: object

  num_cells_x: int
  Num_cells_y: int
  num_cells: int

  make: str
  model: str
  serial_number: str

  parallel_strings: int

  cell_IV: Array of float64

  __Getters__
  EL_metadata()

  __Setters__
  EL_metadata()

  __Methods__
  find_max_exposure()
  is_EL_metadata_sorted()
}

class ELMetadata {
  filepath: str
  module_voltage: float
  module_current: float
  exposure: float
  temperature: float

  cell_highest_pixel: list
  cell_voltage_array: list
  cell_current_array: list

  __Getters__
  filepath()
  module_voltage()
  module_current()
  exposure()
  temperature()
  cell_highest_pixel()

  __Setters__
  filepath()
  module_voltage()
  module_current()
  exposure()
  temperature()
  cell_highest_pixel()
}

ELMetadata -up-|> Module

@enduml