@startuml

class Puzzle {
  grid dimension
  complexity
}

class RowsColumns {
  priorities
  constraints
}

class Solutions {
  general
  row/column
}

class Pixels {
  black
  white
}

class Maker <<actor>> {
  actor
}

class Solver <<actor>> {
  actor
}

Maker "1" -- "*" Puzzle : design
Puzzle "1" -- "*" Solver : solve

Puzzle "1" *-- "*" RowsColumns : contains
Puzzle "1" -- "1" Solutions : contains

RowsColumns "* " -- "* " Solutions

RowsColumns "1" *-- "*" Pixels : contains

@enduml