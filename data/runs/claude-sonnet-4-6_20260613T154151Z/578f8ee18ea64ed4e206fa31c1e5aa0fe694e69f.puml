@startuml

abstract class Klasse {
  navn: String
  beskrivelse: String
  terning: int
}

class Trollmann {
  trylleformler: ArrayList<String>
}

class Barbar {
  raseriAnfall: int
}

class Karakter {
  navn: String
  klasse : Klasse
  level: int
}

Trollmann --|> Klasse
Barbar ..|> Klasse
Karakter --> Klasse

@enduml