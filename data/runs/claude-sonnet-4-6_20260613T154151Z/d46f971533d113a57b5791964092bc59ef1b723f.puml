@startuml
class Account {
  o userdatall
  o admindatall
}

class User {
  o name
  o password
  o IDcard
  o getprice()
  o getdate()
  o getnumber()
  o getplace()
  o bookingtecket()
  o changebooking()
  o returnticket()
}

class Admin {
  o name
  o password
  o changeticket()
}

class TicketSystem {
  o cancel()
  o display()
  o recordticket()
  o recordorder()
  o displayticket()
  o displayorder()
  o update()
  o searchticket()
  o searchorder()
}

class Order {
  o username
  o userId
  o bookingtecket
}

class Ticket {
  o price
  o date
  o number
  o price
}

User --|> Account
Admin --|> Account

User --> TicketSystem
Admin --> TicketSystem

TicketSystem --> Order
TicketSystem --> Ticket

@enduml