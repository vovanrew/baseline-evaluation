@startuml

class ApproveEvent {
  +Render()
  +Home()
  +View()
  +AcceptEvent()
  +RejectEvent()
}

class ResetPassword {
  +Render()
  +Home()
  +ResetPassword(Email : String)
}

class SignUp {
  +Render()
  +Home()
  +SignUp(FName : String, Lname : String, Email : String, Password : String)
  +SignIn()
}

class SendFeedback {
  +Render()
  +Home()
  +SubmitFeedback(Description : String)
  +Cancel()
}

class Admin {
  +Render()
  +Home()
  +View()
  +AcceptUser()
  +RejectUser()
  +BlockUser()
  +DeleteUser()
}

class SignIn {
  +Render()
  +Home()
  +SignIn(Email : String, Password : String)
  +ForgetPassowrd()
  +SignUp()
}

class Index {
  +Render()
  +Home()
  +View()
  +Search(Query : String)
  +JoinEvent()
}

class Dashboard {
  +Render()
  +Home()
  +View()
  +Search(Query : String)
  +AcceptRequest()
  +RejectRequest()
  +EditActivity()
  +EndActivity()
  +CancelRequest()
  +EditRequest()
  +SendFeedback()
}

class Feedbacks {
  +Render()
  +Home()
  +View()
  +Reply()
}

class ReplyFeedback {
  +Render()
  +Home()
  +SubmitReply(Description : String)
  +Cancel()
}

class Reports {
  +Render()
  +Home()
  +DisplayUser(Model : User)
  +DisplayEvent(Model : Event)
  +DisplayFeedback(Model : Feedback)
}

class Profile {
  +Render()
  +Home()
  +EditProfile(FName : String, LName: String, Email : String, Password : String)
  +DiscardChange()
}

class EventManager {
  +Render()
  +Home()
  +View()
  +Search(Query : String)
  +AcceptEvent()
  +RejectEvent()
  +EditEvent()
  +EndEvent()
}

class NewEvent {
  +Render()
  +Home()
  +SubmitEvent(Name : String, Description: String, Dates[] : Date)
  +Cancel()
}

class EditEvent {
  +Render()
  +Home()
  +EditEvent(Name : String, Description: String, Dates[] : Date)
  +DiscardChange()
}

Admin --> Reports
Admin --> ApproveEvent : Admin
SignIn --> ResetPassword
SignIn --> SignUp
SignIn --> Index : User
Index --> Dashboard
Index --> Profile
Index --> EventManager
Dashboard --> Feedbacks
Dashboard --> SendFeedback
Feedbacks --> ReplyFeedback
EventManager --> NewEvent
EventManager --> EditEvent

@enduml