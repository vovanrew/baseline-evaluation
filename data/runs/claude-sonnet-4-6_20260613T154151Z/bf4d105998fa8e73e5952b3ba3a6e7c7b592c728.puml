```plantuml
@startuml

package "com" {
  package "iluwatar" {
    package "dependency" {
      package "injection" {

        class SimpleWizard {
          -{field} tobacco : OldTobyTobacco
          + SimpleWizard()
          + smoke()
        }

        class App {
          + App()
          + {static} main(args : String[])
        }

        class AdvancedWizard {
          -{field} tobacco : Tobacco
          + AdvancedWizard(tobacco : Tobacco)
          + smoke()
        }

        class GuiceWizard {
          -{field} tobacco : Tobacco
          + GuiceWizard(tobacco : Tobacco)
          + smoke()
        }

        class RivendellTobacco {
          + RivendellTobacco()
        }

        class OldTobyTobacco {
          + OldTobyTobacco()
        }

        class SecondBreakfastTobacco {
          + SecondBreakfastTobacco()
        }

        interface Wizard <<interface>> {
          + smoke()
        }

        abstract class Tobacco <<abstract>> {
          + Tobacco()
          + smoke(wizard : Wizard)
        }

        SimpleWizard ..|> Wizard
        AdvancedWizard ..|> Wizard
        GuiceWizard ..|> Wizard

        SimpleWizard --> Tobacco : -tobacco

        AdvancedWizard --> Tobacco : -tobacco
        GuiceWizard --> Tobacco : -tobacco

        RivendellTobacco --|> Tobacco
        OldTobyTobacco --|> Tobacco
        SecondBreakfastTobacco --|> Tobacco

        SimpleWizard ..> AdvancedWizard
        SimpleWizard ..> GuiceWizard

      }
    }
  }
}

@enduml
