@startuml
actor :读者 as reader
actor :图书管理员 as librarian
boundary 还书界面 as ui
entity :还书信息 as info
control :系统 as system

loop
    reader -> librarian : 1.取消预定
    librarian -> ui : 2.处理图书
    ui -> info : 3.获取图书信息
    info --> ui : 4.图书信息
    ui -> system : 5.删除预定记录
    system --> ui : 6.删除预定记录
    ui --> librarian : 7.删除预定成功
    librarian --> reader : 8.处理图成功
    reader <-- librarian : 9.取消预定成功
end

@enduml