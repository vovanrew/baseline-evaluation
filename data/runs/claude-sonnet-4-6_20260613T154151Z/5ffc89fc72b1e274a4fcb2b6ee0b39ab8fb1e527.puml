@startuml

class Account {
  o AccountID : int
  o FirstName : string
  o LastName : string
  o EmailAddressUsername : string
  o password : string
  o AccountCreatedDatetime : datetime
  o isArchived : boolean
  --
  createAccount()
  deleteAccount()
  editAccount()
  forgotPassword()
}

class Recipe {
  o recipeID : int
  o recipeName : string
  o servings : int
  o prepTime : time
  o cookTime : time
  o totalTime : time
  o isFavorite : boolean
  --
  createRecipe()
  editRecipe()
  deleteRecipe()
  saveRecipe()
}

class RecipeImage {
  o RecipeImageID : int
  o RecipeImagePath : int
  o isArchived : boolean
  --
  AddPhoto()
  DeletePhoto()
}

class Ingredient {
  o IngredientID : int
  o IngredientText : string
  o IngredientAmount : int
  o isArchived : boolean
  --
  AddIngredient()
  EditIngredient()
  DeleteIngredient()
}

class Instructions {
  --
  getSteps()
}

class Measurement {
  o MeasurementID : int
  o MeasurementText : string
  --
  getMeasurement()
}

class Step {
  o StepID : int
  o InstructionStepText : string
  o StepNumberOrder : int
  o isArchived : boolean
  --
  AddStep()
  EditStep()
  RemoveStep()
}

Account "0..*" -- "1" Recipe
Recipe "1" -- "1" RecipeImage
Recipe "1" *-- "*" Ingredient
Recipe "1" *-- "1" Instructions
Ingredient "1" *-- "1" Measurement
Instructions "1" -- "*" Step

@enduml