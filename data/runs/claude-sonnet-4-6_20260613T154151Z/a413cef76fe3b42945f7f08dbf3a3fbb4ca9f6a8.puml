@startuml

title 接口隔离原则

class A
class B
class C
class D

interface Interface1 {
  + operation1():void
}

interface Interface2 {
  + operation2():void
  + operation3():void
}

interface Interface3 {
  + operation4():void
  + operation5():void
}

A .down.> Interface2 : use
A .down.|> Interface2

B .down.|> Interface1
B .down.> Interface1 : use

C .down.> Interface1 : use
C .down.|> Interface3

D .down.> Interface3 : use
D .down.|> Interface3

A ..> Interface2
A ..|> Interface2
B ..|> Interface1
B ..> Interface1
C ..> Interface1
C ..|> Interface3
D ..> Interface3
D ..|> Interface3

@enduml