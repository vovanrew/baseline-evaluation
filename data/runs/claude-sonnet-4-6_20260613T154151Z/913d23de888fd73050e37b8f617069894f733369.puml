```plantuml
@startuml

interface Account {
  {abstract} applyMonthlyChange()
}

class CreditAccount {
  ...someAttribute
  --
  applyMonthlyInterest()
  applyMonthlyChange()
  ...someOtherMethod()
}

class DebitAccount {
  ...someAttribute
  --
  applyMonthlyInterest()
  deactivateIfUnderBalanced()
  applyMonthlyChange()
  ...someOtherMethod()
}

class PayrollAccount {
  ...someAttribute
  --
  applyMonthlyChange()
  ...someMethod()
}

class Bank {
  accounts:[Account]
  --
  applyAllMonthlyChanges()
}

note right of Bank
  applyAllMonthlyChanges(){
    ...
    for every account a in accounts{
      a.applyMonthlyChange
    }
  }
end note

CreditAccount ..|> Account
DebitAccount ..|> Account
PayrollAccount ..|> Account
Bank --> Account

@enduml
```