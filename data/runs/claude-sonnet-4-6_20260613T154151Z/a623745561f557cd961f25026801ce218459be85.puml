@startuml

package "org" {
  package "accordproject" {
    package "empty" {
      class "EmptyClause" << (A,green) >>
      class "EmptyRequest" << (T,yellow) >>
      class "EmptyResponse" << (T,yellow) >>
    }

    package "contract" {
      class "Clause" << (C,lightgreen) >>
    }

    package "runtime" {
      class "Request" << (C,lightgreen) >>
      class "Response" << (C,lightgreen) >>
    }
  }
}

EmptyClause --|> Clause
EmptyRequest --|> Request
EmptyResponse --|> Response

@enduml