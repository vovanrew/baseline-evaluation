@startuml

package "InheritanceDesign" {
  class Bond <<C>>
  class Stock <<C>>
  class Car <<C>>
  class House <<C>>
  class Wealth <<C>>
  abstract class Security <<A>>
  class BankAccount <<C>>
  abstract class Property <<A>>
  abstract class Asset <<A>>
}

package "java" {
  package "lang" {
    annotation Override <<@>>
  }
}

Bond --|> Security
Stock --|> Security
Car --|> Property
House --|> Property

Security --|> Asset
BankAccount --|> Asset
Property --|> Asset

Bond ..> Override
Stock ..> Override
Car ..> Override
House ..> Override
Wealth ..> Override
Property ..> Override

@enduml