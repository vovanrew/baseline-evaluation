```plantuml
@startuml
box "drv-ns16550" #E5E5E5
participant "入出力制御" as IO
participant "転送制御" as Transfer
participant "デバイス\nファイル管理" as DeviceFile
end box
participant "MLib" as MLib

ref over DeviceFile
  デバイスファイル管理
  状態遷移Task32
end ref

activate DeviceFile
DeviceFile -> Transfer : 転送要求( COM1/2 )
activate Transfer
Transfer -> MLib : スピンロック( COM1/2 )
activate MLib
MLib --> Transfer
deactivate MLib

opt [転送状態 == 転送停止中]
  Transfer -> IO : IER書込み\n( COM1/2, [1]=1 )
  note right: THR割込み許可
  activate IO
  ref over IO
    入出力制御
    デバイス書込み
  end ref
  IO --> Transfer
  deactivate IO
  Transfer -> Transfer : 転送状態設定( 転送中 )
end

Transfer -> MLib : スピンアンロック( COM1/2 )
activate MLib
MLib --> Transfer
deactivate MLib
Transfer --> DeviceFile
deactivate Transfer
deactivate DeviceFile

@enduml
```