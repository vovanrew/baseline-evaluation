@startuml
package xxx <<Rectangle>> {
    interface Shape {
        void draw()
    }

    class Circle {
        void draw()
    }

    class Rectangle {
        void draw()
    }

    class Square {
        void draw()
    }

    Circle -up-> Shape : implement
    Rectangle -up-> Shape : implement
    Square -up-> Shape : implement
}

class ShapeFactory {
    Shape getShape()
}

class FactoryPatternDemo {
    void main()
}

ShapeFactory -left-> xxx : create
FactoryPatternDemo -up-> ShapeFactory : ask

@enduml
