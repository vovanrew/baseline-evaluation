```plantuml
@startuml
enum State {
  FLOOR_OUT_SIDE,WALL,FLOOR,BOX,TARGET,PLAYER,BOX_ON_TARGET
}

enum TileType {
  WALL,FLOOR,TARGET
}

enum TileFlag {
  NULL,PLAYER,BOX
}

enum Directory {
  UP,DOWN,LEFT,RIGHT,SITU
}

class Game {
  - clock_t start
  - clock_t end
  - int curLevel
  - {const}int MAX_LEVEL
  - bool isFinish
  - bool isQuit
  - Session* curSession
  - handleCmd(char)
  - handleStartCmd(char)
  - initSession()
  - startSession()
  - endSession()
  + start()
  + isFinish()
  + getDuration()
}

class Session {
  - level
  - map
  - step
  - isFinish
  + move(Direction)
  + getMap()
  + finish()
  + isFinish()
  + getLevel()
  + backToPreviousPlace()
  + restart()
}

class MapRepository {
  + {static} MAP_PATH:string
  + {static} MAP_DIR:string
  + MAP_ID:enum
  + MapBuffer:class
  + getMap(MAP_ID)
}

interface Viewer {
  + getInput()
  + getLevel()
  + display()
}

class Map {
  - width:int
  - height:int
  - tiles:TileMap
  - MovableList:vector
  - player:Player
  - Tile:OUT_SIDE_TILE
  - getTile()
  - moveBox()
  + getWidth()
  + getHeight()
  + initMap(const string&)
  + getStateOf(const Position&)
  + getBoxs()
  + getPlayerPosition()
  + back()
}

class Rule {
  + isWin(const Map&)
  + isRightMove(const Map&,Direction)
}

class FileUtil {
  + readFile()
}

class Player {
  + move(Direction)
  + getPreviousDirection()
  + getPreviousPushFlag()
  + clear()
}

class Box {
  - onTarget:bool
  + moveToTile(TileType)
  + getOnTarget()
}

class Tile {
  - position:Position
  - type:TileType
  - flag:TileFlag
  + setPosition(const Position&)
  + getPosition()
  + setFlag(TileFlag)
  + getType()
  + getState()
}

class Moveable {
  - position:Position
  - state:
  + {virtual}move(Direction)
  + back(Direction)
  + getPosition()
  + setPosition(const Position&)
}

class Position {
  - x:int
  - y:int
  + {static} DIRS
  + operator==(const Position&)
  + opeartor+=(const Position&)
  + getX()
  + getY()
  + {static} of(int,int)
}

Game *-- Session
Game *-- MapRepository
Game *-- Viewer
Session *-- Map
Session *-- Rule
MapRepository *-- FileUtil
Map *-- Player
Map *-- Box
Map *-- Tile
Player <|-- Moveable
Box <|-- Moveable
Tile *-- Position

@enduml
```