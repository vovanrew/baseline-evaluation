```plantuml
@startuml
abstract class WordFinder {
  fileCreator()
  replaceInString()
}

class String {
  revised
  content
  file
  str
  replaceAll()
}

class PrintWriter {
  out
  writer
  close()
  println()
}

class Files {
  readString
}

class Scanner {
  input
  nextLine()
}

String -left-|> WordFinder
PrintWriter -up-|> WordFinder
Files -up-|> WordFinder
Scanner -up-|> WordFinder
@enduml
```