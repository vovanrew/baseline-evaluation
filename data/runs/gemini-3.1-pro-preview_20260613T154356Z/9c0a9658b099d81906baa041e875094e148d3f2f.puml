  + agregarObjetivo(objetivo: Objetivo)
  + posicionarEnRelevos(pais: String, cantidad: Int): Boolean
  + quitarPais(unPais: Pais): void
}

abstract class Ronda {
  # Jugador[] jugadores
  # numeroDeRonda: Int
  # turno: Turno
  + {abstract} atacarAConEjercitos(paisDefensor: String, paisAtacante: String, ejercitos: Int)
  + {abstract} posicionarEnRelevos(pais: String, cantidad: Int): Ronda
}

class RondaDeCarga {
  + atacarAConEjercitos(paisDefensor: String, paisAtacante: String, ejercitos: Int)
  + posicionarEnRelevos(pais: String, cantidad: Int): Ronda
}

class RondaDeAtaque {
  + atacarAConEjercitos(paisDefensor: String, paisAtacante: String, ejercitos: Int)
  + posicionarEnRelevos(pais: String, cantidad: Int): Ronda
}

class Pais {
  - cantidad: Int
  - continente: String
