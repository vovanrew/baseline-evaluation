package tictactoe {
  package controllers {
    class Controller {
      ~ Controller(Game)
      + getToken(Coordinate): Token
    }
    class Logic {
      + Logic()
      + getMaxPlayers(): int
      + setUsers(int)
      + getToken(): Token
      + next()
      + isBoardComplete(): boolean
      + isTicTacToe(): boolean
      + isUser(): boolean
      + put(Coordinate): Error
      + move(Coordinate, Coordinate): Error
      + getToken(Coordinate): Token
      + resume()
    }
    class StartController {
      + StartController(Game)
      + setUsers(int)
      + getMaxPlayers(): int
    }
    class ResumeController {
      + ResumeController(Game)
      + resume()
    }
    class PlayController {
      + PlayController(Game)
      + isBoardComplete(): boolean
      + isTicTacToe(): boolean
      + getToken(): Token
      + isUser(): boolean
      + put(Coordinate): Error
      + move(Coordinate, Coordinate): Error
    }
  }
}

