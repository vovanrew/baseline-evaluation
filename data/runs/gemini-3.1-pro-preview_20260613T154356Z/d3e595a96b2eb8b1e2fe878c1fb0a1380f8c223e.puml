```plantuml
@startuml
actor Usuario
boundary boundary
control control
collections Equipos
participant ":Equipo" as Equipo

Usuario -> boundary : expelTeam(data)
activate boundary
boundary -> control
activate control
control -> Equipos : expelTeam(data)
activate Equipos
Equipos -> Equipo
deactivate Equipos
deactivate control
deactivate boundary
@enduml
