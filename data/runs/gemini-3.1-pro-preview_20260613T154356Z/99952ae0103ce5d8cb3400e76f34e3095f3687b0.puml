@startuml
title SOURCE's Class Diagram

package model {
  package data {
    package source {
      abstract class Collector {
        + Collector()
        + getDatumLinkListByTree()
        + getEntityDescription()
        + getEntityName()
        + getQualifiers()
        + getReferences()
        + getSingleStatement()
        + getStatementList()
        + triggerLoad()
        + triggerSave()
      }

      class WebCollector {
        # {static} loaded : Entities
        - gson : Gson
        - {static} seen : ArrayList<Entities>
        + WebCollector()
        + getDatumLinkListByTree()
        + getEntityDescription()
        + getEntityName()
        + getQualifiers()
        + getReferences()
        + getSingleStatement()
        + getStatementList()
        + triggerLoad()
        + triggerSave()
        # getJson()
        - {static} formatURL()
        - iterateSnaks()
        - tryGetQualifiers()
      }

      class LocalCollector {
        + LocalCollector()
        + triggerSave()
        # getJson()
      }

      class LocalRepository {
        - file : File
        + LocalRepository()
        + load()
        + save()
      }

      Collector <|-- WebCollector
      WebCollector <|-- LocalCollector
      Collector o-- LocalRepository : repository
    }
  }
}

@enduml
