```plantuml
@startuml
package InheritanceDesign {
    class Bond
    class Stock
    class Car
    class House
    class Wealth
    abstract class Security
    class BankAccount
    abstract class Property
    abstract class Asset

    Bond --|> Security
    Stock --|> Security
    Car --|> Property
    House --|> Property
    Security --|> Asset
    BankAccount --|> Asset
    Property --|> Asset
}

package java.lang {
    annotation Override
}

Bond ..> Override
Stock ..> Override
Car ..> Override
House ..> Override
Wealth ..> Override
BankAccount ..> Override
@enduml
