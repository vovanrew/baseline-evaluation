```plantuml
@startuml
class Metric {
  resultCompare()
  sendNotification()
}

class DataSet {
  value
  date
  dataSetType
  getValue()
  getDate()
  getDataSetType()
  ==return==
  return date to compare
  and info about metric type
}

class ResultCompare {
  currentValue
  previousValue
  dataSetType
  CmpMethods()
  ==return==
  (-1;0;1)
}

class Notification {
  sendTo
  message
  sendMethod()
  ==return==
  send message
}

class SendMethod {
  sendMethod()
  ==return==
  send method
}

class CmpMethods {
  cmpMethod()
  ==return==
  select method
}

Metric ..> ResultCompare
Metric ..> Notification
ResultCompare .left.> DataSet
ResultCompare ..> CmpMethods
Notification .right.> SendMethod

@enduml
```