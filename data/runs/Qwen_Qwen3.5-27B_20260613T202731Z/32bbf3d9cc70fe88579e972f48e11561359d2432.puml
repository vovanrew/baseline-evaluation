@startuml
skinparam classAttributeIconSize 0

package "xxx" {
    interface Shape {
        + void draw()
    }

    class Circle {
        + void draw()
    }

    class Rectangle {
        + void draw()
    }

    class Square {
        + void draw()
    }
}

class ShapeFactory {
    + Shape getShape()
}

class FactoryPatternDemo {
    + void main()
}

Circle --|> Shape : implement
Rectangle --|> Shape : implement
Square --|> Shape : implement

FactoryPatternDemo --> ShapeFactory : ask
ShapeFactory --> Shape : create

@enduml
