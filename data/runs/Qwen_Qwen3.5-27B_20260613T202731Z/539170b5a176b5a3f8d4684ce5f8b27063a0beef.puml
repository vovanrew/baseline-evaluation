@startuml
package "InheritanceDesign" {
  class Asset <<A>>
  class Security <<A>>
  class Property <<A>>
  class BankAccount <<C>>
  class Bond <<C>>
  class Stock <<C>>
  class Car <<C>>
  class House <<C>>
  class Wealth <<C>>

  Security --|> Asset
  Property --|> Asset
  BankAccount --|> Asset
  Bond --|> Security
  Stock --|> Security
  Car --|> Property
  House --|> Property
}

package "java" {
  package "lang" {
    class Override <<@Override>>
  }
}

Bond ..> Override
Stock ..> Override
Car ..> Override
House ..> Override
Wealth ..> Override
BankAccount ..> Override
