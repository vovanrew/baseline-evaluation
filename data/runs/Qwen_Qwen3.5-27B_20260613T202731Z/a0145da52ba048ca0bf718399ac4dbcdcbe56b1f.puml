```plantuml
@startuml
skinparam classAttributeIconSize 0

package "Modulo-matrícula/Informática" {
    class "Matrícula" as Matricula {
        C << (C,Green) >>
        -id: Int
        -cliente: Client
        -tempo: Int
        -quadra: Turma
        +registraMatrícula(): Int
    }

    class "Aluno" as Aluno {
        C << (C,Green) >>
        -id: Int
        -nome: String
        -locação: List<Matrícula>
    }

    interface ControleNúmeroMatrícula {
        I << (I,Purple) >>
        #quantidadeDeMatrícula: Int
        +registraMatrícula(): Int
    }

    class "Turma" as Turma {
        C << (C,Green) >>
        -numero: Int
        -aluguel: Matrícula
        -ginasio: Curso
        +getcontroleNúmeroMatrícula()
    }

    class "Curso" as Curso {
        C << (C,Green) >>
        -nome: String
        -profesor: String
        -quadra: List<Turma>
    }

    ' Relationships
    Aluno "1" *-- "0..*" Matricula : composição
    Matricula ..|> ControleNúmeroMatrícula : realização
    Turma ..> ControleNúmeroMatrícula : dependência
    Turma "1" *-- "1..*" Matricula : composição >
    Curso "1" *-- "1..*" Turma : composição
}
@enduml
