```plantuml
@startuml
class Client {
    +main(): void
}

package states {
    class Originator {
        -state: String
        +setState(state: String): void
        +getState(): String
        +saveStateToMemento(): Memento
        +recoverStateFromMemento(memento: Memento): void
    }

    class CareTaker {
        -mementos: List<Memento> = new ArrayList<>()
        +add(memento: Memento): void
        +get(index: int): Memento
    }

    class Memento {
        -state: String
        +Memento(state: String): void
        +getState(): String
    }
}

Originator --> Memento
CareTaker o-- Memento
Client --> states

@enduml
```