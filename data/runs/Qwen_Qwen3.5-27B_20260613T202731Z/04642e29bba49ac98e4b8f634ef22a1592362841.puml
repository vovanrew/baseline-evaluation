```plantuml
@startuml
skinparam participantStyle rectangle

participant "User" as User
participant A
participant B
participant C

activate A
User -> A: DoWork
activate B
A -> B: «createRequest»
activate C
B -> C: DoWork
C --> B: WorkDone
deactivate C
destroy C
B --> A: RequestCreted
deactivate B
A --> User: Done
deactivate A

@enduml
