```plantuml
@startuml
skinparam classAttributeIconSize 10

package "Sistema_de_Cobranças" {
    class Cliente {
        C
        +id: Int
        +nome: String
        +cobranças: List<Cobrança>
        +fazerPagamento()
    }

    class Cobrança {
        C
        +id: Int
        +cliente: Client
        +quitado: Boolean
        +gerarBoleto()
        +consultaBoleto(): Boolean
    }

    class Boleto {
        C
        +id: Int
        +validade: Date
        +valor: Float
        +
    }

    interface GerarBoleto {
        I
        <<interface>>
    }

    interface PagarBoleto {
        I
        <<interface>>
        +fazerPagamento()
    }

    Cliente "1" --o "0..*" Cobrança : 
    Cobrança "1" *-- "1" Boleto : 
    Cliente ..|> PagarBoleto : 
}
@enduml
