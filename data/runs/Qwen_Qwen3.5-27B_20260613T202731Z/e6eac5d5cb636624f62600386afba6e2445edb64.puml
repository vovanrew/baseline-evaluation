    + toDTUser()
}

protocol DTAbstractAuthProvider {
    # user: DTUser?
    + signUp(email:password:displayName:)
    + login(email:password:)
}

struct DTUser {
    ~ uid: String
    ~ displayName: String
    ~ email: String
}

