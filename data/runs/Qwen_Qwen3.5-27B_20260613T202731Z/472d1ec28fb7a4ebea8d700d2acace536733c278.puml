```plantuml
@startuml
title login by token

actor "学术袁" as User
participant "App客户端" as App
participant "后台服务器" as Server

User -> App : 启动
activate App
App -> App : 检测本地登录信息
deactivate App

alt [有本地记录]
    alt [token有效]
        App -> Server : token自动登陆
    else [token无效]
        App -> User : 提示登录
        User -> App : 输入手机号+密码
        activate App
        App -> Server : 手机号+密码登录
        Server --> App : 返回新的token
        App -> App : token保存
        deactivate App
    end
else [无本地记录]
    App -> User : 提示输入手机号
    User -> App : 请求发送验证码
    activate App
    App -> Server : 请求发送验证码
    Server --> App : 返回验证码
    deactivate App
    
    User -> App : 输入验证码
    activate App
    App -> Server : 请求后台验证
    
    alt [已注册]
        Server --> App : 提示登录
        deactivate App
        App -> User : 提示登录
        User -> App : 输入手机号+密码
        activate App
        App -> Server : 手机号+密码登录
        Server --> App : 返回新的token
        App -> App : token保存
        deactivate App
    else [未注册]
        Server --> App : 提示注册
        deactivate App
        App -> User : 提示注册
        User -> App : 输入两次密码
        activate App
        App -> Server : 请求注册
        Server --> App : 返回新的token
        App -> App : token保存
        deactivate App
    end
end

@enduml
```