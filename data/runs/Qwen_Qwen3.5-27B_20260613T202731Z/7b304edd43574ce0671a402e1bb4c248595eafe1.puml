package "dao" {
    interface DAO {
        + findId(T id : T) : T
        + create(T obj : T) : T
        + update(T obj : T) : T
        + delete(T obj : T) : boolean
    }

    class QuestionDao {
        + OfferDao()
        + getInstance() : QuestionDao
        + LazyHolder()
        + getQuestionsByOfferedId(offerId : int) : ArrayList<Question>
        + questionExists(id : int) : boolean
        + hasAnAnswer(id : int) : boolean
    }

    class AnswerDao {
        + OfferDao()
        + getInstance() : QuestionDao
        + LazyHolder()
        + getAnswersByOfferedId(offerId : int) : ArrayList<Answer>
        + answerExists(id : int) : boolean
    }

    class AbstractFactoryDao {
        - final connectionDB : ConnectionDB
        + getFactory(type : TypeDB) : AbstractFactoryDao
        + getAnswerDao() : AnswerDao
        + getQuestionDao() : QuestionDao
    }

    class FactoryDaoMySQL {
    }

    class QuestionDaoMySQL {
    }

    class AnswerDaoMySQL {
    }
}

package "db" {
    class ConnectionDB {
    }

    class ConnectionDBMySQL {
        # connection : Connection
        + ConnectionDBMySQL()
        + getConnection() : ConnectionDBMySQL
        + getDB() : Connection
    }

    class LazyHolderDB {
        - final INSTANCE : ConnectionDBMySQL
    }
}

DAO <|.. QuestionDao
DAO <|.. AnswerDao
