```plantuml
@startuml
class Message {
    - topic : string
    - hdr : Header
    - data : Frame
    + version()
    + len()
    + data()
    + topic()
}

class Frame {
    - data
    - len
    + Frame(len)
    + Frame(len, data)
    + ~Frame()
    + len()
    + get()
    + set(data, len)
}

class Header {
    + version : uint32_t
    + len : uint32_t
}

Message *-- Frame
Message *-- Header
@enduml
```