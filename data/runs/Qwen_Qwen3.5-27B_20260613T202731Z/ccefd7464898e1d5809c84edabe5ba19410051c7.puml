class ShapeFactory {
    Shape getShape()
}

ShapeFactory --|> AbstractFactory : extends
ShapeFactory --> "shape" as shapeGroup : create

class ColorFactory {
    Color getColor()
}

ColorFactory --|> AbstractFactory : extends
ColorFactory --> "color" as colorGroup : create

