```plantuml
@startuml
skinparam classAttributeIconSize 0

class "Matrícula" as Matricula {
    -cliente: Client
    -tempo: Int
    -quadra: Turma
}

class "Aluno" as Aluno {
    -id: Int
    -nome: String
    -locação: List<Matrícula>
}

class "Curso" as Curso {
    -nome: String
    -quadra: List<Turma>
}

class "Turma" as Turma {
    -numero: Int
    -aluguel: Matrícula
    -ginasio: Curso
}

class "controleNúmeroMatrícula" as ControleNumeroMatricula {
    -quantidade: Int
}

' Relationships
Aluno "1" *-- "0..*" Matricula : composição
Curso "1" *-- "1..*" Turma : composição
Turma "1" *-- "1..*" Matricula : composição
ControleNumeroMatricula <|-- Turma

@enduml
```