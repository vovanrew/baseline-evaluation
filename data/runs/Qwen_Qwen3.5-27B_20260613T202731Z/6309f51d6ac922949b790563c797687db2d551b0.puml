    activate SystemC
    deactivate SystemC
deactivate Facade

' Operation Phase
activate Facade
Client -> Facade: 5 wrapOpration()
activate Facade
    Facade -> SystemA: 6 operationA()
    activate SystemA
    deactivate SystemA
    
    Facade -> SystemB: 7 operationB()
    activate SystemB
    deactivate SystemB
    
    Facade -> SystemC: 8 operation()
    activate SystemC
    deactivate SystemC
deactivate Facade
