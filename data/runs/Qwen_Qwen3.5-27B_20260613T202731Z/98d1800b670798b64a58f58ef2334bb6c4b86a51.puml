```plantuml
@startuml
skinparam shadowing false
skinparam actor {
  BackgroundColor<<<<<<< LightGray
  BorderColor Black
}
skinparam rectangle {
  BackgroundColor LightGray
  BorderColor Black
}

actor "Player" as Player
rectangle "Game" as Game
rectangle "Screen" as Screen
rectangle "Line" as Line
rectangle "Figure" as Figure

Player -> Game : Reset
Game -> Screen : Reset
Screen -> Line : Reset
Line --> Game
Game -> Figure : Create
Figure --> Player

@enduml
```