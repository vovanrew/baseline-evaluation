```plantuml
@startuml
class Metric {
    +resultCompare()
    +sendNotification()
}

class DataSet {
    +value
    +date
    +dataSetType
    +getValue()
    +getDate()
    +getDataSetType()
    return date to compare and info about metric type
}

class ResultCompare {
    +currentValue
    +previousValue
    +dataSetType
    +CmpMethods()
    return (-1;0;1)
}

class CmpMethods {
    +cmpMethod()
    return select method
}

class Notification {
    +sendTo
    +message
    +sendMethod()
    return send message
}

class SendMethod {
    +sendMethod()
    return send method
}

Metric ..> ResultCompare
Metric ..> Notification
ResultCompare ..> CmpMethods
Notification --> SendMethod
ResultCompare <-- DataSet

@enduml
```