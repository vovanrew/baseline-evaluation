```plantuml
@startuml
skinparam classAttributeIconSize 0

interface HouseBuilder {
    + void buildBasic()
    + void buildBody()
    + void buildRoof()
    + House finish()
}

class CommonHouseBuilder {
    - House house
    + void buildBasic()
    + void buildBody()
    + void buildRoof()
    + House finish()
}

class LuxuryHouseBuilder {
    - House house
    + void buildBasic()
    + void buildBody()
    + void buildRoof()
    + House finish()
}

class Decorate {
    - HouseBuilder houseBuilder
    + House construct()
}

class House {
    - String type
    - boolean base
    - boolean body
    - boolean roof
}

class Client

HouseBuilder <|-- CommonHouseBuilder
HouseBuilder <|-- LuxuryHouseBuilder
HouseBuilder <|-- Decorate

CommonHouseBuilder o--> House
LuxuryHouseBuilder o--> House

Client --> Decorate

note right of House : 具体产品类
note left of Decorate : 具体建造对象

@enduml
```