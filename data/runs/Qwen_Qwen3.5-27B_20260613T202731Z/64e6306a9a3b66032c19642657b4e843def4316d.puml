```plantuml
@startuml
class Member {
    C
    + userId
    + email
    + password
    + login()
    + register()
    + updateProfile()
}

class Customer {
    C
    + customerName
    + tel
    + address
}

class Admin {
    C
    + adminName
    + approveOrder()
    + report()
}

class Order {
    C
    + orderId
    + date
    + price
    + userId
    + customerName
    + status
    + Shippingaddress
    + updateOrder()
    + placeOrder()
    + cancelOrder()
    + makePayment()
    + informPayment()
}

class OrderDetail {
    C
    + odId
    + orderId
    + productId
    + quantity
}

class Product {
    C
    + productId
    + productName
    + productDetail
    + images
    + price
    + addToOrder()
}

Member <|-- Customer
Member <|-- Admin
Customer "1" *-- "0..n" Order : 
Admin "1" --> "0..n" Order : Manage
Order "1" *-- "1" OrderDetail : 
OrderDetail "1" *-- "1..n" Product : 
Customer "1" --> "0..n" Product : View
Admin "1" --> "0..n" Product : Manage

@enduml
```