package "offset" {
    class OffsetProcessor {
        <<interface>>
        - Logger logger
        - AtomicBoolean processingOffsets
        - ConcurrentLinkedDeque<Optional<OFFSET>> offsets
        - GenericOffsetTableFuture<OFFSET> offsetTable
        - Consumer<Exception, OFFSET> exceptionHandler
        - Executor executor
        + void saveOffset(CompletableFuture<Optional<OFFSET>>)
        + void processOffsets(Runnable, Optional<OFFSET>, Throwable)
        + void processOffsets(Runnable, Optional<OFFSET>)
