@startuml
package "events" {
    package "cdc" {
        package "connector" {
            package "db" {
                package "transaction" {
                    package "log" {
                        package "converter" {
                            class TransactionLogEntryConverter {
                                <<interface>>
                                + Optional<TLM> convert(TransactionLogEntry)
                            }

                            class TransactionLogEntryConverterFactory {
                                <<factory>>
                            }

                            class TransactionLogEntryToMessageWithDestinationConverter {
                                <<converter>>
                                + IBCGenerator getGenerator()
                                + Optional<MessageWithDestination> convert(TransactionLogEntry)
                            }

                            class TransactionLogEntryToEventWithSourcingConverter {
                                <<converter>>
                                + IBCGenerator getGenerator()
                                + Optional<EventWithSourcing> convert(TransactionLogEntry)
                            }
                        }
                    }
                }
            }
        }
    }
}

package "messaging" {
