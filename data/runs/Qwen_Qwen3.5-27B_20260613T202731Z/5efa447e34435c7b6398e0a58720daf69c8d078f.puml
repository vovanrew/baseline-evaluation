        + Optional<OFFSET> getOffset(CompletableFuture<Optional<OFFSET>>)
        + boolean isDone(CompletableFuture<Optional<OFFSET>>)
        + AtomicInteger getInProgressOffsetCount()
    }

    class GenericOffsetTable {
        <<interface>>
        + void save(OFFSET)
    }

    class OffsetStore {
        <<interface>>
        + Optional<TransactionLogOffset> getLastTransactionLogOffset()
        + void save(TransactionLogOffset)
    }
}

package "entry" {
    class TransactionLogEntryHandler {
        <<interface>>
        - SchemaAndTable schemaAndTable
        - TransactionLogEntryConverter<TLM> transactionLogEntryConverter
        - Function<TLM,CompletableFuture<Void>> publisher
        + String getQualifiedTable()
        + SchemaAndTable getSchemaAndTable()
        + boolean isPrimaryKeyNull(TLM)
        + CompletableFuture<Void> publish(TransactionLogEntry)
    }

    class TransactionLogEntry {
        - Object getColumnName()
        - TransactionLogOffset getTransactionLogOffset()
        - boolean getIsNewColumn(String)
        - Long getLongColumn(String)
        - String getOnlyColumn(String)
    }
}

TransactionLogEntryConverter ..|> TransactionLogEntryConverterFactory : creates
TransactionLogEntryToMessageWithDestinationConverter ..|> TransactionLogEntryConverter : implements
TransactionLogEntryToEventWithSourcingConverter ..|> TransactionLogEntryConverter : implements
MessageWithDestination ..|> TransactionLogMessage : implements
EventWithSourcing ..|> TransactionLogMessage : implements
OffsetProcessor ..|> GenericOffsetTable : uses
OffsetStore ..|> OffsetProcessor : uses
TransactionLogEntryHandler ..|> TransactionLogEntry : processes

