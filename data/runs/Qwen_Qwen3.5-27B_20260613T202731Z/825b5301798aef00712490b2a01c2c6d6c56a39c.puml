@startuml
class Groupe {
    +Groupe()
    +ajouterEtudiant(Etudiant etudiant)
    +supprimerEtudiant(Etudiant etudiant)
    +calculerMoyenneMatiereGroupe(String matiere) : float
    +calculerMoyenneGeneraleGroupe() : float
