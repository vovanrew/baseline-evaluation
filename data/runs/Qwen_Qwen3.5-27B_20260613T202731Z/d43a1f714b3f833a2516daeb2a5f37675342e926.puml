```plantuml
@startuml
class Personaje {
    <<abstract>>
    - string nombre
    - string correo
    - int telefono
    - Mundo* mundo
    + Personaje()
    + Personaje(string nombre)
    + virtual Personaje* clone()
}

class Princesa {
    + Princesa(string n)
    + Princesa(const Princesa& p)
    + void gritar()
}

class Villano {
    + Villano(string n)
    + Villano(const Villano& v)
    + void secuerstrar()
}

class Heroe {
    + Heroe(string n)
    + Heroe(const Heroe& h)
    + void salvar()
}

class SubClase {
    <<template>>
    + T* clone()
}

class Mundo {
    - string nombreMundo
    + Mundo(string nombreMundo)
}

Personaje <|-- Princesa
Personaje <|-- Villano
Personaje <|-- Heroe
SubClase <|-- Personaje
Princesa --|> SubClase
Villano --|> SubClase
Heroe --|> SubClase
Mundo *-- Personaje

@enduml
