```plantuml
@startuml
abstract class "Strategy" as Strategy {
    <<interface>>
    + algorithm()
}

class "ConcreteStrategy" as ConcreteStrategy {
    + algorithm()
}

class "Context" as Context {
    - strategy
    + operation()
}

ConcreteStrategy ..|> Strategy
Context o-- Strategy : -strategy

note right of Context.operation()
  strategy.algorithm();
end note

skinparam packageStyle rectangle
@enduml
