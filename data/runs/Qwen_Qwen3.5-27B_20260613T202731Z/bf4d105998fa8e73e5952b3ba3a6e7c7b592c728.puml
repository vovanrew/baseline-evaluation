@startuml
namespace com {
  namespace iluwatar {
    namespace dependency {
      namespace injection {
        package "com.iluwatar.dependency.injection" {
          interface Wizard {
            <<I>>
            + smoke()
          }

          class SimpleWizard {
            <<C>>
            - tobacco : OldTobyTobacco
            + SimpleWizard()
            + smoke()
          }

          class AdvancedWizard {
            <<C>>
            - tobacco : Tobacco
            + AdvancedWizard(tobacco : Tobacco)
            + smoke()
          }

          class GuiceWizard {
            <<C>>
            - tobacco : Tobacco
            + GuiceWizard(tobacco : Tobacco)
            + smoke()
          }

          class App {
            <<C>>
            + App()
            + main(args : String[])
          }

          abstract class Tobacco {
            <<A>>
            + Tobacco()
            + smoke(wizard : Wizard)
          }

          class RivendellTobacco {
            <<C>>
            + RivendellTobacco()
          }

          class OldTobyTobacco {
            <<C>>
            + OldTobyTobacco()
          }

          class SecondBreakfastTobacco {
            <<C>>
            + SecondBreakfastTobacco()
          }
        }

        Wizard <|-- SimpleWizard
        Wizard <|-- AdvancedWizard
        Wizard <|-- GuiceWizard
        Tobacco <|-- RivendellTobacco
        Tobacco <|-- OldTobyTobacco
        Tobacco <|-- SecondBreakfastTobacco
        SimpleWizard --> "tobacco" OldTobyTobacco
        AdvancedWizard --> "tobacco" Tobacco
        GuiceWizard --> "tobacco" Tobacco
      }
    }
  }
}
@enduml
