```plantuml
@startuml
abstract class Score {
    <<sealed>>
    placard: String
    isGame: Boolean = false
}

class Points {
    value: Int
    LOVE
    FIFTEEN
    THIRTY
}

class ByPoints {
    placard = "$A - $B"
}

class Forty {
    placard = "$A - 40" | "40 - $B"
}

class Deuce {
    placard = "Deuce"
}

class Advantage {
    placard = "Advantage $W"
}

class Game {
    placard = "Game $W"
    isGame = true
}

class Player {
    A
    B
}

Score <|-- ByPoints
Score <|-- Forty
Score <|-- Deuce
Score <|-- Advantage
Score <|-- Game

ByPoints *-- Points : pointsA
ByPoints *-- Points : pointsB
Forty *-- Points : pointsOther

Player o-- Game : winner
Player --o Game : player
Player --o Advantage : player
Player --o Forty : player

note right of Points: E
note right of ByPoints: C
note right of Forty: C
note right of Deuce: O
note right of Advantage: C
note right of Game: C
note right of Player: E
note left of Score: A

hide circle
@enduml
```