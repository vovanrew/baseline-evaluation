```plantuml
@startuml
' encoding: UTF-8
' start uml viewer: alt+shift+u

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

class DayLog {
    C
    - Integer id
    - LocalDateTime dateTime
    - ArrayList<Log> logs
    + DayLog(ArrayList<Log> logs)
    + void outputToStdout()
}

class Log {
    C
    - Integer id
    - LocalDateTime dateTime
    - ArrayList<Task> tasks
    + Log(ArrayList<Task> tasks)
    + void addTask(Task task)
    + void removeTask(Integer int)
}

class Task {
    C
    - Integer id
    - String name
    - String description
    - LocalDateTime dateTime
    - TaskType type
    + Task(String name, String description, TaskType type)
    + String toString()
    ..Getters..
    + void getName()
    + void getDescription()
    + void getType()
}

interface InsertToDatabase {
    I
    + void insertToDatabase
}

enum TaskType {
    E
    RESEARCH
    CODING
    DESIGN
}

DayLog *-- Log
Log *-- Task
Task --|> InsertToDatabase
Log --|> InsertToDatabase
DayLog --|> InsertToDatabase
Log --|> TaskType

@enduml
```