```plantuml
@startuml
skinparam classAttributeIconSize 0

class Context {
    + Strategy strategy
    + setStrategy(Strategy strategy)
    + execMethod()
}

interface Strategy {
    <<I>>
    + method()
}

class StrategyImp1 {
    + method()
}

class StrategyImp2 {
    + method()
}

Context o-- Strategy
Strategy <|.. StrategyImp1
Strategy <|.. StrategyImp2

note right of Context.execMethod()
  public void execMethod() {
      strategy.method();
  }
end note

legend leftbottom
  策略模式
end legend

style Context fill:#f5f5f5,stroke:#333,color:black
style Strategy fill:#f5f5f5,stroke:#333,color:black
style StrategyImp1 fill:#f5f5f5,stroke:#333,color:black
style StrategyImp2 fill:#f5f5f5,stroke:#333,color:black
@enduml
```