@startuml
participant actor as "user"

participant interface as "student"

participant interface as "teacher"

participant interface as "user"

actor "user" ..|> "student"
actor "user" ..|> "teacher"

actor "user" ..|> "student"
actor "user" ..|> "teacher"

alt [user:teacher]
    actor "user" ..|> "student"
    actor "user" ..|> "teacher"
    actor "user" ..|> "student"
    actor "user" ..|> "teacher"
end

@enduml