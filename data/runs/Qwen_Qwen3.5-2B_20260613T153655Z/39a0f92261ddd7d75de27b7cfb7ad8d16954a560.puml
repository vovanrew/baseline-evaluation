    description "Значения разовых показателей расчета зарплаты (для сотрудников)"
    label "С"
    label "Измерения"
    label "Ресурсы"
}

class Справочник {
    description "Справочник"
}

class Сотрудник {
    description "Сотрудник"
}

class Показатель {
    description "Показатель"
}

class Организация {
    description "Организация"
}

class ФизическоеЛицо {
    description "Физическое лицо"
}

