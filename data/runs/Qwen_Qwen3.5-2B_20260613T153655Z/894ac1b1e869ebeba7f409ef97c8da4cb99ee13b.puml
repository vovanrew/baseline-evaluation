@startuml
skinparam ClassDiagram labelStyle "C"
skinparam Actor labelStyle "I"

class HouseBuilder {
    +void buildBasic()
    +void buildBody()
    +void buildRoof()
    +House finish()
}

class CommonHouseBuilder {
    -House house
    +void buildBasic()
    +void buildBody()
    +void buildRoof()
    +House finish()
}

class LuxuryHouseBuilder {
    -House house
    +void buildBasic()
    +void buildBody()
    +void buildRoof()
    +House finish()
}

class Decorate {
    -HouseBuilder houseBuilder
    +House construct()
}

class Client {
}

class House {
    -String type
    -boolean base
    -boolean body
    -boolean roof
}

HouseBuilder ..> CommonHouseBuilder
HouseBuilder ..> LuxuryHouseBuilder
HouseBuilder ..> Decorate
CommonHouseBuilder ..> House
LuxuryHouseBuilder ..> House
Decorate ..> House

Client ..> Decorate

CommonHouseBuilder ..> House
LuxuryHouseBuilder ..> House

Decorate ..> House

@enduml