@startuml
skinparam ActorColor green
skinparam InterfaceColor purple
skinparam ActorBackgroundColor white
skinparam InterfaceBackgroundColor white

actor A
    note right of A
    "C"
    "A"

actor B
    note right of B
    "C"
    "B"

actor C
    note right of C
    "C"
    "C"

actor D
    note right of D
    "C"
    "D"

interface Interface1
    "I"
    "Interface1"
    "void operation1()"

interface Interface2
    "I"
    "Interface2"
    "void operation2()"
    "void operation3()"

interface Interface3
    "I"
    "Interface3"
    "void operation4()"
    "void operation5()"

note right of A
    "C"
    "A"
end note

note right of B
    "C"
    "B"
end note

note right of C
    "C"
    "C"
end note

note right of D
    "C"
    "D"
end note

A ..> Interface2
A ..> Interface1
C ..> Interface3
B ..> Interface2
B ..> Interface1
D ..> Interface3

@enduml