@startuml
skinparam classBoxStyle {
    background-color: #f0f0f0
    border: 1px solid #000
    border-radius: 4px
}
skinparam actorStyle {
    background-color: #c8e6c9
    border: 1px solid #2e7d32
    border-radius: 4px
    font-size: 14px
}
skinparam interfaceStyle {
    background-color: #fff9c4
    border: 1px solid #fbc02d
    border-radius: 4px
    font-size: 14px
}
skinparam stereotypeStyle {
    background-color: #c8e6c9
    border: 1px solid #2e7d32
    border-radius: 4px
    font-size: 14px
}

Application
    Scanner input
    main()
    readName()
    readAuthor()
    makeJS()
    makeCSS()
    craftHTML()

FileIO
    File inputFile
    setInputFile()
    closeInput()
    readFile()
    writeFile()

DirectoryIO
    String parentDir
    DirectoryIO()
    setParentDir()
    mkDir()
    writeFile()

Application --> FileIO : uses
FileIO ..> DirectoryIO : extends

@enduml