@startuml
class Account {
    +AccountID : int
    +FirstName : string
    +LastName : string
    +EmailAddressUsername : string
    +password : string
    +AccountCreatedDatetime : datetime
    +isArchived : boolean
    createAccount()
    deleteAccount()
    editAccount()
    forgotPassword()
}

class Recipe {
    +recipeID : int
    +recipeName : string
    +servings : int
    +prepTime : time
    +cookTime : time
    +totalTime : time
    +isFavorite : boolean
    createRecipe()
    editRecipe()
    deleteRecipe()
    saveRecipe()
}

class RecipeImage {
    +RecipeImageID : int
    +RecipeImagePath : int
    +isArchived : boolean
    AddPhoto()
    DeletePhoto()
}

class Ingredient {
    +IngredientID : int
    +IngredientText : string
    +IngredientAmount : int
    +isArchived : boolean
    AddIngredient()
    EditIngredient()
    DeleteIngredient()
}

class Measurement {
    +MeasurementID : int
    +MeasurementText : string
    getMeasurement()
}

class Step {
    +StepID : int
    +InstructionStepText : string
    +StepNumberOrder : int
    +isArchived : boolean
    AddStep()
    EditStep()
    RemoveStep()
}

class Instructions {
    +getSteps()
}

Account "0..*" ..> Recipe : hasRecipe
Recipe "1" ..* "1" : hasRecipeImage RecipeImage
Recipe "1" ..* "1" : hasInstruction Instructions
Ingredient "1" ..* "1" : hasMeasurement Measurement
Step "1" ..* "1" : hasInstruction Instructions

@enduml