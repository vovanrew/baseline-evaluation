@startuml
class Expression {
    label "A"
    text "Expression"
}

class Value {
    label "C"
    text "Value"
    attribute int value
}

class Addition {
    label "C"
    text "Addition"
    attribute Expression lhs
    attribute Expression rhs
}

class Multiplication {
    label "C"
    text "Multiplication"
    attribute Expression lhs
    attribute Expression rhs
}

class Visitor {
    label "A"
    text "Visitor"
    attribute visit(Expression& expr)
}

class Evaluator {
    label "C"
    text "Evaluator"
    attribute int total
    attribute visit(Expression& expr)
}

class Printer {
    label "C"
    text "Printer"
    attribute stringstream oss
    attribute visit(Expression& expr)
    attribute visit(Expression& expr)
}

class Printer extends Visitor {
    inherits Visitor
}

class Printer extends Evaluator {
    inherits Evaluator
}

class Printer extends Addition {
    inherits Addition
}

class Printer extends Multiplication {
    inherits Multiplication
}

class Printer extends Value {
    inherits Value
}

class Visitor extends Expression {
    inherits Expression
}

class Evaluator extends Expression {
    inherits Expression
}

@enduml