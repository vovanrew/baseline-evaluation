@startuml
package states {
    actor Client {
        note right of Client
            main(): void
        end note
    }

    interface Memento {
        state: String
    }

    interface CareTaker {
        mementos: List<Memento> = new ArrayList<>()
        add(memento: Memento): void
        get(index: int): Memento
    }

    interface Originator {
        state: String
        setter: void
        getter: String
        other: void
        saveStateToMemento(): Memento
        recoverStateFromMemento(memento: Memento): void
    }
}

