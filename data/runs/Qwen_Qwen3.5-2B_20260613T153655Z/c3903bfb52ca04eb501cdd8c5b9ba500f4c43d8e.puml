@startuml
class ITriangulator {
    "C"
    "Triangulator"
}

class Incremental {
    "C"
    "Incremental"
    "Triangulate(points: IList<Vertex>, config: Configuration) : IMesh"
    "GetBoundingBox() : void"
    "RemoveBox() : int"
}

class Mesh {
    "C"
    "Mesh"
}

ITriangulator <|-- Incremental
Incremental ..> Mesh
@enduml