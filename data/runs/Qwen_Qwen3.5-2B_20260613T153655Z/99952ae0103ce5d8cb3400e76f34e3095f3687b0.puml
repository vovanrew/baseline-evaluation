@startuml
skinparam classDiagram
    class Actor {
        label "A"
        title "Collector"
        note right of Actor
            Collector()
            getDatumLinkListByTree()
            getEntityDescription()
            getEntityName()
            getQualifiers()
            getReferences()
            getSingleStatement()
            getStatementList()
            triggerLoad()
            triggerSave()
        end note
    }

    class WebCollector {
        note right of WebCollector
            loaded : Entities
            gson : Gson
            seen : ArrayList<Entities>
        end note
        title "WebCollector"
        note right of WebCollector
            WebCollector()
            getDatumLinkListByTree()
            getEntityDescription()
            getEntityName()
            getQualifiers()
            getReferences()
            getSingleStatement()
            getStatementList()
            triggerLoad()
            triggerSave()
            getJson()
            formatURL()
            iterateSnaks()
            tryGetQualifiers()
        end note
    }

    class LocalRepository {
        note right of LocalRepository
            file : File
        end note
        title "LocalRepository"
        note right of LocalRepository
            LocalRepository()
            load()
            save()
        end note
    }

    class LocalCollector {
        title "LocalCollector"
        note right of LocalCollector
            LocalCollector()
            triggerSave()
            getJson()
        end note
    }

    Actor --> WebCollector : inherits
    Actor --> LocalRepository : repository
    WebCollector --> LocalCollector : inherits

@enduml