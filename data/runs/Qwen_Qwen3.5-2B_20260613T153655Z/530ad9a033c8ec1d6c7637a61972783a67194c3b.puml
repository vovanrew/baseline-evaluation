@startuml
package Component {
    class Composite {
        +add(component: Component): void
        +remove(component: Component): void
        +getChild(): int
        +operation(): void
    }
    class Leaf {
        +operation(): void
    }
    class Client {
    }
}

class Component {
    +add(component: Component): void
    +remove(component: Component): void
    +getChild(): int
    +operation(): void
}

class OrganizationComponent {
    +add(component: OrganizationComponent): void
    +print(): void
}

class University {
}

class College {
}

class Department {
}

Composite -- Component : composition
Composite -- Leaf : composition
Component -- Component : composition
Component -- OrganizationComponent : composition
OrganizationComponent -- University : composition
OrganizationComponent -- College : composition
OrganizationComponent -- Department : composition

note right of Composite
组合可以操作子节点或者叶子节点，但可能不具有叶子节点的某些行为
end note

note left of Component
Component 为所有节点的基类，不管是普通节点还是叶子节点
end note

note right of Leaf
叶子节点，不能操作子节点
end note

note left of Client
end note

@enduml