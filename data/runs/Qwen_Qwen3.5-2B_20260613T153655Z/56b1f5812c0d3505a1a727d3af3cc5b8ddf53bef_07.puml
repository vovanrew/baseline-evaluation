}

class Token {
    Token()
}

class Logic {
    Logic()
    getMaxPlayers(): int
    setUsers(int)
    getToken(): Token
    next()
    isBoardComplete(): boolean
    isTicTacToe(): boolean
    isUser(): boolean
    put(Coordinate): Error
    move(Coordinate, Coordinate): Error
