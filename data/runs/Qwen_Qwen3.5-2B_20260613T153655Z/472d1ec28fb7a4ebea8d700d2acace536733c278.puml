@startuml
title login by token

participant "学术袁" as 学术袁
participant "App客户端" as App客户端
participant "后台服务器" as 后台服务器

section [有本地记录]
    section [token有效]
        学术袁 -> App客户端: 启动
        App客户端 -> 后台服务器: 检测本地登录信息
        App客户端 -> 学术袁: token自动登陆
    section [token无效]
        学术袁 -> App客户端: 提示登录
        App客户端 -> 学术袁: 输入手机号+密码
        学术袁 -> 后台服务器: 手机号+密码登录
        后台服务器 -> App客户端: 返回新的token
        App客户端 -> 学术袁: token保存
    end

    section [无本地记录]
        学术袁 -> App客户端: 提示输入手机号
        App客户端 -> 后台服务器: 请求发送验证码
        后台服务器 -> App客户端: 返回验证码
        App客户端 -> 学术袁: 输入验证码
        App客户端 -> 后台服务器: 请求后台验证
        后台服务器 -> App客户端: 返回新的token
        App客户端 -> 学术袁: token保存
    end

section [已注册]
    section [未注册]
        学术袁 -> App客户端: 提示注册
        App客户端 -> 学术袁: 输入两次密码
        App客户端 -> 后台服务器: 请求注册
        后台服务器 -> App客户端: 返回新的token
        App客户端 -> 学术袁: token保存
    end
end

@enduml