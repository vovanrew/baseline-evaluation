@startuml
participant CPO1 as "CPO1"
participant HUB as "HUB"
participant MSP1 as "MSP1"

CPO1 --> HUB : HTTP: GET
CPO1 --> HUB : TO: MSP1
CPO1 --> HUB : FROM: CPO1

HUB --> MSP1 : HTTP: GET
HUB --> MSP1 : TO: MSP1
HUB --> MSP1 : FROM: CPO1

MSP1 --> HUB : HTTP: RESPONSE
MSP1 --> HUB : TO: CPO1
MSP1 --> HUB : FROM: MSP1

HUB --> CPO1 : HTTP: RESPONSE
HUB --> CPO1 : TO: CPO1
HUB --> CPO1 : FROM: MSP1

@enduml