@startuml
skinparam classDiagram {
    class Actor {
        +string name
        +string age
        +string gender
    }
    class Database {
        +string name
        +string type
        +string location
    }
    class Interface {
        +string name
        +string description
        +string version
    }
    class Enum {
        +string name
        +string value
        +string description
    }
}

class ConquestMapPart {
    +string part
    +ConquestMapPart(String part)
    +ConquestMapPart values()
    +ConquestMapPart valueOf(String name)
    +String getPart()
    +ConquestMapPart fromString(String part)
}

actor Actor
database Database
interface Interface
enum Enum

ConquestMapPart ..> Actor : has
ConquestMapPart ..> Database : has
ConquestMapPart ..> Interface : has
ConquestMapPart ..> Enum : has

@enduml