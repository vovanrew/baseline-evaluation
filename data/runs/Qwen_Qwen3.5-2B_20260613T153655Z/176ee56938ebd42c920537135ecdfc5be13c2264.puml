@startuml
actor Пользователь as Пользователь

section Модули
    module СиловойМодуль as СиловойМодуль
    module РелеПитания as РелеПитания
    module МодульСетевогоУправления as МодульСетевогоУправления
endsection

section Модули производят начальную настройку
    СиловойМодуль -> РелеПитания: Выключен
    РелеПитания -> МодульСетевогоУправления: Включение
    МодульСетевогоУправления -> СиловойМодуль: Включение
    Модули производят начальную настройку
endsection

section Нормальная работа робота
    Пользователь -> СиловойМодуль: Нажатие кнопки
    СиловойМодуль -> РелеПитания: Включение
    РелеПитания -> МодульСетевогоУправления: Включение
    МодульСетевогоУправления -> СиловойМодуль: Светодиод на кнопке включён
    Модули производят начальную настройку
    Пользователь -> СиловойМодуль: Нажатие кнопки
    СиловойМодуль -> РелеПитания: Включение
    РелеПитания -> МодульСетевогоУправления: Включение
    МодульСетевогоУправления -> СиловойМодуль: Светодиод на кнопке включён
    Модули производят начальную настройку
    Пользователь -> СиловойМодуль: Нажатие кнопки
    СиловойМодуль -> РелеПитания: shutdown
    РелеПитания -> МодульСетевогоУправления: timeout: N
    МодульСетевогоУправления -> СиловойМодуль: Выключение
    Модули производят процедуры по безопасному выключению
endsection

section Проходит N секунд
    Пользователь -> СиловойМодуль: Светодиод на кнопке выключен
    СиловойМодуль -> РелеПитания: Выключение
    РелеПитания -> МодульСетевогоУправления: Выключение
    МодульСетевогоУправления -> СиловойМодуль: Выключен
    Модули производят процедуры по безопасному выключению
    Модули производят начальную настройку
endsection

@enduml