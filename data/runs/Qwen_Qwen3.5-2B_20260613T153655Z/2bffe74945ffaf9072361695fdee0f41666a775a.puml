@startuml
    actor "User" as user

    interface Database as DB

    database DB
        database "A" as A
        database "B" as B

    A
        database "A" as A1
        database "B" as B1

    B
        database "A" as A2
        database "B" as B2

    A1 -- A2 : <image>
    B1 -- B2 : <image>

    A1 : A
    B1 : B
    A2 : A
    B2 : B

    @enduml