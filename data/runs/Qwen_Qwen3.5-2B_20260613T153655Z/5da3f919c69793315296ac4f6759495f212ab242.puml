@startuml
class Display {
    "A"
    getColumns(): int
    getRows(): int
    getRowText(row: int): String
    show(): void
}

class StringDisplay {
    "C"
    string: String
    getColumns(): int
    getRows(): int
    getRowText(row: int): String
}

class Border {
    "A"
    display: Display
    Border(display: Display)
}

class SideBorder {
    "C"
    borderChar: char
    SideBorder(display: Display, ch: char)
    getColumns(): int
    getRows(): int
    getRowText(row: int): String
}

class FullBorder {
    "C"
    FullBorder(display: Display)
    getColumns(): int
    getRows(): int
    getRowText(row: int): String
    makeLine(ch: char, count: int): void
}

Display <|-- StringDisplay
Display <|-- Border
Border <|-- SideBorder
Border <|-- FullBorder

@enduml