@startuml
package Actor {
    class TicTacToe {
        <<Actor>>
        turn : Turn
        board : Board
        players : Player[] [0..*]
        TicTacToe()
        Play()
    }
    class Player {
        <<Actor>>
        color : char
        Player(i: int)
        Put(board : Board)
        Move(board : Board)
        Win()
    }
    class Turn {
        <<Actor>>
        value : int = 0
        Turn()
        Current() <<"Take">>
        Next() <<"NotTake">>
        Change()
    }
}

package Interface {
    class Board {
        <<Interface>>
        Color : char[,] [0..*] = {'x', 'o'}
        tokens : char[,] [0..*]
        Board()
        IsTicTacToe() : bool
        IsTicTacToe(token : char) : bool
        IsComplete() : bool
        IsTileEmpty(row : int, column: int) : bool
        IsTileFull(row : int, column: int) : bool
        ToString() : string
    }
    class IO {
        <<Interface>>
        static
        ReadString(title : string) : string
        ReadInt(title : string) : int
        Write(title : string)
        WriteLn()
        WriteError(format : string)
    }
}

