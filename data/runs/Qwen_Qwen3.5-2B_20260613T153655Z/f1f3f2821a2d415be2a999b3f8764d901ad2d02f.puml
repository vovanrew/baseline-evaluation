@startuml
package Documents {
    StringDocument
    URLDocument
    FileDocument
    Document
}

package Indexes {
    SimilarityIndex
    CachingSimilarityIndex
    JaacardIndex
}

package Shingles {
    Shinglizer
    WordShinglizer
}

package MinHash {
    HashGenerator
    MinHash
}

Document --> StringDocument
Document --> URLDocument
Document --> FileDocument

Document --> SimilarityIndex

SimilarityIndex --> CachingSimilarityIndex

SimilarityIndex --> JaacardIndex

JaacardIndex --> HashGenerator

JaacardIndex --> MinHash

Shinglizer --> WordShinglizer

@enduml