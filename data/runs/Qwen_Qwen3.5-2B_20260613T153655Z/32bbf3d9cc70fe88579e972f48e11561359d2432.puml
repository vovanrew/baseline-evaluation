@startuml
participant "xxx" as XXX

interface Shape {
    void draw()
}

actor Circle {
    void draw()
}

actor Rectangle {
    void draw()
}

actor Square {
    void draw()
}

participant ShapeFactory {
    Shape getShape()
}

participant FactoryPatternDemo {
    void main()
}

ShapeFactory "create" <- XXX : Shape
ShapeFactory "ask" <- FactoryPatternDemo : Shape

Circle "implement" Shape
Rectangle "implement" Shape
Square "implement" Shape

@enduml