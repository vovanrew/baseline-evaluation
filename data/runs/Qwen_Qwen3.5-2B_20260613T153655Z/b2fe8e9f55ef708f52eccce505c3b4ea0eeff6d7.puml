@startuml
package C {
    class Team {
        - name : string
        - description : string
        - ownerId : User
        - participants : Participant[]
        - topics : Topic[]
    }

    class Topic {
        - name : string
        - icon : string
        - isSequential : boolean
        - subtopics : Subtopic[]
    }

    class Subtopic {
        - name : string
        - description : string
        - challenges : Challenge[]
    }

    class Challenge {
        - name : string
        - body : string
        - type : ChallengeType
        - selection : string[]
        - correct : string[]
        - points : number
        - feedback : string
    }

    class ChallengeType {
        - type : string
        - input : string
        - radio : string
        - checkbox : string
    }

    class Participant {
        - userId : User
        - points : number
        - status : ParticipantStatus
    }

    class ParticipantStatus {
        - status : string
        - pending : string
        - accepted : string
        - disabled : string
    }

    class User {
        - name : string
        - email : string
        - educationalInstitution : string
        - educationalBackground : EducationalBackground
        - birthDate : Date
        - points : number
    }

    class EducationalBackground {
        - educationalBackground : string
        - middle_incomplete : string
        - middle_ongoing : string
        - middle_complete : string
        - high_incomplete : string
        - high_ongoing : string
        - high_complete : string
        - graduation_incomplete : string
        - graduation_ongoing : string
        - graduation_complete : string
    }

    class ChallengeReport {
        - userId : User
        - challengeld : Challenge
        - answer : string[]
        - answeredCorrectly : boolean
    }
}

