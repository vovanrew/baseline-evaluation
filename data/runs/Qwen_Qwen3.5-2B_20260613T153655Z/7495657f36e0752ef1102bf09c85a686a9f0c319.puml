@startuml
class File {
    "C" File
    "File" image
    "cropImage() : void"
    "toValue() : float[]"
}

class ImageFile {
    "C" ImageFile
    "File" image
    "cropImage() : void"
    "toValue() : float[]"
}

class Measurement {
    "C" Measurement
    "camera"
    "int[] redValues"
    "int imgPerSecond"
    "captureImage() : ImageFile"
    "start() : void"
    "analyzeImage(imageFile) : int"
    "calculateREsult(): int"
}

class ResultActivity {
    "C" ResultActivity
    "Measurement"
    "displayResult()"
    "backToMainActivity()"
    "onCreate()"
}

class MainActivity {
    "C" MainActivity
    "camera"
    "duration"
    "showActiveMeasurement()"
    "hideActiveMeasurement()"
    "createMeasurement()"
    "showResult()"
}

File <|-- ImageFile

ResultActivity ..> Measurement
ResultActivity ..> MainActivity
MainActivity ..> Measurement
Measurement ..> File

@enduml