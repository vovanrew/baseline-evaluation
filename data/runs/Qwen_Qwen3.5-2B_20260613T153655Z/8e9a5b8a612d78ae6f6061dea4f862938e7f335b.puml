@startuml
package billing {
    class TotalFee {
        note right of TotalFee
            TotalFee
        endnote
    }
    class DiscountFee {
        note right of DiscountFee
            DiscountFee
        endnote
    }
    class ContractFee {
        note right of ContractFee
            ContractFee
        endnote
    }
    class ContractForCharge {
        note right of ContractForCharge
            ContractForCharge
            DataMax5GPLan
        endnote
    }
    class ContractForDiscount {
        note right of ContractForDiscount
            ContractForDiscount
        endnote
    }
}

package discount {
    class DiscountService {
        note right of DiscountService
            DiscountService
        endnote
    }
}

package contract {
    class ContractForCharge {
        note right of ContractForCharge
            ContractForCharge
            DataMax5GPLan
        endnote
    }
    class ContractFee {
        note right of ContractFee
            ContractFee
        endnote
    }
}

package contractmanage {
    class FamilyContracts {
        note right of FamilyContracts
            FamilyContracts
        endnote
    }
    class Contract {
        note right of Contract
            Contract
        endnote
    }
    class Plan {
        note right of Plan
            Plan
        endnote
    }
    class ContractRepository {
        note right of ContractRepository
            ContractRepository
        endnote
    }
}

package otherservice {
    class SmartValueTargetServiceContracts {
        note right of SmartValueTargetServiceContracts
            SmartValueTargetServiceContracts
        endnote
    }
}

package plan {
    class Plan {
        note right of Plan
            Plan
        endnote
    }
}

TotalFee ..> DiscountFee
TotalFee ..> ContractFee
DiscountService ..> DiscountFee
DiscountService ..> ContractForDiscount
ContractForDiscount ..> FamilyContracts
ContractForDiscount ..> Contract
ContractForCharge ..> ContractFee
ContractForCharge ..> Plan
ContractRepository ..> FamilyContracts
ContractRepository ..> Contract
ContractRepository ..> Plan
SmartValueTargetServiceContracts ..> DiscountService
@enduml