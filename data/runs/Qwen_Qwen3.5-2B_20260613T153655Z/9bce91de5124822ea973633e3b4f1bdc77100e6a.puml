@startuml
skinparam UMLClassBoxStyle fillcolor: #f5f5f5
skinparam UMLActorBoxStyle fillcolor: #f5f5f5
skinparam UMLInterfaceBoxStyle fillcolor: #f5f5f5

class Artisan {
    "C"
    salaire coordonnee
    getPaye()
}

class Chantier {
    "C"
    dateD
    dateF
    adresse
    getAdresse()
    affecterArtisan()
}

class Travailler {
    "C"
    nbHeure
    debMission
    finMission
    calculerPaye()
}

Artisan ..> Chantier : 1..*
Travailler ..> Chantier : 0..*

@enduml