@startuml
package "businessRules" as businessRules

entity User
    "email: string"
    "roles: array"
    "password: string"
    "firstname: string"
    "lastname: string"

entity Post
    "title: string"
    "description: string"
    "createdAt: DateTimeInterface"

entity Picture
    "name: string"
    "url: string"

User --|> Post : One
Post --|> Picture : One

@enduml