package controller {
    class File {
        - save()
        - load()
        - make_directory()
        - remove_directory()
        - is_file_path_ok()
    }
    class AnalyseData {
    }
    class AnalyseWeatherData {
    }
    class conversation {
    }
}

package models {
    class Forecaster {
        - name: string
        - my_name: string
        - speak_color: string
        + hello()
        + goodbye()
    }
    class MyForecaster {
        - ask_which_area()
        - ask_from_when_to_when()
        - say_results()
    }
    class JmaDataModel {
        - get_daily_weather_data()
        - get_http_body()
        - integrate_monthly_data()
        - str2float()
    }
    class CSVModel {
    }
}

