@startuml
skinparam ClassDiagram font "Comic Sans MS"

class Personaje {
    <<abstract>>
    string nombre
    string correo
    int telefono
    Mundo* mundo

    Personaje()
    Personaje(string nombre)
    virtual Personaje* clone()
}

class SubClase {
    <<template>>
    T* clone()
}

class Princesa {
    C
    Princesa(string n)
    Princesa(const Princesa& p)
    void gritar()
}

class Villano {
    C
    Villano(string n)
    Villano(const Villano& v)
    void secuestrar()
}

class Heroe {
    C
    Heroe(string n)
    Heroe(const Heroe& h)
    void salvar()
}

class Mundo {
    C
    string nombreMundo
    Mundo(string nombreMundo)
}

class Personaje {
    C
    string nombre
    string correo
    int telefono
    Mundo* mundo

    Personaje()
    Personaje(string nombre)
    virtual Personaje* clone()
}

Personaje ..> Mundo : posee
Mundo ..> Personaje : posee

Princesa ..> Personaje : es
Villano ..> Personaje : es
Heroe ..> Personaje : es

SubClase ..> Personaje : es
SubClase ..> Mundo : es

@enduml