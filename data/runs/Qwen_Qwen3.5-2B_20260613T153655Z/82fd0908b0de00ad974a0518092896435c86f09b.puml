@startuml
class IFoo {
    +void method()
}

class Bar {
    static String name
    Foo foo
    int x
    int y
    void method(String string)
}

class Foo {
    int x
    void methodA()
}

class Qoo {
    Foo foo
}

class Actor {
    +void method()
}

Actor "IFoo" as IFooActor
Actor "Bar" as BarActor
Actor "Foo" as FooActor
Actor "Qoo" as QooActor

IFooActor ..> BarActor : Aggregation
IFooActor ..> FooActor : Composition
IFooActor ..> QooActor : Inheritance

BarActor ..> IFooActor : Aggregation
FooActor ..> IFooActor : Inheritance

BarActor ..> FooActor : Aggregation
FooActor ..> QooActor : Composition

@enduml