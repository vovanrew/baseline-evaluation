@startuml
title ENTITIES's Class Diagram

skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "il" {
  package "ac" {
    package "afeka" {
      package "tomco" {
        package "cookingapp" {
          package "Entities" {

            class CategoriesContent {
              +CATEGORIES : List<Category>
              --
              +clear()
              +addCategory()
            }

            class RecipesContent {
              +RECIPES : List<Recipe>
              --
              +clear()
              +addRecipe()
            }

            class Category {
              -title : String
              -imageURL : String
              +CREATOR : Creator<Category>
              --
              +Category()
              +Category()
              +Category()
              +setTitle()
              +setImageURL()
              +getTitle()
              +getImageURL()
              +describeContents()
              +writeToParcel()
            }

            class Recipe {
              -title : String
              -ingredients : String
              -cookingOperations : String
              -category : String
              -imageURL : String
              -uploadingUser : String
              +CREATOR : Creator<Recipe>
              --
              +Recipe()
              +Recipe()
              +Recipe()
              +getTitle()
              +setTitle()
              +getIngredients()
              +setIngredients()
              +getCookingOperations()
              +setCookingOperations()
              +getImageURL()
              +setImageURL()
              +getCategory()
              +setCategory()
              +getUploadingUser()
              +setUploadingUser()
              +describeContents()
              +writeToParcel()
            }

            class UploadImage {
              -name : String
              -imageUrl : String
              --
              +UploadImage()
              +UploadImage()
              +getName()
              +setName()
              +getImageUrl()
              +setImageUrl()
            }

          }
        }
      }
    }
  }
}

class Parcelable

Category -up-|> Parcelable
Recipe -up-|> Parcelable

@enduml