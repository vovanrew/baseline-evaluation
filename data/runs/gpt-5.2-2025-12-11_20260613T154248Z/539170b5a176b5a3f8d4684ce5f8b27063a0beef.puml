@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho

skinparam class {
  BackgroundColor #F7F7F7
  BorderColor #333333
}

package "InheritanceDesign" as InheritanceDesign {
  class Bond
  class Stock
  class Car
  class House
  class Wealth

  abstract class Security
  class BankAccount
  abstract class Property
  abstract class Asset

  Bond -|> Security
  Stock -|> Security

  Car -|> Property
  House -|> Property

  Security -|> Asset
  BankAccount -|> Asset
  Property -|> Asset
}

package "java" as java {
  package "lang" as lang {
    annotation Override
  }
}

Bond ..> Override
Stock ..> Override
Car ..> Override
House ..> Override
Wealth ..> Override
BankAccount ..> Override
Property ..> Override
@enduml