@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F7F7F7
  BorderColor #333333
  ArrowColor #333333
}

interface "Collection" as Collection
interface "Set" as Set
interface "List" as List
interface "Queue" as Queue
interface "SortedSet" as SortedSet

Set ..|> Collection
List ..|> Collection
Queue ..|> Collection
SortedSet ..|> Set

@enduml