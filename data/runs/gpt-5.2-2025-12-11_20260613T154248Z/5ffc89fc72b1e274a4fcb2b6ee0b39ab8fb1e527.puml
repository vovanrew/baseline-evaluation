@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam class {
  BackgroundColor white
  BorderColor #333333
}

class Account {
  AccountID : int
  FirstName : string
  LastName : string
  EmailAddressUsername : string
  password : string
  AccountCreatedDatetime : datetime
  isArchived : boolean
  --
  createAccount()
  deleteAccount()
  editAccount()
  forgotPassword()
}

class Recipe {
  recipeID : int
  recipeName : string
  servings : int
  prepTime : time
  cookTime : time
  totalTime : time
  isFavorite : boolean
  --
  createRecipe()
  editRecipe()
  deleteRecipe()
  saveRecipe()
}

class RecipeImage {
  RecipeImageID : int
  RecipeImagePath : int
  isArchived : boolean
  --
  AddPhoto()
  DeletePhoto()
}

class Ingredient {
  IngredientID : int
  IngredientText : string
  IngredientAmount : int
  isArchived : boolean
  --
  AddIngredient()
  EditIngredient()
  DeleteIngredient()
}

class Measurement {
  MeasurementID : int
  MeasurementText : string
  --
  getMeasurement()
}

class Instructions {
  --
  getSteps()
}

class Step {
  StepID : int
  InstructionStepText : string
  StepNumberOrder : int
  isArchived : boolean
  --
  AddStep()
  EditStep()
  RemoveStep()
}

Account "0..*" -- "0..*" Recipe

Recipe "1" o-- "1" RecipeImage

Recipe "1" *-- "*" Ingredient
Ingredient "1" *-- "1" Measurement

Recipe "1" *-- "1" Instructions
Instructions "1" *-- "*" Step

@enduml