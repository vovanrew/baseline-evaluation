@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

class Project
class User
class Submission
class Revision
class Resource
class Admin
class Author
class Editor
class Comment
class Document
class AudioFile
class Video

' Inheritance
Admin -|> User
Author -|> User
Editor -|> User

Document -|> Resource
AudioFile -|> Resource
Video -|> Resource

' Associations / Aggregations / Compositions with multiplicities
Project "1" o-- "*" User
Project "1" *-- "*" Submission
Project "1" *-- "1" Resource

Submission "1" o-- "1" Author
Submission "1" *-- "*" Revision
Submission "1" *-- "*" Comment
Submission "1" *-- "*" Resource

Revision "1" o-- "1" Editor
Revision "1" o-- "1" Resource

Editor "1" --> "1" Comment
Author "1" --> "*" Comment
@enduml