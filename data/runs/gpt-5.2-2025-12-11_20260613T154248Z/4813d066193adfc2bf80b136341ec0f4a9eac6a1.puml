@startuml
skinparam classAttributeIconSize 0

class Customer << (C,#b7d7b7) >> {
  + numberOfRentalsWithDifferentOffices(CalculateNumberOfRentalsDO ca):Integer
}

class Rental << (A,#bfe3e6) >>

interface CalculateNumberOfRentalsDO << (I,#b9b2e6) >> {
  + calculate(rentals:Rental[]):Integer
}

class ImplCalculate << (C,#b7d7b7) >> {
  + calculate(rentals:Rental[]):Integer
}

Customer "1" -- "*" Rental : makes
Customer ..> CalculateNumberOfRentalsDO
ImplCalculate ..|> CalculateNumberOfRentalsDO
@enduml