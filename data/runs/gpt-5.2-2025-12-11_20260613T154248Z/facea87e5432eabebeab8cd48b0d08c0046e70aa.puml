@startuml
skinparam classAttributeIconSize 0

class DataSet <<C>> {
  value
  date
  dataSetType
  --
  getValue()
  getDate()
  getDataSetType()
  __return__
  return date to compare
  and info about metric type
}

class ResultCompare <<C>> {
  currentValue
  previousValue
  dataSetType
  --
  CmpMethods()
  __return__
  (-1;0;1)
}

class CmpMethods <<C>> {
  cmpMethod()
  __return__
  select method
}

class Metric <<C>> {
  resultCompare()
  sendNotification()
}

class Notification <<C>> {
  sendTo
  message
  --
  sendMethod()
  __return__
  send message
}

class SendMethod <<C>> {
  sendMethod()
  __return__
  send method
}

Metric ..> ResultCompare
Metric ..> Notification

ResultCompare ..> DataSet
ResultCompare ..> CmpMethods

Notification ..> SendMethod
@enduml