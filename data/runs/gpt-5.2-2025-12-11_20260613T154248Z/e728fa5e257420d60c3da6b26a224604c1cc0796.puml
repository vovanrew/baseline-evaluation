@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam class {
  BackgroundColor #F2F2F2
  BorderColor #333333
}

class lexicon
class symbol
class lexema
class type

lexicon "1" *-- "*" lexema : reserved
lexicon "1" *-- "*" lexema : symbols

symbol "1" *-- "1" lexema
symbol "1" *-- "1" type
@enduml