@startuml
skinparam classAttributeIconSize 0

class "Handler" as Handler <<abstract>> {
  next
  --
  handle()
}

class "ConcreteHandler1" as ConcreteHandler1 {
  --
  handle()
}

class "ConcreteHandler2" as ConcreteHandler2 {
  --
  handle()
}

class "ConcreteHandler3" as ConcreteHandler3 {
  --
  handle()
}

circle client

client --> Handler : handle()

ConcreteHandler1 --|> Handler
ConcreteHandler2 --|> Handler
ConcreteHandler3 --|> Handler

Handler "1" o-- "*" Handler

@enduml