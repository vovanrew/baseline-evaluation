@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

class TicTacToe {
  - String answer
  + TicTacToe()
  + void play()
  + void playGame()
  + boolean isResumedGame()
  + void read(String)
  + boolean isAffirmative()
  + boolean isNegative()
  + void main(String[])
}

class Turn {
  - int NUMBER_PLAYERS = 2
  - int activePlayer
  + Turn(Board)
  + void reset()
  + void play()
  + void writeWinner()
  + Color getActiveColor()
}

class Player {
  + Player(Color, Board)
  + void play()
  + void putToken()
  + Coordinate getCoordinate(Message)
  + Error getPutTokenError(Coordinate)
  + void moveToken()
  + Error getMoveTokenError(Coordinate)
  + Error getTargetMoveTokenError(Coordinate, Coordinate)
  + void writeWinner()
  + Color getColor()
}

class Board {
  + Board()
  + void reset()
  + boolean isComplete(Color)
  + Square[] getSquares(Color)
  + void putToken(Coordinate, Color)
  + void moveToken(Coordinate, Coordinate)
  + Color getColor(Coordinate)
  + boolean isOccupied(Coordinate, Color)
  + boolean isEmpty(Coordinate)
  + boolean isTicTacToe(Color)
  + Direction[] getDirections(Color)
  + void write()
  + boolean isComplete(Color)
}

class Square {
  - Coordinate coordinate;
  - Color color;
}

class Coordinate {
  - int DIMENSION = 3
  - int row
  - int column
  + int getDimension()
  + Coordinate()
  + Coordinate(int, int)
  + Direction getHorizontal(Coordinate)
  + boolean inHorizontal(Coordinate)
  + boolean inVertical(Coordinate)
  + boolean inMainDiagonal()
  + boolean inInverseDiagonal()
  + void read(String)
  + String getErrorMessage()
  + int getRow()
  + int getColumn()
  + boolean equals(Coordinate)
}

enum Color {
  X,
  O,
  NULL
  + Color get(int)
  + void write()
  + boolean isNULL()
}

enum Direction {
  VERTICAL,
  HORIZONTAL,
  MAIN_DIAGONAL,
  INVERSE_DIAGONAL,
  NULL
  + boolean isNULL()
}

class BoundedIntDialog {
  - ClosedInterval LIMITS
  + BoundedIntDialog(int, int)
  + int read(String)
  + String getLimits()
}

class ClosedInterval {
  - int min;
  - int max;
  + ClosedInterval(int, int)
  + boolean includes(int)
  + String toString()
  + boolean equals(ClosedInterval)
}

class YesNoDialog

class Console {
  - BufferedReader bufferedReader
  - Console instance = new Console()
  - Console()
  + Console getInstance()
  + String readString(String)
  + String readString()
  + int readInt(String)
  + int readInt()
  + char readChar(String)
  + void write(String)
  + void write(int)
  + void writeln(String)
  + void writeln(int)
  + void writeError(String)
}

class Message {
  TITLE
  HORIZONTAL_LINE
  VERTICAL_LINE
  NULL
  TURN
  ENTER_COORDINATE_TO_PUT
  COORDINATE_TO_PUT
  COORDINATE_TO_REMOVE
  COORDINATE_TO_MOVE
  ROW
  COLUMN
  BOUNDED_INT_ERROR
  LIMITS
  CLOSED_INTERVAL
  PLAYER_WIN
  RESUME
  YES_NO_SUFFIX
  YES_NO_ERROR
  + char AFFIRMATIVE
  + char NEGATIVE
  + String $COLOR
  + String $PLAYER
  + String $CLOSED_INTERVAL
  + String $MIN
  + String $MAX
  - String message
  + Message(String)
  + void write()
  + void writeln()
  + void writeln(String)
  + String toString()
}

class Error {
  NOT_EMPTY
  NOT_OWNER
  SAME_COORDINATES
  WRONG_COORDINATES
  NULL
  - String message
  + Error()
  + Error(String)
  + void writeln()
  + boolean isNULL()
}

TicTacToe --> Turn : turn
TicTacToe --> Board : board

Turn --> Board : board
Turn --> "2" Player : players

Player --> Board : board
Player --> Color : color
Player ..> Error
Player ..> Message

Board --> "3x3" Square
Board ..> Coordinate
Board ..> Direction
Board ..> Color
Board ..> Message

Square --> Coordinate
Square --> Color

Coordinate ..> Direction
Coordinate ..> BoundedIntDialog
Coordinate ..> ClosedInterval

BoundedIntDialog --> ClosedInterval : LIMITS

Message ..> Console
Error ..> Message
Error ..> Console

YesNoDialog ..> Console

@enduml