```plantuml
@startuml
title メモリ管理

skinparam backgroundColor white
skinparam sequence {
  ParticipantPadding 30
  BoxPadding 15
  MessageAlign left
  ArrowColor black
  LifeLineBorderColor #777777
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #777777
  ParticipantBackgroundColor #E9E9F6
  BoxBorderColor #777777
  BoxBackgroundColor #DDDDDD
  ReferenceBorderColor black
  ReferenceBackgroundColor #F2F2F2
}

participant "タスク管理" as TM
box "メモリ管理" #DDDDDD
  participant "ページング\n管理" as PG
  participant "物理メモリ\n領域管理" as PM
end box
participant "MLIB" as MLIB

TM -> PG : ページディレクトリ解放\n（ページディレクトリID）
activate PG

PG -> MLIB : 管理情報取得
activate MLIB
ref over MLIB
  動的配列
end ref
deactivate MLIB

PG <-- MLIB : ページディレクトリ操作領域マッピング設定
ref over PG
  マッピング設定
end ref

loop [カーネル領域以外の全有効エントリ毎]\nページテーブル操作領域マッピング設定
  ref over PG
    マッピング設定
  end ref

  PG -> PG : ページテーブル0初期化
  PG -> PM : ページテーブル解放
  activate PM
  ref over PM
    物理メモリ領域解放
  end ref
  deactivate PM

  PG <-- PM
end

PG -> PG : ページディレクトリ0初期化
PG -> PM : ページディレクトリ解放
activate PM
ref over PM
  物理メモリ領域割当
end ref
deactivate PM

PG -> MLIB : 管理情報解放
activate MLIB
ref over MLIB
  動的配列
end ref
deactivate MLIB

PG --> TM
deactivate PG

@enduml
```