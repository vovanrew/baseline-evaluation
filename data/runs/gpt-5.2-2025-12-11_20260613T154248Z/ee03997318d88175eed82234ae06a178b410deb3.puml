@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam class {
  BackgroundColor #F7F7F7
  BorderColor #333333
  AttributeFontColor #8B0000
  FontStyle italic
}
skinparam stereotypeCBackgroundColor #BFE6E6
skinparam stereotypeCBorderColor #333333

hide methods

abstract class "Iterable" as Iterable {
  {field} __iter__
}

abstract class "Reversible" as Reversible {
  {field} __reversed__
}

abstract class "Sized" as Sized {
  {field} __len__
}

abstract class "Container" as Container {
  {field} __contains__
}

abstract class "Collection" as Collection {
  {field} __contains__
  {field} __iter__
  {field} __len__
}

abstract class "Sequence" as Sequence {
  {field} __getitem__
  {field} __len__
  __contains__
  __iter__
  __reversed__
  index
  count
}

abstract class "MutableSequence" as MutableSequence {
  {field} __getitem__
  {field} __setitem__
  {field} __delitem__
  {field} __len__
  insert
  __contains__
  __iter__
  __reversed__
  index
  count
  append
  reverse
  extend
  pop
  remove
  __iadd__
}

Iterable <|-- Reversible
Iterable <|-- Collection
Sized <|-- Collection
Container <|-- Collection
Reversible <|-- Sequence
Collection <|-- Sequence
Sequence <|-- MutableSequence

@enduml