@startuml
skinparam shadowing false
skinparam sequence {
  ParticipantPadding 40
  BoxPadding 10
  MessageAlign left
}
skinparam Participant {
  BackgroundColor #D9D9E8
  BorderColor #666666
}
skinparam Actor {
  BorderColor #666666
}

actor "图书管理员" as Admin
participant ": 读者" as Reader
participant ": 图书目录" as Catalog
participant ": 图书信息" as BookInfo
participant ": 借书记录" as BorrowRecord

Admin -> Reader : 验证读者信息
activate Reader
deactivate Reader

Admin -> Reader : 获取读者借书数量
activate Reader

opt [超出借书数量]
  Reader --> Admin : 借书失败
end

deactivate Reader

Admin -> Catalog : 获取图书目录
activate Catalog
Catalog -> BookInfo : 查询图书信息
activate BookInfo
BookInfo --> Admin : 返回信息
deactivate BookInfo
deactivate Catalog

Admin -> BorrowRecord : 存储借书记录
activate BorrowRecord
deactivate BorrowRecord

Admin -> Catalog : 借出图书
activate Catalog
Catalog -> BookInfo : 减少图书数量
activate BookInfo
deactivate BookInfo
deactivate Catalog

Admin -> Reader : 减少读者可借数量
activate Reader
deactivate Reader

@enduml