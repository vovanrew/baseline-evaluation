@startuml
hide footbox
skinparam shadowing false
skinparam sequence {
  LifeLineBorderColor #888888
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #666666
  ParticipantBackgroundColor #E9E9F6
  ActorBorderColor #666666
  ActorBackgroundColor #FFFFFF
  ArrowColor #333333
  MessageAlign left
}

actor teacher
participant "操作界面" as UI
participant studentcourse as SC
participant student as ST
participant experiment as EX
participant experimentscore as ES
participant scoreitem as SI

teacher -> UI : 1 选择学期
activate UI

UI -> SC : 2 查询哪些学生选了老师的课
activate SC

SC -> ST : 3 请求学生列表
activate ST
ST --> SC : 4 返回数据
deactivate ST

deactivate SC

UI -> EX : 5 查询这些课程的实验
activate EX

EX -> ES : 6 查询实验得分
activate ES

ES -> SI : 7 查询得分
activate SI
SI --> ES : 8 返回
deactivate SI

ES --> EX : 9 返回得分
deactivate ES

EX --> UI : 10 返回得分列表
deactivate EX

UI --> teacher : 11 显示数据
deactivate UI
@enduml