@startuml
hide footbox

participant "s:ObjectStructure" as s
participant "a:ConcreteElementA" as a
participant "b:ConcreteElementB" as b
participant "v1:ConcreteVisitor1" as v1

s -> a : accept(v1)
activate s
activate a

a -> v1 : visit(this)
activate v1

v1 -> a : operationA()
activate a
a --> v1
deactivate a
v1 --> a
deactivate v1

a --> s
deactivate a

s -> b : accept(v1)
activate b

b -> v1 : visit(this)
activate v1

v1 -> b : do nothing
b --> v1
deactivate v1

b --> s
deactivate b
deactivate s

@enduml