@startuml
title PLAYER's Class Diagram

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "cz" {
  package "kksffn" {
    package "player" {

      interface IPlayer {
        +getCoordinatesOfShips()
        +getGuess()
        +getName()
        +isHuman()
        +updateGuesses()
        +updateGuesses()
      }

      abstract class APlayer {
        -coordinatesOfShips : HashMap<ShipName, ArrayList<Integer>>
        -isHuman : boolean
        -name : String
        --
        +getCoordinatesOfShips()
        +getGuess()
        +getName()
        +isHuman()
        +updateGuesses()
        +updateGuesses()
      }

      class AI {
        +AI()
        +getCoordinatesOfShips()
        +getGuess()
        +updateGuesses()
        +updateGuesses()
        -setName()
      }

      class Human {
        +Human()
        +getCoordinatesOfShips()
        +getGuess()
        -setName()
        -setShips()
      }

      interface IStrategy {
        +findCoordinates()
        +updateGuesses()
        +updateGuesses()
      }

      class Strategy {
        -allGuesses : ArrayList<Integer>
        -allHits : ArrayList<Integer>
        -lastHit : int
        -lastHits : ArrayList<Integer>
        -myChances : int
        -myGuess : int
        -numberOfNotRandomMoves : int
        -rand : Random
        -sunkShips : ArrayList<ShipName>
        --
        +findCoordinates()
        +updateGuesses()
        +updateGuesses()
        -addTheRightCells()
        -addToGuesses()
        -alreadyGuessed()
        -doNotGuessFourth()
        -doNotGuessThird()
        -isNotOnBottom()
        -isNotOnTheLeftEdge()
        -isNotOnTheRightEdge()
        -isNotOnTheTop()
        -shootNextToFirstHitAgain()
        -thinkOfWhatNotToGuess()
        -tryNearestCells()
        -tryToSinkCarrier()
        -updateGuesses()
      }

      interface ISetShips

      APlayer ..|> IPlayer
      AI --|> APlayer
      Human --|> APlayer

      Strategy ..|> IStrategy

      AI o-- IStrategy : think
      APlayer o-- ISetShips : sea
    }

    package "prepare" {
      interface ISetShips
    }
  }
}
@enduml