@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam class {
  BackgroundColor White
  BorderColor #666666
}
skinparam stereotypeCBackgroundColor #CFE9CF
skinparam stereotypeABackgroundColor #BFE7E7

' --- Classes ---
abstract class Directory <<A>> {
  Directory表示一些扁平(没有子目录)文件的集合,这些文件都只能在创建时写入一次。
  写入之后,就只能读或者删除,不可再修改。

  // 返回目录下所有文件
  + String[] listAll()
  + void deleteFile(String name)
  + long fileLength(String name)
  // 创建一个新文件
  + IndexOutput createOutput(String name, IOContext context)
  // 创建一个临时文件
  + IndexOutput createTempOutput(String prefix, String suffix, IOContext context)
  // 确保对这些文件所有的写入都被转移到稳定的存储介质上去。
  + void sync(Collection<String> names)
  // 重命名文件
  + void rename(String source, String dest)
  // 持久化Directory的元数据
  + void syncMetaData()
  // 打开一个文件
  + IndexInput openInput(String name, IOContext context)
  // 获取锁
  + Lock obtainLock(String name)
}

abstract class BaseDirectory <<A>> {
  // Directory具体实现的基类, 使用LockFactory来获取锁
  ~ LockFactory lockFactory
}

class FileSwitchDirectory <<C>> {
  // / ??????
}

class RAMDirectory <<C>> {
  // 在内存中的实现
}

class FSDirectory <<A>> {
  // 在文件系统上的实现
  // 根据当前的环境来选择使用哪一种实现。
  {static} + FSDirectory open(Path path, LockFactory lockFactory)
  ~ Path directory
}

class SimpleFSDirectory <<C>> {
  //
}

class MMapDirectory <<C>> #98FB98 {
  <<Important>>
  // 使用Mmap来读取数据
}

class NIOFSDirectory <<C>> {
}

abstract class FilterDirectory <<A>> {
  // 装饰
}

class NRTCachingDirectory <<C>> {
}

class LockValidatingDirectoryWrapper <<C>> {
  // 在一些写操作进行之前, 提供锁的校验
}

class TrackingDirectoryWrapper <<C>> {
  // 可以记录创建了哪些文件
  + Set<String> getCreatedFiles()
}

class SleepingLockWrapper <<C>> {
  // 如果获取锁失败, 则休眠一段时间后重试。
}

' --- Inheritance / relationships ---
BaseDirectory --|> Directory
FSDirectory --|> BaseDirectory
RAMDirectory --|> BaseDirectory
FileSwitchDirectory --|> Directory

SimpleFSDirectory --|> FSDirectory
MMapDirectory --|> FSDirectory
NIOFSDirectory --|> FSDirectory

FilterDirectory --|> Directory
NRTCachingDirectory --|> FilterDirectory
LockValidatingDirectoryWrapper --|> FilterDirectory
TrackingDirectoryWrapper --|> FilterDirectory
SleepingLockWrapper --|> FilterDirectory
@enduml