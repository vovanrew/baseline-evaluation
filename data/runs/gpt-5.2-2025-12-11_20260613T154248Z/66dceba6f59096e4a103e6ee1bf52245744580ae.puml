  package "heap" {
    class HeapUsage << (C,#DDDDDD) >> {
      +Add(int)
      +Subtract(int)
      +WarnIfNeeded(void)
      +Get(void): int
      +Clear(void)
      +SetWarning(int, WarningDelegate)
    }

    class Heap << (C,#DDDDDD) >> {
      +New(int): void*
      +Delete(void**)
    }

    Heap -up-> HeapUsage
  }

  package "io_data" {
    class IoData << (C,#DDDDDD) >> {
      +Write(IoAddress, IoData)
      +Add(IoAddress, IoData)
      +Remove(IoAddress, IoData)
      +Read(IoAddress): IoData
    }
  }

  package "list" {
    class ListNode << (C,#DDDDDD) >> {
      +New(const void*): ListNode
      +Delete(ListNode)
      +GetItem(ListNode): void*
      +SetItem(ListNode, const void*)
      +GetNext(ListNode): ListNode
      +SetNext(ListNode, ListNode)
    }

    class List << (C,#DDDDDD) >> {
      +New(const void*): List
      +Delete(List*)
      +Count(List): int
      +Get(List, int): void*
      +Add(List, const void*)
      +Clear(List)
      +Find(List, const void*): void*
      +Pop(List, int): void*
      +SetItemComparer(List, ComparerInterface)
      +SetItemDeleter(List, DeleterInterface)
    }

    interface Comparer << (I,#DDDDDD) >> {
      +Compare(const void*, const void*): int
    }

    interface Deleter << (I,#DDDDDD) >> {
      +Delete(void**)
    }

    List -up-> ListNode
    List ..> Comparer
    List ..> Deleter
  }

  Heap <.. Queue
  Heap <.. Xorshift
  Heap <.. XorshiftPlus
  Heap <.. List
