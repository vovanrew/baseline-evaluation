    }
  }

  package "rng" {
  }

  package "xorshift" {
    abstract class Xorshift << (A,#DDDDDD) >> {
      +New(int, XorshiftAbstractMethod): Xorshift
      +Delete(Xorshift)
      +Give(Xorshift, uint32_t)
      +Generate(Xorshift): uint32_t
    }

    class Xorshift32 << (C,#DDDDDD) >> {
      +New(void): Xorshift
    }
    class Xorshift64 << (C,#DDDDDD) >> {
      +New(void): Xorshift
    }
    class Xorshift96 << (C,#DDDDDD) >> {
      +New(void): Xorshift
    }
    class Xorshift128 << (C,#DDDDDD) >> {
      +New(void): Xorshift
    }

    Xorshift32 -up-|> Xorshift
    Xorshift64 -up-|> Xorshift
    Xorshift96 -up-|> Xorshift
    Xorshift128 -up-|> Xorshift
  }

  package "xorshift_plus" {
    abstract class XorshiftPlus << (A,#DDDDDD) >> {
      +New(int, XorshiftPlusAbstractMethod): XorshiftPlus
      +Delete(XorshiftPlus)
      +Give(XorshiftPlus, uint64_t)
      +Generate(XorshiftPlus): uint64_t
    }

    class Xorshift128Plus << (C,#DDDDDD) >> {
      +New(void): XorshiftPlus
    }

    Xorshift128Plus -up-|> XorshiftPlus
