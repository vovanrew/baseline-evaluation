@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "XXX" {
  interface Shape {
    +void draw()
  }

  class Circle {
    +void draw()
  }

  class Rectangle {
    +void draw()
  }

  class Square {
    +void draw()
  }

  Circle ..> Shape : implement
  Rectangle ..> Shape : implement
  Square ..> Shape : implement
}

class ShapeFactory {
  +Shape getShape()
}

class FactoryPatternDemo {
  +void main()
}

FactoryPatternDemo --> ShapeFactory : ask
ShapeFactory --> "XXX" : create
@enduml