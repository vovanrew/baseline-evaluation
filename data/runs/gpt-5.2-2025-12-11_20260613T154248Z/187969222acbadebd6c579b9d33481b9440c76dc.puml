```plantuml
@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #999999

title 类图

class User {
  int id
  string name
  string github（github地址）
  string sex
  string picture
}

class Teacher {
  int teacherNumber（工号）
  string office（办公室）
  string phone
}

class Student {
  int studentNumber（学号）
  string class（班级）
}

class TeacherCourse {
  int id
  int teacherId
  int courseId
}

class StudentCourse {
  int id
  int studentId
  int courseId
}

class Course {
  int id
  int courseNum
  string name
  string term
  float credit（学分）
}

class Experiment {
  int id
  string name（实验名）
  Date date（实验发布时间）
  string github（实验的github地址）
  int courseId（与Course类的id关联）
}

class Scoreitem {
  int id
  int complexScore（复杂度得分）
  int completeScore（完成度得分）
  int answerScore（答辩得分）
}

class Experimentscore

class Login {
  int id
  int username（学生账号就是学号，老师账号是工号）
  string password
  int role（角色）
}

class Experimentcore {
  int id
  int studentId（与学生关联）
  int scoreitemId（与scoreitem关联）
}

Teacher --|> User
Student --|> User

Teacher "1" -- "n" TeacherCourse
TeacherCourse "n" -- "1" Course

Student "1" -- "n" StudentCourse
StudentCourse "n" -- "1" Course

Course "1" -- "n" Experiment
Experiment "1" -- "n" Scoreitem

Student "1" -- "n" Experimentscore
