}

package "РегистрСведений" as P {
  class "«РегистрыСведений»\nЗначения разовых показателей расчета зарплаты (для сотрудников)" as R {
    .. Измерения ..
    ПериодДействия : Дата
    Сотрудник : Справочник.Сотрудник
    Показатель : Справочник.Показатель
    Организация : Справочник.Организация
    ФизическоеЛицо : Справочник.Физическое лицо
    .. Ресурсы ..
    Значение : Число 15, 5
  }
}
@enduml