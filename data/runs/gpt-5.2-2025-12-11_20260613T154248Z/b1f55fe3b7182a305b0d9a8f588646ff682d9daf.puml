@startuml
hide footbox
skinparam shadowing false
skinparam sequence {
  ParticipantPadding 80
  BoxPadding 20
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ActorBorderColor #000000
  ActorFontSize 28
  ParticipantFontSize 28
  MessageFontSize 28
  NoteFontSize 24
  GroupFontSize 28
  GroupHeaderFontSize 28
  GroupBorderThickness 4
  MessageThickness 3
  ArrowThickness 3
}

actor "顧客" as C
participant ":入力画面" as UI
participant ":貸出コントローラ" as CTRL

C -> UI : 1 データ入力

opt "ログイン成功"
  UI -> CTRL : 10 通常貸出()
  CTRL --> UI : 11 貸出明細情報()
end
@enduml