@startuml
hide footbox
participant User
participant Adder
participant Value
participant Expression

User -> Adder : Start the operation
activate Adder

Adder -> Adder : applyTo

Adder -> Value : getTypeMatrix
Adder -> Expression : getLeftOperand
Adder -> Value : getTypeMatrix
Adder -> Expression : getRightOperand

Adder --> User : result
deactivate Adder
@enduml