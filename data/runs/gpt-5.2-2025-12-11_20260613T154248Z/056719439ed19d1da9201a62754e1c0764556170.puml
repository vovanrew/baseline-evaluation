  BorderColor #666666
  BackgroundColor #E9E9FF
  FontSize 22
}

actor User

box "GIT                              jalbertomr.blogspot.com" #E6E6E6
participant "Working dir" as WD
participant "Stage" as ST
database "History" as HIS
end box

note over WD
end note

note over WD #FF5A5A
Working dir
end note

note over ST #98FB98
Stage
end note

note over HIS
History
end note

== create file2, add, reset, delete ==

User -> WD : create file2

note over ST #FF8A80
file2 created
end note

WD -> ST : <color:lime><b>git add file2</b></color> .
note over ST #98FB98
file2 created
end note

ST -> WD : <color:lime><b>git [ reset | reset file2 | reset HEAD file2 ]</b></color> .
note over ST #FF8A80
file2 created
end note

User <-- WD : delete file2

@enduml
