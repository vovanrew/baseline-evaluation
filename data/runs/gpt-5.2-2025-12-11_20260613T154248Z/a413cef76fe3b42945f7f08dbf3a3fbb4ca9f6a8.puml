@startuml
title 接口隔离原则

skinparam backgroundColor #EEF3F4
skinparam shadowing false
skinparam class {
  BackgroundColor #D7DEE0
  BorderColor #8A8F93
  FontColor #2F3A3A
  AttributeIconSize 0
}
skinparam stereotypeCBackgroundColor #5BC0EB
skinparam stereotypeIBackgroundColor #CFEA7A

class A <<C>> 
class B <<C>>
class C <<C>>
class D <<C>>

interface "Interface2" as Interface2 {
  +operation2(): void
  +operation3(): void
}

interface "Interface1" as Interface1 {
  +operation1(): void
}

interface "Interface3" as Interface3 {
  +operation4(): void
  +operation5(): void
}

A ..> Interface2
A ..> Interface1

B ..> Interface2
B ..> Interface1

C ..> Interface1
C ..> Interface3

D ..> Interface1
D ..> Interface3

@enduml