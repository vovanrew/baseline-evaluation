@startuml
hide methods
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundcorner 15
skinparam class {
  BackgroundColor #F2F2F2
  BorderColor #333333
  HeaderBackgroundColor #F2F2F2
  FontSize 28
  AttributeFontSize 28
  FontStyle bold
}

class "users\n(사용자)" as users {
  id INTEGER
  __name__ VARCHAR[30]
  __email__ VARCHAR[30]
  phone_no VARCHAR[12]
  __enabled__ BOOL
}
@enduml