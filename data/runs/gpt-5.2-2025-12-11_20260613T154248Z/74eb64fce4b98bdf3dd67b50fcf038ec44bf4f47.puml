@startuml
skinparam shadowing false
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "com" {
  package "qxcode" {
    class Car {
      -gas : int
      -gasMax : int
      -km : int
      -pass : int
      -passMax : int
      --
      +Car()
      +drive(km : int)
      +enter()
      +fuel(gas : int)
      +leave()
      +toString() : String
    }
  }
}
@enduml