@startuml
hide footbox
skinparam sequenceMessageAlign left
skinparam ParticipantPadding 30
skinparam BoxPadding 10

participant User_App
participant WebRTC_GW
participant SkyWay_Server
participant Target_Peer

User_App -> WebRTC_GW: POST /peers\n{\n  key: "YOUR_API_KEY",\n  domain: "localhost",\n  turn: true,\n  peer_id: "media_caller"\n}
WebRTC_GW --> User_App: 201 Created\n{\n  command_type: "PEERS_CREATE",\n  params: {\n    peer_id: "media_caller",\n    token: "pt-be747373-5762-401f-a526-01fa44d98a11"\n  }\n}

User_App -> WebRTC_GW: GET /peers/media_caller/events?\ntoken=pt-be747373-5762-401f-a526-01fa44d98a11
WebRTC_GW -> SkyWay_Server: CREATE PEER
SkyWay_Server --> WebRTC_GW: SUCCESS\n(to bind peer_id)
WebRTC_GW --> User_App: 200 OK\n{\n  "event": "OPEN",\n  params: {\n    peer_id: "media_caller",\n    token: "pt-be747373-5762-401f-a526-01fa44d98a11"\n  }\n}

User_App -> WebRTC_GW: POST /media\n{\n  is_video=true\n}
WebRTC_GW --> User_App: 201 Created\n{\n  ip_v4: "172.16.1.106",\n  media_id: "ip-9856040d-bd3e-4b33-b121-e3435842e5fc",\n  port: 50003\n}

User_App -> WebRTC_GW: POST /media\n{\n  is_video=false\n}
WebRTC_GW --> User_App: 201 Created\n{\n  ip_v4: "172.16.1.106",\n  media_id: "au-a46c482c-9d9c-4e12-a52a-c927ec33793e",\n  port: 50004\n}

User_App -> WebRTC_GW: POST /media/rtcp\n{}
WebRTC_GW --> User_App: 201 Created\n{\n  "rtcp_id": "rc-970f2e5d-4da0-43e7-92b6-796678c10a4d",\n  "port": 50003,\n  "ip_v4": "172.16.1.106"\n}

User_App -> WebRTC_GW: POST /media/rtcp\n{}
WebRTC_GW --> User_App: 201 Created\n{\n  "rtcp_id": "rc-4044658s-dee5-4aac-a60a-ad133bab4f92",\n  "port": 50004,\n  "ip_v4": "172.16.1.106"\n}

User_App -> WebRTC_GW: POST /media/connections\n{\n  peer_id: "media_caller",\n  token: "pt-be747373-5762-401f-a526-01fa44d98a11",\n  target_id: "media_callee",\n  constraints: {\n    video: true,\n    videoReceiveEnabled: true,\n    audio: true,\n    audioReceiveEnabled: true,\n    video_params: {\n      band_width: 1500,\n      codec: "H264",\n      media_id: "ip-9856040d-bd3e-4b33-b121-e3435842e5fc",\n      rtcp_id: "rc-970f2e5d-4da0-43e7-92b6-796678c10a4d",\n      payload_type: 100\n    },\n    audio_params: {\n      band_width: 1500,\n      codec: "opus",\n      media_id: "au-a46c482c-9d9c-4e12-a52a-c927ec33793e",\n      rtcp_id: "rc-4044658s-dee5-4aac-a60a-ad133bab4f92",\n      payload_type: 111\n    }\n  },\n  redirect_params: {\n    video: {\n      ip_v4: "172.16.1.105",\n      port: 20000\n    },\n    video_rtcp: {\n      ip_v4: "172.16.1.105",\n      port: 20010\n    },\n    audio: {\n      ip_v4: "172.16.1.105",\n      port: 20001\n    },\n    audio_rtcp: {\n      ip_v4: "172.16.1.105",\n      port: 20011\n    }\n  }\n}
WebRTC_GW --> User_App: 201 Created\n{\n  command_type: "MEDIA_CONNECTION_CREATE",\n  params: {\n    media_connection_id: "mc-55f0b9c7-77c7-42d7-b21b-a6a6cb3cfe3a"\n  }\n}

User_App -> WebRTC_GW: GET /media/connections\n/mc-55f0b9c7-77c7-42d7-b21b-a6a6cb3cfe3a/events
WebRTC_GW --> User_App: 200 OK\n{\n  event: "READY"\n}

loop
  User_App -> WebRTC_GW: send RTP Video to 172.16.1.106:50001
  WebRTC_GW -> Target_Peer: redirect Video with MediaStream

  User_App -> WebRTC_GW: send RTP Audio to 172.16.1.106:50002
  WebRTC_GW -> Target_Peer: redirect Audio with MediaStream

  User_App -> WebRTC_GW: send RTCP for Video to 172.16.1.106:50003
  WebRTC_GW -> Target_Peer: redirect RTCP with MediaStream

  User_App -> WebRTC_GW: send RTCP for Audio to 172.16.1.106:50004
  WebRTC_GW -> Target_Peer: redirect RTCP with MediaStream

  User_App -> WebRTC_GW: redirect RTP Video to 172.16.1.105:20000
  WebRTC_GW -> Target_Peer: recv Video with MediaStream

  User_App -> WebRTC_GW: redirect RTP Audio to 172.16.1.105:20001
  WebRTC_GW -> Target_Peer: recv Audio with MediaStream

  User_App -> WebRTC_GW: redirect RTCP for Video to 172.16.1.105:20010
  WebRTC_GW -> Target_Peer: recv RTCP for Video with MediaStream

  User_App -> WebRTC_GW: redirect RTCP for Audio to 172.16.1.105:20011
  WebRTC_GW -> Target_Peer: recv RTCP for Audio with MediaStream
end

User_App -> WebRTC_GW: Delete /media/connections\n/mc-55f0b9c7-77c7-42d7-b21b-a6a6cb3cfe3a
WebRTC_GW -> Target_Peer: Close MediaStream
WebRTC_GW -> Target_Peer: erase Video object\nand Audio object
WebRTC_GW --> User_App: 204 No Content

User_App -> WebRTC_GW: Delete /peers/media_caller?token=pt-be747373-5762-401f-a526-01fa44d98a11
WebRTC_GW -> SkyWay_Server: disconnect
WebRTC_GW --> User_App: 204 No Content
@enduml