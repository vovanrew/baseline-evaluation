@startuml
skinparam classAttributeIconSize 0

interface CarPart {
  + PrintPart()
  + AddPart(v interface{})
  + RemovePart(v interface{})
}

class CylinderBlock
class Sump
class Crankshaft
class Rod

class Engine {
  Container: list.List
}

class Absorber
class Damping
class Stabilizer
class Rack
class Lever
class Spring

class Suspension {
  Container: list.List
}

class Car {
  Container: list.List
}

CylinderBlock --> Engine
Sump --> Engine
Crankshaft --> Engine
Rod --> Engine

Absorber --> Suspension
Damping --> Suspension
Stabilizer --> Suspension
Rack --> Suspension
Lever --> Suspension
Spring --> Suspension

Engine --> Car
Suspension --> Car

Engine ..|> CarPart
Suspension ..|> CarPart
Car ..|> CarPart
@enduml