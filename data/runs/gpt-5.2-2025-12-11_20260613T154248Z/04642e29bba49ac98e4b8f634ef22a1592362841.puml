@startuml
hide footbox
skinparam shadowing false
skinparam sequence {
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #000000
  ParticipantBackgroundColor #E6E6FA
  ActorBorderColor #000000
  ActorBackgroundColor #E6E6FA
  ArrowColor #000000
  ArrowThickness 2
  MessageAlign center
}

actor User as User
participant A as A
participant B as B
participant C as C

User -> A : DoWork
activate A

A -> B : «createRequest»
activate B

B -> C : DoWork
activate C

C --> B : WorkDone
destroy C

B --> A : RequestCreted
deactivate B

A -> User : Done
deactivate A
@enduml