@startuml
title AI's Class Diagram

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "com" {
  package "dekinci" {
    package "eden" {
      package "model" {
        package "animal" {
          package "ai" {

            class AnimalVision {
              grass : double[]
              hares : double[]
              wolves : double[]
              land : double[]
              water : double[]
