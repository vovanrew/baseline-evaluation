@startuml
hide footbox
skinparam shadowing false
skinparam sequence {
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #E6E6F2
  ParticipantBorderColor #000000
  ParticipantBackgroundColor #E6E6F2
  ActorBorderColor #000000
  ActorBackgroundColor #E6E6F2
  ArrowColor #000000
  MessageAlign left
}

actor Player as PlayerTop
participant Game
participant Screen
participant Line
participant Figure

PlayerTop -> Game : Reset
Game -> Screen : Reset
Screen -> Line : Reset
Line --> Game
Game -> Figure : Create
Figure --> PlayerTop

@enduml