@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundcorner 10

class TilePyramid

enum TGCEDatatype {
  integer
  float
}

enum GridCellEncoding {
  grid-value-is-center
  grid-value-is-area
  grid-value-is-corner
}

class TiledGriddedCoverage {
  id: Integer
  dataType = tiles
  coverageDataType: TGCEDatatype
  scale: Real
  offset: Real
  precision: Real?
  nullValue: Real?
  gridCellEncoding: GridCellEncoding?
  unitOfMeasure: String?
  fieldName: String?
  quantityDefinition: String?
}

class Tile

class CoverageTile {
  scale: Real
  offset: Real
  min: Real?
  max: Real?
  mean: Real?
  standardDeviation: Real?
}

TiledGriddedCoverage --|> TilePyramid

TilePyramid o-- "*" Tile

TiledGriddedCoverage o-- "*" CoverageTile

CoverageTile --|> Tile

@enduml