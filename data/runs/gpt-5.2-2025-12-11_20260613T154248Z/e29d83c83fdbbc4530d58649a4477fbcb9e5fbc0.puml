@startuml
title <u><b>EXCEPTION's Class Diagram</b></u>

package "com" {
  package "deta" {
    package "kopmart_backend" {
      package "exception" {
        class "MyException" as MyException {
          - code : Integer
          + MyException()
          + MyException()
        }
      }
    }
  }
}
@enduml