@startuml
title DeTrace Creature connection

hide footbox
skinparam sequenceMessageAlign left
skinparam ParticipantPadding 25
skinparam BoxPadding 10

participant "«Creature: Wheel»\nWheel_1" as W1
participant "«Creature: BBBBB»\nWheel_1" as BWheel1
participant "«Creature: Wheel»\nWheel_2" as W2
participant "B_1" as B1
participant "«Creature: Wheel»\nWheel_3" as W3
participant "«Creature: Wheel»\nWheel_4" as W4
participant "«Creature: Wheel»\nWheel_5" as W5
participant "«Creature: Frame»\nFrame" as F

== ==

W1 -> W2 : 1 changeOwner
activate W1
activate W2

W2 -> W2 : 2 checkMatrix
W2 -> W2 : 3 checkSlot
W2 -> W2 : 4 checkOwner

W1 ->x W1 : 5 connectError
deactivate W1

BWheel1 -> B1 : 6 cdcdcdcdcd
activate BWheel1
activate B1
deactivate BWheel1
deactivate B1

deactivate W2

== ==

W3 -> F : 1 changeOwner
activate W3
activate F

F -> F : 2 checkMatrix
F -> F : 3 checkOwner
F -> F : 4 checkSlot

F -> W3 : 5 connect
deactivate W3

W4 -> F : 6 changeOwner
activate W4

F -> F : 7 checkMatrix
F -> F : 8 checkOwner
F -> F : 9 checkSlot

F -> W4 : 10 connect
deactivate W4

W5 -> F : 11 changeOwner
activate W5

F -> F : 12 checkMatrix
F -> F : 13 checkOwner
F -> F : 14 checkSlot

W5 ->x W5 : 15 connect
deactivate W5
deactivate F

@enduml