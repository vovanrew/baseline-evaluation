@startuml
skinparam classAttributeIconSize 0

interface Creator {
  +factoryMethod()
}

class ConcreteCreator {
  +factoryMethod()
}

interface Product
class ConcreteProduct

ConcreteCreator -|> Creator
ConcreteProduct -|> Product
ConcreteCreator --> ConcreteProduct

interface Device
class PC
class Laptop
class Phone

PC ..|> Device
Laptop ..|> Device
Phone ..|> Device
@enduml