@startuml
left to right direction
skinparam sequenceMessageAlign center
skinparam note {
  BackgroundColor #FFFFE0
  BorderColor #999999
}

participant "AbstractApplicationContext" as AbstractApplicationContext
participant "GenericApplicationContext" as GenericApplicationContext
participant "ApplicationContextAwareProcessor" as ApplicationContextAwareProcessor
participant "AbstractAutowireCapableBeanFactory" as AbstractAutowireCapableBeanFactory
participant "DefaultListableBeanFactory" as DefaultListableBeanFactory

note over AbstractApplicationContext
  以下流程都在refresh()方法内部
end note

note over AbstractApplicationContext
  第1步
end note

AbstractApplicationContext->AbstractApplicationContext: 1 prepareRefresh
