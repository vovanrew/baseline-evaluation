@startuml
!theme plain
skinparam packageStyle rectangle
skinparam class {
  ArrowSize 2
  BackgroundColor White
  BorderColor Black
  FontColor Black
  FontSize 12
  LineColor Black
  Padding 10
  Shape Border
  Width 200
  Height 100
}

package "com" {
  package "jue" {
    package "meet" {
      package "model" {
        class "AddFriendModel" {
          +age : int
          +contactName : String
          +contactPhone : String
          +desc : String
          +isContact : boolean
          +nickName : String
          +photo : String
          +sex : boolean
          +title : String
          +type : int
          +userId : String
          
          +getAge()
          +getContactName()
          +getContactPhone()
          +getDesc()
          +getNickName()
          +getPhoto()
          +getTitle()
          +getType()
          +getUserId()
          +isContact()
          +isSex()
          +setAge()
          +setContact()
          +setContactName()
          +setContactPhone()
          +setDesc()
          +setNickName()
          +setPhoto()
          +setSex()
          +setTitle()
          +setType()
          +setUserId()
        }
        
        class "ChatModel" {
          +address : String
          +imgUrl : String
          +la : double
          +lo : double
          +localFile : File
          +mapUrl : String
          +messageTime : long
          +text : String
          +type : int
          
          +getAddress()
          +getImgUrl()
          +getLa()
          +getLo()
          +getLocalFile()
          +getMapUrl()
          +getMessageTime()
          +getText()
          +getType()
          +setAddress()
          +setImgUrl()
          +setLa()
          +setLo()
          +setLocalFile()
          +setMapUrl()
          +setMessageTime()
          +setText()
          +setType()
        }
        
        class "AllFriendModel" {
          +desc : String
          +nickName : String
          +sex : boolean
          +url : String
          +userId : String
          
          +getDesc()
          +getNickName()
          +getUrl()
          +getUserId()
          +isSex()
          +setDesc()
          +setNickName()
          +setSex()
          +setUrl()
          +setUserId()
        }
        
        class "ChatRecordModel" {
          +endMsg : String
          +nickName : String
          +time : String
          +unReadSize : int
          +url : String
          +userId : String
          
          +getEndMsg()
          +getNickName()
          +getTime()
          +getUnReadSize()
          +getUrl()
          +getUserId()
          +setEndMsg()
          +setNickName()
          +setTime()
          +setUnReadSize()
          +setUrl()
          +setUserId()
        }
        
        class "StarModel" {
          +nickName : String
          +photoUrl : String
          +userId : String
          
          +getNickName()
          +getPhotoUrl()
          +getUserId()
          +setNickName()
          +setPhotoUrl()
          +setUserId()
        }
        
        class "UserInfoModel" {
          +bgColor : int
          +content : String
          +title : String
          
          +getBgColor()
          +getContent()
          +getTitle()
          +setBgColor()
          +setContent()
          +setTitle()
        }
      }
    }
  }
}

@enduml