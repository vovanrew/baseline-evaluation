@startuml
class "Artisan" {
  +salaire
  +coordonnee
  +getPaye()
}

class "Travailler" {
  +nbHeure
  +debMission
  +finMission
  +calculerPaye()
}

class "Chantier" {
  +dateD
  +dateF
  +adresse
  +getAdresse()
  +affecterArtisan()
}

"Artisan" -- "Chantier" : 1..*
"Chantier" -- "Travailler" : 0..*
@enduml