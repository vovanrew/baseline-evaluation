@startuml
!theme plain

class "Dummy" {
  <<C>>
  - private
  + protected
  + pkg method()
  + public()
}

class "User" {
  <<I>>
  + createAccount(AccountType)
  + login()
  + logout()
}

class "Admin" {
  <<C>>
  + createService()
  + removeAccount()
  + removeAccount()
  + setHourlyRate()
  + setForm(Service.type, customerInfo)
}

class "Employee" {
  <<C>>
  + createAccount(Employee)
  + selectService()
  + setBusinessHour()
  + boolean processServiceRequest()
  + notifyCustomer()
}

class "Customer" {
  <<C>>
  + createAccount(Customer)
  + searchBranch()
  + selectService()
  + getForm(Service.type).fill()
  + submitForm()
  + rateBranch()
}

class "Form" {
  <<I>>
  + firstName
  + lastName
  + dateOfBirth
  + address
  + email
}

class "RentalForm" {
  <<A>>
  + pickupTime
  + returnTime
  + licenseType
}

class "MovingForm" {
  <<C>>
  + startLocation
  + endLocation
  + numberOfMovers
  + numberOfBoxes
}

class "carRentalForm" {
  <<C>>
  + carType
}

class "truckRentalForm" {
  <<C>>
  + usageArea
}

"Dummy" ..> "User" : extends
"Admin" ..> "User" : extends
"Employee" ..> "User" : extends
"Customer" ..> "User" : extends
"Form" ..> "RentalForm" : extends
"Form" ..> "MovingForm" : extends
"RentalForm" ..> "carRentalForm" : extends
"RentalForm" ..> "truckRentalForm" : extends

@enduml