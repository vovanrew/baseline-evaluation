@startuml
!define ActorIcon "C"
!define ActorColor "#90EE90"
!define ActorBorder "#000000"
!define ActorText "#000000"
!define ActorFont "Arial"
!define ActorSize "14"

class Person {
  [name]
  [lastname]
  [NationalID]
  [birth date]
  [favorite food]
  [favorite color]
  +TellName()
  +TellAge()
  +Singing()
  +Driving()
  +Swimming()
}

Person << Actor >>
Person : Person
Person : name
Person : lastname
Person : NationalID
Person : birth date
Person : favorite food
Person : favorite color
Person : TellName()
Person : TellAge()
Person : Singing()
Person : Driving()
Person : Swimming()

@enduml