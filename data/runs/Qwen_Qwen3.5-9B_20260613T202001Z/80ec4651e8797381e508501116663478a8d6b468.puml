@startuml
!theme plain

package "ca" {
  package "ualberta" {
    package "CMPUT3012019T02" {
      package "alexandria" {
        package "model" {
          class "chatroom.ChatRoomItem" {
            - chatId : String
            - userId : String
            - userName : String
            - user1UserPic : String
            - user2Id : String
            - user2Name : String
            - user2UserPic : String
            - readStatus : boolean
            + ChatRoomItem()
            + ChatRoomItem()
            + toMap()
            + getUserId()
            + setUserId()
            + getUserName()
            + setUserName()
            + getUser1UserPic()
            + setUser1UserPic()
            + getUser2Id()
            + setUser2Id()
            + getUser2Name()
            + setUser2Name()
            + getUser2UserPic()
            + setUser2UserPic()
            + getChatId()
            + setChatId()
            + getReadStatus()
            + setReadStatus()
          }

          class "message.Message" {
            - id : String
            - type : String
            - content : String
            - status : String
            - date : Long
            - sender : String
            + Message()
            + Message()
            + toMap()
            + getId()
            + setId()
            + getType()
            + setType()
            + getContent()
            + setContent()
            + getStatus()
            + setStatus()
            + getDate()
            + setDate()
            + getSender()
            + setSender()
          }

          class "message.ImageMessage" {
            - imageId : String
            + ImageMessage()
            + getImage()
            + setImage()
          }

          class "message.LocationMessage" {
            - imageId : String
            + LocationMessage()
            + getLocation()
            + setLocation()
            + getImageId()
            + setImageId()
          }

          class "message.TextMessage" {
            + TextMessage()
            + TextMessage()
            + getText()
            + setText()
          }

          class "Location" {
            - latitude : double
            - longitude : double
            + Location()
            + getLatitude()
            + setLatitude()
            + getLongitude()
            + setLongitude()
          }

          class "user.User" {
            - chatRoomList : Map<String, ChatRoomItem>
            - ownedBooks : Map<String, OwnedBook>
            - borrowedBooks : Map<String, BorrowedBook>
            - userProfile : UserProfile
            - id : String
            + User()
            + getChatRoomList()
            + getOwnedBooks()
            + getBorrowedBooks()
            + getProfile()
            + getId()
          }

          "chatroom.ChatRoomItem" ..> "message.Message" : associated with
          "chatroom.ChatRoomItem" ..> "user.User" : associated with
          "message.Message" <|-- "message.ImageMessage"
          "message.Message" <|-- "message.LocationMessage"
          "message.Message" <|-- "message.TextMessage"
          "message.LocationMessage" o-- "Location" : location
        }
      }
    }
  }
}

@enduml