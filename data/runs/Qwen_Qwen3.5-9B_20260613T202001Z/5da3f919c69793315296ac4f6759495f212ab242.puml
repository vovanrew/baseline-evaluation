@startuml
class "Display" as Display {
  +getColumns(): int
  +getRows(): int
  +getRowText(row: int): String
  +show(): void
}

class "StringDisplay" as StringDisplay {
  -string: String
  +getColumns(): int
  +getRows(): int
  +getRowText(row: int): String
}

class "Border" as Border {
  <<interface>>
  +display: Display
  +Border(display: Display)
}

class "SideBorder" as SideBorder {
  -borderChar: char
  +SideBorder(display: Display, ch: char)
  +getColumns(): int
  +getRows(): int
  +getRowText(row: int): String
}

class "FullBorder" as FullBorder {
  +FullBorder(display: Display)
  +getColumns(): int
  +getRows(): int
  +getRowText(row: int): String
  +makeLine(ch: char, count: int): void
}

Display <|-- StringDisplay
Display <|-- Border
Border <|-- SideBorder
Border <|-- FullBorder

@enduml