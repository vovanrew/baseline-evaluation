@startuml
left to right direction
skinparam packageStyle rectangle
skinparam class {
  ArrowSize 2
  BackgroundColor White
  BorderColor Black
  FontColor Black
  FontSize 12
  Alignment Left
}

class "MediumDungeon" as MediumDungeon {
  [C]
  newBokoblin() : Bokoblin
  newMoblin() : Moblin
}

class "EasyDungeon" as EasyDungeon {
  [C]
  newBokoblin() : Bokoblin
  newMoblin() : Moblin
}

class "Encounter" as Encounter {
  [C]
  enemies : [Monster]
  dungeon : Dungeon
  announceEnemies()
  moveEnemies()
}

class "BlueBokoblin" as BlueBokoblin {
  [C]
  announce()
  move()
  bludgeon()
  defend()
}

class "BlueMoblin" as BlueMoblin {
  [C]
  announce()
  move()
  stab()
  kick()
}

class "NormalBokoblin" as NormalBokoblin {
  [C]
  announce()
  move()
  bludgeon()
  defend()
}

class "NormalMoblin" as NormalMoblin {
  [C]
  announce()
  move()
  stab()
  kick()
}

class "Dungeon" as Dungeon {
  [I]
  newBokoblin() : Bokoblin
  newMoblin() : Moblin
}

class "Bokoblin" as Bokoblin {
  [I]
  bludgeon()
  defend()
}

class "Moblin" as Moblin {
  [I]
  stab()
  kick()
}

class "Monster" as Monster {
  [I]
  announce()
  move()
}

MediumDungeon --|> Dungeon
EasyDungeon --|> Dungeon
Encounter --|> Dungeon

MediumDungeon ..> BlueBokoblin
MediumDungeon ..> BlueMoblin
EasyDungeon ..> NormalBokoblin
EasyDungeon ..> NormalMoblin

BlueBokoblin ..> Bokoblin
BlueMoblin ..> Moblin
NormalBokoblin ..> Bokoblin
NormalMoblin ..> Moblin

Bokoblin ..> Monster
Moblin ..> Monster

@enduml