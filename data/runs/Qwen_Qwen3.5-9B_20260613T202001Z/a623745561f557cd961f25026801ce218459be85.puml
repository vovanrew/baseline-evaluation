@startuml
!theme plain

package "org" as org {
  package "accordproject" as accordproject {
    package "empty" as empty {
      class EmptyClause {
        <<Actor>>
      }
      class EmptyRequest {
        <<Test>>
      }
      class EmptyResponse {
        <<Test>>
      }
    }
    package "contract" as contract {
      class Clause {
        <<Component>>
      }
    }
    package "runtime" as runtime {
      class Request {
        <<Component>>
      }
      class Response {
        <<Component>>
      }
    }
  }
}

empty.EmptyClause --> contract.Clause
empty.EmptyRequest --> runtime.Request
empty.EmptyResponse --> runtime.Response

@enduml