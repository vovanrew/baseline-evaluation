@startuml
autonumber
left to right direction
skinparam sequenceMessageAlign center

actor A
participant "CircuitBreaker" as CB
actor B

alt [no errors]
  A -> CB: call()
  activate CB
  CB -> B: call()
  activate B
  B --> CB: response
  deactivate B
  CB --> A: response
  deactivate CB
else [errors]
  A -> CB: call()
  activate CB
  loop [while err_count < max_errors]
    CB -> B: call()
    activate B
    B x-> CB: error
    deactivate B
    CB -> CB: err_count ++
    deactivate CB
  end
  CB -> CB: sleep(timeout)
  activate CB
  deactivate CB
  CB -> B: call()
  activate B
  B x-> CB: error
  deactivate B
  CB -> CB: sleep(timeout*2)
  activate CB
  deactivate CB
  CB -> B: call()
  activate B
  B x-> CB: error
  deactivate B
  CB --> A: error
  deactivate CB
end
@enduml