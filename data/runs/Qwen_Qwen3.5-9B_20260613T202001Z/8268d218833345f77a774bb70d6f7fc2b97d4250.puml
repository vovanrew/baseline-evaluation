@startuml
!theme plain

class plugin_translation {
  [I] plugin_translation ((Translations))
  label string
  description longText
  manufacturerLink string
  supportLink string
  changelog json
  customFields customFields
  createdAt createdAt
  updatedAt updatedAt
  pluginId foreignKey
  languageId foreignKey
}

class plugin {
  [T] plugin (Plugin)
  id id
  baseClass string
  name string
  composerName string
  autoload json
  active bool
  managedByComposer bool
  path string
  author string
  copyright string
  license string
  version string
  upgradeVersion string
  installedAt date
  upgradedAt date
  iconRaw blob
  icon string
  label translated
  description translated
  manufacturerLink translated
  supportLink translated
  changelog translated
  customFields translated
  createdAt createdAt
  updatedAt updatedAt
  translated json
}

class language {
  [T] language
}

class payment_method {
  [T] payment_method
}

plugin_translation --> plugin
plugin_translation --> language
plugin --> payment_method

@enduml