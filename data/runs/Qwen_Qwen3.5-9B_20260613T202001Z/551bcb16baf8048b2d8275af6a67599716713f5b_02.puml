@startuml
class "Message" as Message {
  + topic : string
  + hdr : Header
  + data : Frame
  + getters / setters
  + version()
  + len()
  + data()
  + topic()
}

class "Frame" as Frame {
  + data
  + len
  + Frame(len)
  + Frame(len, data)
  + ~Frame()
  + getters / setters
  + len()
  + get()
  + set(data, len)
}

class "Header" as Header {
  + version : uint32_t
  + len : uint32_t
}

Message --|> Frame :
Message --|> Header :

@enduml