@startuml
!theme plain

class "Pizza" as Pizza {
  +void prepare()
  +void bake()
  +void cut()
  +void box()
}

class "LDPepperPizza" as LDPepperPizza {
}

class "LDCheesePizza" as LDCheesePizza {
}

class "BJPepperPizza" as BJPepperPizza {
}

class "BJCheesePizza" as BJCheesePizza {
}

class "AbsFactory" as AbsFactory {
  +Pizza createPizza()
}

class "LDFactory" as LDFactory {
}

class "BJFactory" as BJFactory {
}

class "OrderPizza" as OrderPizza {
}

Pizza <|-- LDPepperPizza
Pizza <|-- LDCheesePizza
Pizza <|-- BJPepperPizza
Pizza <|-- BJCheesePizza

AbsFactory <|-- LDFactory
AbsFactory <|-- BJFactory

LDFactory ..> AbsFactory
BJFactory ..> AbsFactory

OrderPizza o-- AbsFactory

note left of Pizza
  A
end note

note right of LDPepperPizza
  C
end note

note right of LDCheesePizza
  C
end note

note right of BJPepperPizza
  C
end note

note right of BJCheesePizza
  C
end note

note left of AbsFactory
  I
end note

note left of LDFactory
  C
end note

note left of BJFactory
  C
end note

note left of OrderPizza
  C
end note

@enduml