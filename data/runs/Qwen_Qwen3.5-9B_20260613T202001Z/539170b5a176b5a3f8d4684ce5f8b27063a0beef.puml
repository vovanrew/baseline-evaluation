@startuml
left to right direction
package "InheritanceDesign" as pkg {
  class Bond {
    <<C>>
  }
  class Stock {
    <<C>>
  }
  class Car {
    <<C>>
  }
  class House {
    <<C>>
  }
  class Wealth {
    <<C>>
  }
  class Security {
    <<A>>
  }
  class BankAccount {
    <<C>>
  }
  class Property {
    <<A>>
  }
  class Asset {
    <<A>>
  }

  Bond --|> Security
  Stock --|> Security
  Car --|> Property
  House --|> Property
  Security --|> Asset
  BankAccount --|> Asset
  Property --|> Asset

  Wealth ..> Asset
  Wealth ..> Security
  Wealth ..> Property
  Wealth ..> BankAccount
}

package "java" as java {
  package "lang" as lang {
    class Override {
      <<@>>
    }
  }
}

Bond ..> Override
Stock ..> Override
Car ..> Override
House ..> Override
Wealth ..> Override
Security ..> Override
BankAccount ..> Override
Property ..> Override
Asset ..> Override

@enduml