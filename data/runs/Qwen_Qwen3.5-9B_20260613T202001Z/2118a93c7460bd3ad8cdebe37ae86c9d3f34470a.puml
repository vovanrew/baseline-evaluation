@startuml
!theme plain

class "lable" {
  int ID
  String info
}

class "borrowHis" {
  Date returnDate
  Boolean flag
}

class "user" {
  String ID
  String pwd
  Date createTime
  byte status
}

class "ticket" {
  String title
  String info
  String adminID
}

class "bookDetList" {
  String ID
  Date borrowDate
  short deadline
  byte status
}

class "bookDetListInfo" {
  byte number
}

class "book" {
  String ISBN
  String name
  String Label
  String logo
  String info
  float price
  String publisher
  String author
  Date publishDate
  short stock
  short Number
}

class "borrower" {
  String firstName
  String lastName
  String IDCardNo
  String email
  String m_phoneNumber
  String creditRating
}

class "admin" {
  String firstName
  String lastName
  String email
  Boolean root
}

class "root" {
}

"lable" ..> "user" : 拥有或管理
"borrowHis" --|> "bookDetList" : 继承
"borrowHis" --o "ticket" : 包含
"bookDetList" --* "bookDetListInfo" : 拥有
"bookDetListInfo" -- "book" : 记录
"ticket" -- "admin" : 管理
"admin" --|> "user" : 继承
"borrower" --|> "user" : 继承
"root" --|> "borrower" : 继承

note right of "lable"
  图书分类,用来控制添加或修改图书时
  控制器选项范围,不与book建立直接联系
end note

@enduml