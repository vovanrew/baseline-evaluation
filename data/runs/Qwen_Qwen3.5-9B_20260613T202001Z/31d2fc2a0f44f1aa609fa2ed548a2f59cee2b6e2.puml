@startuml
!theme plain

class "Pizza" as Pizza {
  <<interface>>
  void prepare();
  void back();
  void cut();
  void box();
}

class "PepperPizza" as PepperPizza {
  <<class>>
}

class "GreakPizza" as GreakPizza {
  <<class>>
}

class "CheesePizza" as CheesePizza {
  <<class>>
}

class "SimpleFactory" as SimpleFactory {
  <<class>>
  Pizza createPizza();
}

class "OrderPizza" as OrderPizza {
  <<class>>
}

class "OrderPizza2" as OrderPizza2 {
  <<class>>
}

class "OrderPizza3" as OrderPizza3 {
  <<class>>
}

Pizza --|> PepperPizza
Pizza --|> GreakPizza
Pizza --|> CheesePizza

SimpleFactory --> PepperPizza
SimpleFactory --> GreakPizza
SimpleFactory --> CheesePizza

SimpleFactory o-- OrderPizza
SimpleFactory o-- OrderPizza2
SimpleFactory o-- OrderPizza3

note right of Pizza
  A
end note

note left of PepperPizza
  C
end note

note left of GreakPizza
  C
end note

note left of CheesePizza
  C
end note

note left of SimpleFactory
  C
end note

note left of OrderPizza
  C
end note

note left of OrderPizza2
  C
end note

note left of OrderPizza3
  C
end note

@enduml