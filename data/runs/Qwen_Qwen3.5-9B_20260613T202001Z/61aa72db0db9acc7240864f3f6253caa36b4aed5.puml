@startuml
!theme plain

package "cz" as cz {
  package "kksffn" as kksffn {
    package "player" as player {
      interface IPlayer {
        +getCoordinatesOfShips()
        +getGuess()
        +getName()
        +isHuman()
        +updateGuesses()
        +updateGuesses()
      }

      class APlayer {
        -coordinatesOfShips : HashMap<ShipName, ArrayList<Integer>>
        -isHuman : boolean
        -name : String
        +getCoordinatesOfShips()
        +getGuess()
        +getName()
        +isHuman()
        +updateGuesses()
        +updateGuesses()
      }

      class AI {
        +AI()
        +getCoordinatesOfShips()
        +getGuess()
        +updateGuesses()
        +updateGuesses()
        -setName()
      }

      class Human {
        +Human()
        +getCoordinatesOfShips()
        +getGuess()
        +setName()
        +setShips()
      }

      interface IStrategy {
        +findCoordinates()
        +updateGuesses()
        +updateGuesses()
      }

      class Strategy {
        -allGuesses : ArrayList<Integer>
        -allHits : ArrayList<Integer>
        -lastHit : int
        -lastHits : ArrayList<Integer>
        -myChances : int
        -myGuess : int
        -numberOfNotRandomMoves : int
        -rand : Random
        -sunkShips : ArrayList<ShipName>
        +findCoordinates()
        +updateGuesses()
        +updateGuesses()
        -addTheRightCells()
        -addToGuesses()
        -alreadyGuessed()
        -doNotGuessFourth()
        -doNotGuessThird()
        -isNotOnBottom()
        -isNotOnTheLeftEdge()
        -isNotOnTheRightEdge()
        -isNotOnTheTop()
        -shootNextToFirstHitAgain()
        -thinkOfWhatNotToGuess()
        -tryNearestCells()
        -tryToSinkCarrier()
        +updateGuesses()
      }
    }

    interface ISetShips {
      +getCoordinatesOfShips()
      +getGuess()
      -setName()
      -setShips()
    }
  }
}

IPlayer <|-- APlayer
APlayer <|-- AI
APlayer <|-- Human
AI o-- IStrategy
APlayer --o ISetShips :sea
AI o-- IStrategy :think

@enduml