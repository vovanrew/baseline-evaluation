@startuml
class "Account" {
  + userdata11
  + admindata11
}

class "User" {
  + name
  + password
  + IDcard
  + getprice()
  + getdate()
  + getnumber()
  + getplace()
  + bookingtecket()
  + changebooking()
  + returnticket()
}

class "Admin" {
  + name
  + password
  + changeticket()
}

class "TicketSystem" {
  + cancel()
  + display()
  + recordticket()
  + recordorder()
  + displayticket()
  + displayorder()
  + update()
  + searchticket()
  + searchorder()
}

class "Order" {
  + username
  + userId
  + bookingtecket
}

class "Ticket" {
  + price
  + date
  + number
  + price
}

"Account" <|-- "User"
"Account" <|-- "Admin"
"User" --> "TicketSystem"
"Admin" --> "TicketSystem"
"TicketSystem" --> "Order"
"TicketSystem" --> "Ticket"

@enduml