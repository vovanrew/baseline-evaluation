@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam packageStyle rectangle
skinparam packageBackgroundColor #F5F5F5
skinparam packageBorderColor #000000
skinparam packageFontColor #000000

package "b" {
  circle "C" as C
  rectangle "CajaDeAhorro" as CajaDeAhorro
  rectangle "suma()" as suma
  circle "b()" as b
}

CajaDeAhorro -- C
CajaDeAhorro -- suma
CajaDeAhorro -- b

CajaDeAhorro {
  rectangle "CajaDeAhorro" as CajaDeAhorro
  rectangle "suma()" as suma
  circle "b()" as b
}

CajaDeAhorro -- C
CajaDeAhorro -- suma
CajaDeAhorro -- b

@enduml