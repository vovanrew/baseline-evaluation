@startuml
!theme plain

class "GUI" as GUI {
  <<C>>
}

interface "IController" as IController {
  <<I>>
  getPlanets()
  addPlanet(Planet)
  updatePlanet(Planet)
  deletePlanetById(int)
  getUFOsByPlanetId(int)
  addUFOToPlanet(UFO, int)
  updateUFO(UFO)
  deleteUFOById(int)
  deleteUFOsByPlanetId(int)
}

class "Controller" as Controller {
  <<C>>
}

interface "IDatabase" as IDatabase {
  <<I>>
  getPlanets()
  savePlanet()
  deltePlanet()
  newPlanet()
}

class "RelationalDatabase" as RelationalDatabase {
  <<C>>
}

GUI --|> IController
Controller --|> IController
Controller ..> IDatabase
IController --|> IDatabase
RelationalDatabase --|> IDatabase

@enduml