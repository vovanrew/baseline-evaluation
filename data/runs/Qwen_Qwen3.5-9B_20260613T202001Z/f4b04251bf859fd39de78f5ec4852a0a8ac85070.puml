}

class "MenuItem" as MI {
  "C"
  eapli.framework.actions.menu
}

HMR ..> MR : itemRenderer
VMR ..> MR : itemRenderer
MR ..> MIR : itemRenderer
MIR ..> MI : itemRenderer
MIR ..> MIR : DEFAULT

@enduml