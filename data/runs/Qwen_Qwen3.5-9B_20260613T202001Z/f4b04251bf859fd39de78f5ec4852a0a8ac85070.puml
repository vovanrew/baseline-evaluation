@startuml
!theme plain

class "HorizontalMenuRenderer" as HMR {
  <<SuppressWarnings>>
  "C"
  eapli.framework.presentation.console.menu
}

class "MenuRenderer" as MR {
  "C"
  eapli.framework.presentation.console.menu
}

class "VerticalMenuRenderer" as VMR {
  <<SuppressWarnings>>
  "C"
  eapli.framework.presentation.console.menu
}

class "MenuItemRenderer" as MIR {
  <<SuppressWarnings>>
  "C"
  eapli.framework.presentation.console.menu
  MenuItemRenderer DEFAULT
