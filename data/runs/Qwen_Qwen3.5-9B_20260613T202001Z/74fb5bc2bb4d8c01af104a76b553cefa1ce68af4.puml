@startuml
class Duck {
  public abstract void display()
  void quack()
  void swim()
  void fly()
}

class WildDuck {
  void display()
}

class PekingDuck {
  void display()
  void fly()
}

class ToyDuck {
  void display()
  void quack()
  void swim()
  void fly()
}

Duck <|-- WildDuck
Duck <|-- PekingDuck
Duck <|-- ToyDuck

note left of Duck
  A
end note

note right of WildDuck
  C
end note

note right of PekingDuck
  C
end note

note right of ToyDuck
  C
end note
@enduml