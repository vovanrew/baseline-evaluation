@startuml
!theme plain

class "Bleu" {
}

class "queue" {
  [Queue]
  - New(int): Queue
  - Delete(Queue*)
  - Enqueue(Queue, uint8_t)
  - Dequeue(Queue): uint8_t
  - Add(Queue, int, const void* data)
  - Pop(Queue, int, void*)
  - Clear(Queue)
  - UsedSize(Queue)
  - AvailableSize(Queue)
}

class "xorshift" {
  [Xorshift]
  - New(int, XorshiftAbstractMethod): Xorshift
  - Delete(Xorshift*)
  - Give(Xorshift, const uint32_t*)
  - Generate(Xorshift): uint32_t
}

class "xorshift_plus" {
  [XorshiftPlus]
  - New(int, XorshiftPlusAbstractMethod): XorshiftPlus
  - Delete(XorshiftPlus*)
  - Give(XorshiftPlus, const uint64_t*)
  - Generate(XorshiftPlus): uint64_t
}

class "xorshift32" {
  [Xorshift32]
  - New(void): Xorshift
}

class "xorshift64" {
  [Xorshift64]
  - New(void): Xorshift
}

class "xorshift96" {
  [Xorshift96]
  - New(void): Xorshift
}

class "xorshift128" {
  [Xorshift128]
  - New(void): Xorshift
}

class "xorshift128Plus" {
  [Xorshift128Plus]
  - New(void): XorshiftPlus
}

class "heap" {
  [Heap]
  - New(int): void*
  - Delete(void**)
}

class "HeapUsage" {
  [HeapUsage]
  - Add(int)
  - Subtract(int)
  - WarnIfNeeded(void)
  - Get(void): int
  - Clear(void)
  - SetWarning(int, WarningDelegate)
}

class "io_data" {
  [IoData]
  - Write(ioAddress, IoData)
  - Add(ioAddress, IoData)
  - Remove(ioAddress, IoData)
  - Read(ioAddress): IoData
}

class "list" {
  [List]
  - New(const void*): List
  - Delete(List*)
  - Count(List): int
  - GetItem(List, int): void*
  - SetItem(ListNode, const void*)
  - Add(List, const void*)
  - Clear(List)
  - Find(List, const void*): void*
  - Pop(List, int): void*
  - SetItemComparer(List, ComparerInterface)
  - SetItemDeleter(List, DeleterInterface)
}

class "ListNode" {
  [ListNode]
  - New(const void*): ListNode
  - Delete(ListNode*)
  - GetItem(ListNode): void*
  - SetItem(ListNode, const void*)
  - GetNext(ListNode): ListNode
  - SetNext(ListNode, ListNode)
}

class "Comparer" {
  [Comparer]
  - Compare(const void*, const void*): int
}

class "Deleter" {
  [Deleter]
  - Delete(void**)
}

class "rng" {
  [Xorshift]
  [XorshiftPlus]
}

