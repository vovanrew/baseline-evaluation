@startuml
autonumber
left to right direction
skinparam sequenceMessageSize 100

participant "s:ObjectStructure" as s
participant "a:CroncreteElementA" as a
participant "b:CroncreteElementB" as b
participant "v1:ConcreteVisitor1" as v1

activate s
s -> a : accept(v1)
activate a
a -> v1 : visit(this)
activate v1
v1 -> a : operationA()
deactivate v1
a -> a : <<return>>
deactivate a
a -> s : <<return>>
deactivate s

activate s
s -> b : accept(v1)
activate b
b -> v1 : visit(this)
activate v1
v1 -> b : do nothing
deactivate v1
b -> s : <<return>>
deactivate b
deactivate s

@enduml