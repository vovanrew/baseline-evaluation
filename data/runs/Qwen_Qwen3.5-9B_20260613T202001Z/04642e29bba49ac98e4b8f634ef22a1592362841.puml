@startuml
autonumber
left to right direction
skinparam sequenceMessageAlign center

actor "User" as User
participant "A" as A
participant "B" as B
participant "C" as C

User -> A : DoWork
activate A
A -> B : «createRequest»
activate B
B -> C : DoWork
activate C
C -> B : WorkDone
deactivate C
B -> A : RequestCreted
deactivate B
A -> User : Done
deactivate A

@enduml