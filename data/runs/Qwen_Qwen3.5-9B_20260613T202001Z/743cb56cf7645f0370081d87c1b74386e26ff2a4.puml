@startuml
left to right direction
actor "teacher" as teacher
participant "操作界面" as ui
participant "studentcourse" as sc
participant "student" as st
participant "experiment" as exp
participant "experimentscore" as es
participant "scoreitem" as si

activate teacher
activate ui
activate sc
activate st
activate exp
activate es
activate si

teacher -> ui : 1 选择学期
ui -> sc : 2 查询哪些学生选了老师的课
sc -> st : 3 请求学生列表
st --> sc : 4 返回数据
deactivate st
deactivate sc

ui -> exp : 5 查询这些课程的实验
exp -> es : 6 查询实验得分
es -> si : 7 查询得分
si --> es : 8 返回
deactivate si
es --> exp : 9 返回得分
deactivate es
exp --> ui : 10 返回得分列表
deactivate exp
ui --> teacher : 11 显示数据
deactivate ui
deactivate teacher

@enduml