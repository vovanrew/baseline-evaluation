@startuml
title クラス図_6月UML例題

class ItemManagerUser {
  [C] ItemManagerUser
  + void main(String[]:args)
}

class ItemManager {
  [C] ItemManager
  - List<Item> itemList
  + void regist(Item:item)
  + void displayAll()
  + void serachDisplay()
}

class Item {
  [C] Item
  - String name
  - int price
  + Item(String:name, int:price)
  ---
  + String getName()
  + int getPrice()
  ---
  + void setName(String: name)
  + void setPrice(int: price)
}

ItemManagerUser --|> ItemManager
ItemManager o-- Item

@enduml