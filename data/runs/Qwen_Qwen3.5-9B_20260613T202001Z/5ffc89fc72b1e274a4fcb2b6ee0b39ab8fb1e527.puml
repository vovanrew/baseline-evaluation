@startuml
!define CLASS_NAME "C"
!define CLASS_CONTENTS "o"
!define CLASS_METHODS "o"

class Account {
  o AccountID : int
  o FirstName : string
  o LastName : string
  o EmailAddressUsername : string
  o password : string
  o AccountCreatedDatetime : datetime
  o isArchived : boolean
  createAccount()
  deleteAccount()
  editAccount()
  forgotPassword()
}

class Recipe {
  o recipeID : int
  o recipeName : string
  o servings : int
  o prepTime : time
  o cookTime : time
  o totalTime : time
  o isFavorite : boolean
  createRecipe()
  editRecipe()
  deleteRecipe()
  saveRecipe()
}

class RecipeImage {
  o RecipeImageID : int
  o RecipeImagePath : int
  o isArchived : boolean
  AddPhoto()
  DeletePhoto()
}

class Ingredient {
  o IngredientID : int
  o IngredientText : string
  o IngredientAmount : int
  o isArchived : boolean
  AddIngredient()
  EditIngredient()
  DeleteIngredient()
}

class Instructions {
  getSteps()
}

class Step {
  o StepID : int
  o InstructionStepText : string
  o StepNumberOrder : int
  o isArchived : boolean
  AddStep()
  EditStep()
  RemoveStep()
}

class Measurement {
  o MeasurementID : int
  o MeasurementText : string
  getMeasurement()
}

Account "0..*" --|> Recipe "1"
Recipe "1" --o RecipeImage "1"
Recipe "1" *-- Ingredient "*"
Recipe "1" *-- Instructions "1"
Ingredient "1" *-- Measurement "1"
Instructions "1" *-- Step "*"

@enduml