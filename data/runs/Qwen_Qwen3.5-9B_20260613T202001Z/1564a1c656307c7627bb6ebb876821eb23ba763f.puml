@startuml
left to right direction
actor Maker
actor Solver

class Puzzle {
  grid dimension
  complexity
}

class RowsColumns {
  priorities
  constraints
}

class Solutions {
  general
  row/column
}

class Pixels {
  black
  white
}

Maker "1" -- "design *" Puzzle
Solver "1" -- "solve *" Puzzle

Puzzle "1" --* "contains" RowsColumns
Puzzle "1" -- "1" Solutions
RowsColumns "1" --* "contains" Pixels
RowsColumns "*" -- "*" Solutions

@enduml