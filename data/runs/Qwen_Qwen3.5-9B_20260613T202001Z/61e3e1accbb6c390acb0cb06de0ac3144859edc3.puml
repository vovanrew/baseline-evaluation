@startuml
left to right direction
package "Application" as Application {
  [Scanner input]
  [main()]
  [readName()]
  [readAuthor()]
  [makeJS()]
  [makeCSS()]
  [craftHTML()]
}

package "FileIO" as FileIO {
  [File inputFile]
  [setInputFile()]
  [closeInput()]
  [readFromFile()]
  [writeToFile()]
}

package "DirectoryIO" as DirectoryIO {
  [String parentDir]
  [DirectoryIO()]
  [setParentDir()]
  [mkDir()]
  [writeToFile()]
}

Application ..> FileIO : extends
FileIO ..> DirectoryIO : extends

@enduml