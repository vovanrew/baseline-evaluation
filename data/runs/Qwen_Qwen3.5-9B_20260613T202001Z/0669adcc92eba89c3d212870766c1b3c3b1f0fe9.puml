@startuml
left to right direction
skinparam packageStyle rectangle
skinparam class {
  BackgroundColor White
  ArrowColor Black
  BorderColor Black
  FontColor Black
  FontSize 12
}

' Define the interface
interface IBeverage {
  string Description
  void GetDescription()
  double Cost()
}

' Define the concrete classes
class HouseBlend {
  string Description
  void GetDescription()
  double Cost()
}

class DarkRoast {
  string Description
  void GetDescription()
  double Cost()
}

class Espresso {
  string Description
  void GetDescription()
  double Cost()
}

' Define the decorator class
class CondimentDecorator {
  IBeverage _beverage
  string Description
  string GetDescription()
  double Cost()
}

' Define the concrete decorator classes
class Milk {
  Milk(IBeverage beverage)
  string Description
  void GetDescription()
  double Cost()
}

class Mocha {
  Mocha(IBeverage beverage)
  string Description
  void GetDescription()
  double Cost()
}

class Whip {
  Whip(IBeverage beverage)
  string Description
  void GetDescription()
  double Cost()
}

' Relationships
HouseBlend --|> IBeverage
DarkRoast --|> IBeverage
Espresso --|> IBeverage

CondimentDecorator --|> IBeverage
Milk --|> CondimentDecorator
Mocha --|> CondimentDecorator
Whip --|> CondimentDecorator

' Notes
note right of IBeverage
  全てのオブジェクトはこの抽象インタフェースを起点に操作する
  特定の具象コンポーネントに対する操作がしたい時は設計を見直す必要がある。
  例えば、HouseBlendのみ割引したい時とか、
  装飾により型の情報は破壊されているので。。
end note

note right of CondimentDecorator
  IBeverageを実装する理由は
  スーパークラスの型を取得するため。
  これを継承するクラスはBeverageを装飾することができる
end note

@enduml