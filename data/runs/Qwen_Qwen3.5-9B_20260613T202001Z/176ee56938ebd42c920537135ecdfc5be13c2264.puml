@startuml
left to right direction
actor "Пользователь" as Пользователь
participant "СиловойМодуль" as СиловойМодуль
participant "РелеПитания" as РелеПитания
participant "МодульСетевогоУправления" as МодульСетевогоУправления

Pользователь -> СиловойМодуль : Нажатие кнопки
СиловойМодуль --> Пользователь : Светодиод на кнопке моргает
СиловойМодуль --> РелеПитания : Включение
СиловойМодуль --> СиловойМодуль : Включение
РелеПитания --> СиловойМодуль : Включение

СиловойМодуль --> МодульСетевогоУправления : {"action": "found_module", "meta":{...}}
МодульСетевогоУправления --> СиловойМодуль : {"status": "ok"}
СиловойМодуль --> Пользователь : Светодиод на кнопке включён
СиловойМодуль --> СиловойМодуль : Включён

СиловойМодуль --> МодульСетевогоУправления : {"action": "shutdown"}
МодульСетевогоУправления --> СиловойМодуль : {"timeout": N}
СиловойМодуль --> СиловойМодуль : Выключение

СиловойМодуль --> РелеПитания : Выключение
СиловойМодуль --> СиловойМодуль : Выключен

СиловойМодуль --> Пользователь : Светодиод на кнопке выключен

note right of СиловойМодуль
Модули производят начальную настройку
end note

note right of СиловойМодуль
Нормальная работа робота
end note

note right of СиловойМодуль
Модули производят процедуры по безопасному выключению
end note

note right of СиловойМодуль
Проходит N секунд
end note

@enduml