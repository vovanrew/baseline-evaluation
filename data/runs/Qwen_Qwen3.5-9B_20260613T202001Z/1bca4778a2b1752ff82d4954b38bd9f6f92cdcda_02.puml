@startuml
title Ski Championships Management
last updated 15/10/2020

class "Event" {
  [C]
  + id: int
  + location: string
  + startDate: Date
  + endDate: Date
  + create(): Event
  + update()
  + delete(): bool
  + list(): Event[]
  + export(): bool
  + import(): bool
}

class "Result" {
  [C]
  + time: Time
  + create(): Result
  + delete(): bool
  + list(): Result[]
}

class "Run" {
  [C]
  + number: int
  + time: Time
  + Getters and setters
  + getId()
  + Other methods
  + create(): Run
  + delete(): bool
}

class "Competitor" {
  [C]
  + id: int
  + lastName: string
  + firstName: string
  + birthDate: Date
  + bibNumber: int
  + email: string
  + photo: resource
  + create(): Competitor
  + update()
  + delete(): bool
  + list(): Competitor[]
}

class "Metadata" {
  [A]
  + id: int
  + name: string
  + description: string
  + create()
  + update()
  + delete(): bool
  + list(): Metadata
}

class "Category" {
  [C]
}

class "Profile" {
  [C]
}

"Event" o-- "Competitor" : "takes part"
"Event" o-- "Run" : "runs"
"Result" o-- "Competitor" : "obtains"
"Competitor" o-- "Category" : "belongs to"
"Competitor" o-- "Profile" : "has"
"Category" <|-- "Metadata"
"Profile" <|-- "Metadata"

@enduml