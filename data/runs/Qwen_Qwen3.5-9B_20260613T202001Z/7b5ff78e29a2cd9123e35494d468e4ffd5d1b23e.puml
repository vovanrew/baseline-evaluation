@startuml
' UML diagram for app-related entities

class app_translation {
    label string
    description longText
    privacyPolicyExtensions longText
    createdAt createdAt
    updatedAt updatedAt
    appIdId foreignKey
    languageId foreignKey
}

class app_action_button_translation {
    label string
    createdAt createdAt
    updatedAt updatedAt
    appActionButtonId foreignKey
    languageId foreignKey
}

class app_action_button {
    id id
    entity string
    view string
    url string
    action string
    openNewTab bool
    label translated
    appIdId foreignKey
    createdAt createdAt
    updatedAt updatedAt
    translated json
}

class app_template {
    id id
    template longText
    path string
    active bool
    appIdId foreignKey
    createdAt createdAt
    updatedAt updatedAt
}

class app {
    id id
    name string
    path string
    author string
    copyright string
    license string
    active bool
    configurable bool
    privacy string
    version string
    iconRaw blob
    icon string
    appSecret string
    modules list
    cookies list
    label translated
    description translated
    privacyPolicyExtensions translated
    integrationId foreignKey
    aclRoleId foreignKey
    createdAt createdAt
    updatedAt updatedAt
    translated json
}

class language {
    id id
    name string
    createdAt createdAt
    updatedAt updatedAt
}

class integration {
    id id
    name string
    createdAt createdAt
    updatedAt updatedAt
}

class acl_role {
    id id
    name string
    createdAt createdAt
    updatedAt updatedAt
}

class custom_field_set {
    id id
    name string
    createdAt createdAt
    updatedAt updatedAt
}

class webhook {
    id id
    name string
    createdAt createdAt
    updatedAt updatedAt
}

' Relationships
app_translation --> language
app_action_button_translation --> language
app_action_button_translation --> app_action_button
app_action_button --> app
app_template --> app
app --> integration
app --> acl_role
app --> custom_field_set
app --> webhook

' Styling
class app_translation {
    <<Translations>>
}

class app_action_button_translation {
    <<Translations>>
}

class language {
    <<Translations>>
}

class integration {
    <<Translations>>
}

class acl_role {
    <<Translations>>
}

class custom_field_set {
    <<Translations>>
}

class webhook {
    <<Translations>>
}

@enduml