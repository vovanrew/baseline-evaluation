@startuml
class "Klasse" as A {
  navn: String
  beskrivelse: String
  terning: int
}

class "Trollmann" as C {
  trylleformler: ArrayList<String>
}

class "Barbar" as C {
  raseriAnfall: int
}

class "Karakter" as C {
  navn: String
  klasse : Klasse
  level: int
}

C "Trollmann" --|> A "Klasse"
C "Barbar" --|> A "Klasse"
C "Karakter" --|> A "Klasse"

note right of A
  A
end note

note left of C
  C
end note

note right of C
  C
end note

@enduml