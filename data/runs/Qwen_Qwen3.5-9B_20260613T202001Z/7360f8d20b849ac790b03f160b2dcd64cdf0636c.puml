@startuml
!theme plain

class "Category" as Category {
  [String name]
  +void setName(String name)
  +String getName()
}

class "Movie" as Movie {
  [Long code]
  [String name]
  [String description]
  [String length]
  [String imageUrl]
  +set()
  +get()
}

class "User" as User {
  [String username]
  [String password]
  [String name]
  [String email]
  [Boolean active]
  [Boolean admin]
  +set()
  +get()
}

Category --|> Movie : 1 *
@enduml