@startuml
interface Printer {
  + print(Document)
}

interface Scanner {
  + scan(Document)
}

class SimplePrinter {
  + print(Document)
}

class SimplePrinterScanner {
  + print(Document)
  + scan(Document)
}

SimplePrinter ..> Printer
SimplePrinterScanner ..> Printer
SimplePrinterScanner ..> Scanner

note left of SimplePrinterScanner
  "This class implements both Printer and Scanner interfaces"
end note

@enduml