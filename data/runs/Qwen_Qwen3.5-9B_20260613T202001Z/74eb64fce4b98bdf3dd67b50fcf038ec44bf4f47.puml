@startuml
!theme plain

package "com" as com {
  package "qxcode" as qxcode {
    class Car {
      -gas : int
      -gasMax : int
      -km : int
      -pass : int
      -passMax : int
      +Car()
      +drive(km : int)
      +enter()
      +fuel(gas : int)
      +leave()
      +toString() : String
    }
  }
}

@enduml