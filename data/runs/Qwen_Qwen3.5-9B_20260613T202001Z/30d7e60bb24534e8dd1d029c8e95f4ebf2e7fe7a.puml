@startuml
class ASTNode {
  getLine(): int
  getColumn(): int
}

class Type {
}

class IntType {
}

class RealType {
}

class CharType {
}

class ArrayType {
  size: int
  type: Type
}

class VoidType {
}

class FunctionType {
  params: List<VarDef>
  returnType: Type
}

class StructType {
  fields: List<StructField>
}

class StructField {
  name: String
  type: Type
}

Type --|> ASTNode
IntType ..|> Type
RealType ..|> Type
CharType ..|> Type
ArrayType ..|> Type
VoidType ..|> Type
FunctionType ..|> Type
StructType ..|> Type
StructType o-- StructField
StructType --|> ASTNode
@enduml