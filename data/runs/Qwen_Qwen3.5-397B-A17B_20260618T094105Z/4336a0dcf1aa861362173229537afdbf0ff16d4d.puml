@startuml
actor Member
participant ":TicketDetailPage" as TicketDetailPage
participant ":TicketDetailContainer" as TicketDetailContainer
participant "AttendanceService\n(Frontend)" as AttendanceFrontEnd
participant Router
participant :AttendanceHTTPTransport as HTTPTransport
participant :AttendanceEndpoint as Endpoint
participant :RequesterService as RequesterService
database :"AttendanceCommand" as CommandDB
queue :"AttendanceQuery" as QueryQueue


Member ->> TicketDetailPage 	: Click \"Yes\" Button 
activate TicketDetailPage 

alt Data Valid? == true then
    
    activate TicketDetailPage 
    
	TicketDetailPage->+TicketDetailContainer   : handleConfirmation(input)  
	
	loop for each input in inputs do
		
        alt Input type check box ?==true then
            
            loop while checkbox.checked != null
                
                if Checkbox checked = false then
                    
                    break
                        
                end if
                
                
				if ClassId not empty && Payload has data then
				
					TicketDetailContainer-->-Router     : confirmAttendence(classid,payload)   
					
					    
					    opt Route exists to endpoint class_id/attendence/confimation then
					        route("PATCH", "/v2/class/{class_id}/attendance/confirmation") --> + Confirmation(AttendanceService,[ServerOption])
						        
						    else path doesnot exist or invalid request method used
						    	return error message ("405 Method Not Allowed ")
					    	end if
					     		
							     			
							   	 	   	  		      
