@startuml
skinparam sequenceMessageAlign center
autonumber "<b>" 1

box "web" #LightBlue2
participant web as "" 
end box 

box "考试系统" #LightGreen3
participant examSystem as ""  
end box  

box "Redis(缓存数据库)" #Pink4
database redisDB as ""   
end box   

box "MQ(消息队列)" #Yellow5
queue mqQueue as ""    
end queue    

