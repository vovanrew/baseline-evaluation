                    alt if(redis.get("examInfo")==null){                    
                        break ;                 
                     }else{//消费延时的redis中的信\\\n息并写入mysql数据库中};                     
                         <-ExamSys:"从缓存在数库据取出当前场次的卷试题";                        
                            return->Web :"返回生当考前次场的试试题文到本览地浏器localStorage存储中;"                         
