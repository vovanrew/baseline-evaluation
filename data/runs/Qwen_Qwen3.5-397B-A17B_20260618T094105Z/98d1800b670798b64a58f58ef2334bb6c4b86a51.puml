@startuml
actor Player
participant "Game" as Game
participant "Screen" as Screen
participant "Line" as Line
participant "Figure" as Figure

Player -> Game : Reset
activate Game
    Game -> Screen : Reset
        activate Screen
            Screen -> Line : Reset
                activate Line
                    deactivate Line
                return 
            deactivate Screen
        create participant Figure
        Game -> Figure : Create
deactivate Game
return 

@enduml