@startuml
skinparam classAttributeIconSize 0

package "class Flyweight(享元模式)" {
    [FlyweightFactory] <<C>> #lightgreen
        -mMap : HashMap 
        +getFlyweight() 
    
    note right of FlyweightFactory::mMap\n#paleyellow;[<b>享元工厂</b>] </note>; 

    [ConcreteFlyweight] <<C>> #lightgreen  
       -intrinsicState:String   
      +dosomething ()  

     arrow up ConcreteFlyweight --|> FlyWeight
    
   rectangle "<u>Flyweight<<abstract C></u>"{ }    
         <font color=black><i>+ dosomethings()</i></font >


}



@enduml