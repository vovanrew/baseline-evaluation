@startuml
skinparam classAttributeIconSize 0

class User {
    String userName
    String password
} <<C>>

class Tenant {
    String name
} <<C>>

class CloudCredential {
    String userName
    String secret
} <<C>>

class Resource {
    String id
    String name
} <<A>>

class Image {
    String id
    String name
} <<C>>

class HardwareOffer { } <<C>>

class OperatingSystem { } <<C>>

enum LocationScope {
    REGION, ZONe, HOST
} <<E>>

note "Location" as locNote #LightGray;line:black;text:green;bold:false;fontName:"Arial";fontSize:14<<C>>\nString id\nString name\nboolean isAssignable</> end note

note "GeoLocation" as geoLocNote #LightGray;line:black;text:green;bold:false;fontName:"Arial";fontSize:14<<C>> </>end note


@enduml