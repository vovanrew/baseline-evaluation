@startuml
actor SalesClerk
participant ChangeOrderToBeingDeliveredUI as UI
control ChangeOrderToBeingDeliveredController as Controller
entity "ChangeAllToBeingDeliveredService" as Service1 #90EEFF 
database OrderRepository as Repo
boundary "ChangeToBeingDeliveredService\n(External System)" as ExternalSystem

== Update Dispatched Orders ==
SalesClerk -> UI : 1 Update the status of dispatched orders to \"Being delivered\" for customer delivery.\n
activate UI
    UI ->> Controller : 2 orderDispatched()
        activate Controller
            Controller --> Service1 : 3 orderDispatched()\n
                activate Service1
                    Service1 ->> Repo : 4 orderDispatched()\n
                        activate Repo
                            Repo -->> Service1 : \n5 ordersDispatched
                        deactivate Repo
                deactivate Service1
            return "\n6 Shows all the orders that are dispatched."
        deactivate Controller
    
loop Select an Order
    note over SalesClerk, UI: User selects one specific order from list
end loop

note right of SalesClerk: **7 Asks**\nto choose one of the orders
return "**8 Selects**\nthe order he wants to change status"\n

== Process Status Change Request ==
group Processing Selected Order
    participant ":SelectedOrderItem" as Item hidden
    UI -x Controller : 9 <b><u>change</u>To<u>Being</u></b>\n<b><u>Deliver</u>(order)</b>
    
    group Internal Logic Flow
        
        alt Valid Selection?
            
            else Invalid Input
            
            end if
            
            rect rgb(240, 248, 255)
                
                opt Check Business Rules
                
                    
                        
                            
                                item = new("NewlyCreatedObject")#LightGreen
                        
                                
                                    create "<font color=red>**Critical Failure Point:**\nDatabase Connection Lost"</font> as DBFail
                    
                    

                end opt
                
                hline black
                
                box "Core Domain Layer" LightGray/Black
                    control CoreLogicHandler
                    entity DataValidator
                endbox
                
                controller -> corelogichandler : Validate(orderID)\n<color:red>[Timeout Exception]</color>
                
                par Parallel Execution Block A & B
                    service1 -> external_system : SyncDataPush(payload)\n[Latency > 50ms]
                and
                    repo <- data_validator : QueryResult(status='PENDING')
                endpar
                
                destroy dbfail
                
            endrect
            
        
    end group
    
    Control <-- ui : Return Result Object {id: null}
    
    Note left of salesclerk:<i>User sees error message:</i>"Operation Failed due to system timeout."\nThe transaction was rolled back automatically by framework.
    

@enduml