@startuml
skinparam classAttributeIconSize 0

class "Starfsmaður" {
    nafn string [1]
    kennitala
    heimilisfang
    heimasími
    gsm sími
    netfang
}

interface Bókari {
    recurringVoyage()
    addVoyage()
    addDestination()
    staffVoyage()
}

entity Vinnuferð {
    Flugstjóri
    aðalflugþjórn
    Flugferð út
    Flugferð inn
    áfangastaður
    dags og tími brottfarar frá Íslandi
    dags og tíma brottfarar til íslansd
}

database Áfangastödur {
    land
    flugvöllur
    flugtími
    fjarlægð frá Íslandi
    nafn tengiliðar
    neyðarsimanúmer tengiliða
}

