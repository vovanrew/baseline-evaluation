                          interface AbstractFactory<<A>>{
                              Shape getShape();
                               Color getColor ();
                               
                                }
                                
                                 class FactoryProducer extends AbstractFactory{
                                     AbstractFactory getFactory();
                                     
                                       }
                                       
                                         class ShapeFactory extends AbstractFactory{
                                             Shape getShape();
                                             
                                               }
                                               
                                                 class ColorFactory extends AbstractFactory{
