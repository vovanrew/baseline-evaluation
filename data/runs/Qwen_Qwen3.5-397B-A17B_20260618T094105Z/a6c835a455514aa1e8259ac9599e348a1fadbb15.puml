@startuml
title End Screen Action Sequences

actor User as user

package "Views" {
    participant Game
    participant End
    participant HighScore
    participant Start
}

participant Navigation #LightBlue [User Interface Control]

rectangle BackEnd #Purple {
    package Settings {}
    
    rectangle JoggleCube
    
    partition Scores {
        component CubeScores
        
        queue ScoreQueue <<queue>> 
        entity BlockEntity <<entity>> 
        
        note right of BlockEntity : Stores block data\nfor scoring system
    }
}


