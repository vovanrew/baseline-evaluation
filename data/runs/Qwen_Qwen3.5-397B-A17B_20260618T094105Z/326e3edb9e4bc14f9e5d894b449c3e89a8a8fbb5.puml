@startuml
title 基于GitHub的实验管理平台--学生列表用例的顺序图

actor users as u1
participant "首页" as h1
participant "登录" as l1
participant "选择登录身份" as s1

u1 ->> h1 : 查看所有学生列表

alt [如果users是老师]
    h1 --> l1 
    l1 --> s1 
    
else [如果users是students]
    h1 --> l1  
    l1 --> s1
    
end


note over u2,h3,s4 #f0f8ff#ffffff\n</font>\n<color=black><b></b></color>: </p>



@enduml