@startuml
actor Admin
participant ":DivisionPage" as DivisionPage
participant ":DivisionTableContainer" as TableContainer
participant ":DivisionTable" as Table
participant " :DivisionService\n(Frontend)" as FrontEndSvc
participant ":Router" as Router
participant ":DivisionHTTPTransport" as HTTPTransp
participant ":DivisionEndpoint" as Endpoint
participant ":DivisionService" as BackendSvc
database ":DivisionCommand" as CommandDB
database ":DivisionQuery" as QueryDB


Admin -> DivisionPage: Open \"Manage Division\" Page
activate DivisionPage
    DivisionPage->TableContainer: Render \"Division Table\" Container 
        activate TableContainer    
            TableContainer->Table:  Render \"Division Table\"\n        
                activate Table            
                    return rendered                
                deactivate Table                        
            return rendered                    
        deactivate TableContainer                            
return rendered                                
deactivate DivisionPage                                    



note over Admin #lightgreen:green note on left\nto be continued</font> end note 

== Marking Divisions ==

Admin -> DivisionPage:Mark \"Division\"  
activate DivisionPage   
		DivisionPage->TableContainer:Mark \"Division\"     
			activate TableContainer      
				TableContainer->Table:Mark \"Division\"       
					return marked               
				deactivate TableContainer           
			return marked                   
		deactivate DivisionPage                       
return marked                           




== Deleting Selected Items ==

Admin -> DivisionPage:Click \"Delete Selected\" Button  

alt [Cancel Delete]
   DivisionPage-->FrontEndSvc:showDeleteConfirmation(item) \nasdadasdasdsad
    
else
   
    	FrontEndSvc --> DivisionPage:Close Dialog
     
     	
      	loop ["for each uuid"]
      		QueryDB <-#red:red line to self <b>Bold text </i></u>:italics font color=Blue size=18
      			CommandDb<-<color:#FF0000><size:24>"Hello"</size></color>-CommandDb
        
        	end loop
      
         
  
          
           else
            
              endif
                
               while( data available? ) is yes then
                  Read Data
                  
                 elseif(no more data at position x = -567; y=-39;)no
                   stop
                 
             endwhile()
             
              
endif 


@enduml