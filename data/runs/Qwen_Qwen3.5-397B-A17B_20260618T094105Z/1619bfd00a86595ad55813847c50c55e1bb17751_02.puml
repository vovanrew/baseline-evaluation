@startuml
skinparam classAttributeIconSize 0

class thread_base {
}

class socket_thread {
}

class transport_socket_thread {
    + bus : LocalBusInterface
    + poller : Poller
    
    -transport_socket_thread() 
    ~-~transport_socket_thread() 
    
    init() override
    work() override
    add_socket() override
    remove_socket() override
    read_ready() override
    configure_ieee1905_transport_interfaces()
    
    broker_subscribe()
    broker_connect()
    send_cmdu_to_broker()
    
    #broker_init()
    #broker_send()
    handle_cmd_message_broker()
}


thread_base <|--socket_thread
socket_thread<| --transport_socket_thread 

LocalBusInterface *-- "bus" transport_socket_thread  
Poller*-- "poller": transport_socket_thread 


@enduml