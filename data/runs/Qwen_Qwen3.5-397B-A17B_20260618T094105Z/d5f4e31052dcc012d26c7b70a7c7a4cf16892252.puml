@startuml
skinparam classAttributeIconSize 0
package "javafx" {
    [App] <<C>> {
        start()
        main()
    }
}

[InventoryController] <<C>> {
    ObservableList inventoryList
}

Item --|> InventoryController : extends
FileUtil --|> InventoryController : implements

class Item <<C>> {
    String name
    String serialNumber
    BigDecimal price
    
    get()
    set()
    toString()
}

interface FileLoader <<I>> {
    readFromTXT()
    readFromHTML()
    readFromJSON()
}

interface FileSaver <<I>> {
    writeToTxt()
    writeTtoHTML()
    writeToJSON()
}

abstract class FileUtils <<A>> {
    +readToText(): void
    #writeToFile(String): boolean
}

note right of App::main\n-- This method initializes the application.\nIt sets up UI components and loads data from files using FileReader or FileWriter classes depending on user input parameters passed via command line arguments." as N1

N1 ..> App :: * 

@enduml