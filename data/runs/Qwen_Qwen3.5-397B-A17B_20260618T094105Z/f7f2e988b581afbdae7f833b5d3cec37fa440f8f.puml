@startuml
skinparam handwritten false
title 登陆流程图

actor User #09C7E8 
participant Client #3498DB  
database OpenLDAP #2ecc71   
entity ActiveDirectory #f6ddcc 

User ->>Client : <b><font color=black size="5">1</color></b>\n请求登陆服务器(邮箱，密码)
activate Client
    Client->OpenLDAP:<b><font color=black size="5">2</color></b>\n验证用户\n    
        activate OpenLDAP        
            openldap-->ActiveDirectory:\n<b><font color=black size="5">3</color></b>\n验证用户            
                Activate activedirectory                
                    active directory -->openLdap :\n<--\n<b><font color=black size="5">4</color></b>\n返回验证结果                    
                        DeActivate Activedirectory                        
                            deactivate openLdap                            
                                client <- -client: \n<-\n<b><font color=black size="5">5</color></b>\n返回组信息 , sudo信息等                                
                                    user<- -client: \n<-\n<b><font color=black size="5">6</color></b>\n用户登录 Client                                    
                                        deactiveate client                                        
                                            note top of this "Please use '!option handwritten true' to enable handwritten"                                            
@enduml