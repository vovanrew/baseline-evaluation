@startuml
actor User
participant Frontend
participant API
database Database

== Log in with token ==
User -> Frontend : Request token
alt [Token found]
    Frontend -> API : Validate token
    activate API
        API -> Database : Find token
        activate Database
            Database --> API : Return matching user
        deactivate Database
        
        alt 
            note right of API: Token not in database\nReturn error
            
                return "error"
            
        
        else 
        
            API --> Frontend : Open main page
    
    end if 

else 
    
    



API -X>Frontend  :Open loginpage


    
    

deactivate API




endif 


