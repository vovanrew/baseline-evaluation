@startuml
skinparam rectangle {
    BackgroundColor<<Enumerated_Data_Type>> #F0F0F0
}

rectangle "«Enumerated_Data_Type»\nE_LCD_Config_Font" <<Enumerated_Data_Type>> as E1 {
  note right of top : Allows to define a data representing\na font size on LCD.
  
  state "" as s1
  
  [LCD_CONFIG_FONT_5x8] --|> s1
  [LCD_CONFIG_FONT_5x10] --|> s1
}

circle eIcon <<icon>> 
note left of eIcon::top-left-corner: <b>E</b>\ncolor:#FF9966;size=24px;fontStyle:bold;lineThickness=3;colorLine:black;background:white;border:none;marginTop=-7px;marginLeft=-7px;width=auto;height=auto;textAlign=center


@enduml