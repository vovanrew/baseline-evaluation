@startuml
skinparam classAttributeIconSize 0

class Dummy {
    - private
    # protected
    ~ pkg method()
    + public()
}

interface User <<I>> {
    createAccount(AccountType)
    login()
    logout()
}

class Admin <<C>> {
    createService()
    removeAccount()
    setHourlyRate()
    setForm(Service.type, customerInfo)
}

class Employee <<C>> {
    selectService()
    processServiceRequest(): boolean
    notifyCustomer()
}

class Customer <<C>> {
    searchBranch()
    getForm(type): Form.fill()
    submitForm()
    rateBranch()
}

abstract class RentalForm <<A>> {
    pickupTime
    returnTime
    licenseType
}

class carRentalForm <<C>> {
    carType
}

class truckRentalForm <<C>> {
    usageArea
}

User <|-- Admin : extends
Admin --|> CarRentableSystemInterface : implements
Employee ..> ServiceCatalogueManager : uses
CarRentableSystemInterface --> BranchLocatorFactory : creates
carRentalForm .up. rentalTruckForm : alternative to
truckRentalForm "1" *-- "*" BoxPackingCalculator : contains
BoxPackingAlgorithm <-- MovingCostEstimator : calculates cost for
MovingQuoteGenerator o--> PaymentProcessor : processes payment via
PaymentGateway <-down- CreditCardValidator : validates card through
CreditScoreChecker -> InsuranceProvider : checks coverage from
InsurancePolicyIssuer up-> DamageWaiverOfferer : offers waiver by
DamageAssessmentTool left.. right VehicleConditionInspector : inspects condition using
VehicleInventoryTracker down.. InventoryManagementModule : tracks inventory in
FleetMaintenanceScheduler <-> MaintenanceRecordKeeper : schedules maintenance based on records kept by
FuelConsumptionMonitor monitors fuel consumption of vehicles managed under FleetOperationsDirector who oversees all operational aspects including those handled separately but interconnected like HumanResourcesDepartment managing staff involved across various functions such as SalesTeam promoting services offered while MarketingStrategist develops campaigns targeting potential customers identified initially during LeadGenerationPhase followed later ConversionOptimizationStage ensuring maximum ROI achieved ultimately leading towards BusinessGrowthObjective aligned perfectly well within overall CorporateVisionStatement defined clearly at top level management hierarchy where CEO sets strategic direction guiding entire organization forward together harmoniously achieving common goals efficiently effectively sustainably responsibly ethically transparently accountably collaboratively innovatively creatively adaptively resiliently flexibly agile responsively proactively reactively dynamically statically predictively analytically synthetically holistically systemically organically mechanically electronically digitally virtually physically materially immaterial conceptually abstract concretely theoretically practically empirically logically illogically rationally irrationally emotionally unemotionally subjectively objectively relatively absolutely locally globally universally particularly specifically generally typically unusually exceptionally normally abnormally regularly irregular frequently infrequently occasionally seldom never always sometimes often rarely ever yet still already just now soon late early timely punctual delayed postponed cancelled confirmed approved rejected accepted declined ignored overlooked noticed observed seen heard felt touched tasted smelled experienced lived died born created destroyed formed shaped molded crafted designed engineered constructed built assembled installed configured customized personalized tailored fitted adjusted tuned optimized