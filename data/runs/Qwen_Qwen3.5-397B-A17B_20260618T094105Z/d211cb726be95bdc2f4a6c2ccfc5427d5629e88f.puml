@startuml
skinparam sequenceMessageAlign center
title 蓝牙配对-搜索流程

participant "sdk_client" as sdk {
    participant IotRecorderManager
    participant DevicesManagerMachine
    participant BlueDiscoveryControl
    participant BlueBondControl
    participant BleScanControl
}


group 搜素设备 #LightGray
    
        activate BluetoothGattConfig
        
            note over IotRecorderManager : InitState
            
                init->>DevicesManagerMachine:init() 
                
                    registerReceiver ->>BlueDiscoveryControl:registerReciver
                
                        startDiscoverDevice -->BluetoothAdapter:startDisovery
                        
                            CMD_DISCOVERY_START-->IotRecorderManager:CMD_DISCOVER_DEVICE
                    
                                DiscoveryBroadcastRecever<--new:new DiscoverBroadCastReceiveer
                                
                                    sendMesage <--sendMesaage():sendMessage("MSG_DICOVERY_FOUND")
                                    
                                        MSG_DICSOVERY_FOUNG<<---return:return discover device found message to bluetoothdevice
                                        
                                            return -->>initstateenter:end state enter  
                                            
                                                end group   
                                                
                                                    group 绑定设备#lightgray
                                                    
                                                        BondDevice --->CMD_BOND_DEVIVE:Bond Device command sent from devicesmanagermachine
                                                                        
