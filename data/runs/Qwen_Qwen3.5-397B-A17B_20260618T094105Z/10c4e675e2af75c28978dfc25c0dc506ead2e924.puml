@startuml
actor User
participant "PC" as PC #LightBlue
rectangle Robot #Red
database Camera

User -> PC : Answer()
activate PC
deactivate PC
Robot <- PC : turn left()
activate Robot
deactivate Robot
Robot <- PC : Move on the left()
activate Robot
deactivate Robot
Robot <- PC : Move forward()
activate Robot
deactivate Robot
Robot <- PC : Clean the floor()
activate Robot
deactivate Robot
Robot <- PC : Clean the wall()
activate Robot
deactivate Robot
Robot <- PC : Paint over the graffiti on the wall()
activate Robot
deactivate Robot
Robot <- PC : Paint over the graffiti on the floor()
activate Robot
deactivate Robot
Robot <- PC : Return on his place()
activate Robot
deactivate Robot
PC --> User : Ask()
activate PC
deactivate PC
Camera <-- PC : takepicture()
activate Camera
deactivate Camera
note right of PC 
detectgarffiti()
end note
@enduml