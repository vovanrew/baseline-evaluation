@startuml
participant "JsonData" as JsonData1 { }
participant "Permission1" as Permission1_0 { }
participant Callback { }
participant "JsonData2" as JsonData2_3 { }
participant "Permission2" as Permission2_4 { }

== hasAccess ==
->> Permission1_0 : execute 
activate Permission1_0 

Callback ->> JsonData2_3  :execute  
deactivate Permission1_0  

JsonData2_3 --> Permission2_4   :hasAccess   
return false   

JsonData2_3 <-- Callback    :"Session expired"    
Callback <- - Permission1_0     :"Throw exception"     
Permission1_0 < -- JsonData1     :false    

@enduml