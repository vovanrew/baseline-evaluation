@startuml
skinparam classAttributeIconSize 0
hide circle

class Account {
    +AccountID : int
    +FirstName : string
    +LastName : string
    +EmailAddressUsername : string
    +password : string
    +AccountCreatedDatetime : datetime
    +isArchived : boolean
    
    createAccount()
    deleteAccount()
    editAccount()
    forgotPassword()
}

class Recipe {
    +recipeID : int
    +recipeName : string
    +servings : int
    +prepTime : time
    +cookTime : time
    +totalTime : time
    +isFavorite : boolean
    
    createRecipe()
    editRecipe()
    deleteRecipe()
    saveRecipe()
}

class Ingredient {
    +IngredientID : int
    +IngredientText : string
    +IngredientAmount : int
    +isArchived : boolean
    
    AddIngredient()
    EditIngredient()
    DeleteIngredient()
}

class Measurement {
    +MeasurementID : int
    +MeasurementText : string
    
    getMeasurement()
}

class Instructions {
    
    getSteps()
}

class Step {
    +StepID : int
    +InstructionStepText : string
    +StepNumberOrder : int
    +isArchived : boolean
    
    AddStep()
    EditStep()
    RemoveStep()
}

class RecipelImage {
    +RecipelmageID : int
    +RecipelmagePath : int
    +isArchived : boolean
    
    AddPhoto()
    DeletePhoto()
}


' Relationships from original diagram preserved exactly where visible/interpretable
"1..*" -- "C": "" 
"*" -up-|> "*" 

@enduml