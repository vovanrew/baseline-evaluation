@startuml
skinparam classAttributeIconSize 0

class Capitan {
    + nombre: String
    + apellido: String
    + matricula: int
}

abstract class Embarcacion <<A>> {
    - capitan: Capitan
    # precioBase: double
    # valorAdicional: double
    # AñoDeFabricacion: int
    + montoDeAlquiler(): double
}

interface Comparable <<I>> {
    compareTo(o Object): int
}

class Yate <<C>> implements Comparable {
    cantCamarotes: int
    compareTo(o Object): int
}

class Velero <<C>> extends Embarcacion {
    cantMastiles: int
    esGrande(): boolean
}

Capitan "1" --* "1..*" Embarcacion : > 

Yate -->|extends |Embarcacion 
Velero -->|extends |Embarcation 


@enduml