@startuml
skinparam classAttributeIconSize 0

class Player {
    int xPos
    int yPos
    boolean alive
    int identifier
    
    Player()
    boolean getStatus()
    int getXPos()
    int getYPos()
    void setStatus()
    void setXPos()
    void setYPos()
    int getIdentifier()
    
    void run()
}

interface Runnable <<I>> {}

Player ..|> Runnable : implements

note right of "void run()" in Player #line;#line;"(from\nRunnable)" as note1
link note1 to Player::run() hidden


class Bomb {
    int xPos
    int yPos
    static final int[][] DIREC
    
    Bomb()
    int getXPos()
    int getYPos()
    void explode()
    
    void run()
}

Bomb --|> Creature : extends
Bomb ..|> Runnable : implements

note top of "void run()" in Bomb #line;#line;"(overrides)\n(from\nCreature)" as note2
link note2 to Bomb::run() hidden


abstract class Thing {
    World world
    Tile<? extends Thing> tile
    Color color
    char glyph
    
    Thing()
    getX()
    getY()
    setTile()
    getColor()
    setColor()
    getGlyph()
    setGlyph()
}

Thing -[hidden]d- Serializable
thing_note = "#line;\n#line;(implements)\nSerializable"
note bottom on link thing_note


class Floor {
    Floor()
}

Floor --|> Thing : inherits from


class Wall {
    Wall()
}

Wall --|> Thing : inherits from


abstract class Creature {
    Creature()
    moveTo()
}

Creature --|> Thing : inherits from


