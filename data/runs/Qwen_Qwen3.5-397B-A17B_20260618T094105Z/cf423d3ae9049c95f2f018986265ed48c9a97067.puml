@startuml
actor User
participant "uic : UIController" as uic
participant "UIExt : UIExtension" as uiext
participant "mp : MacrosPanel" as mp
participant "sui : ScriptUI" as sui

User -> uiext: select macro window\nactivate uiext
create participant "mp : MacrosPanel" as mp2 #LightBlue 
note right of create 10px/5px;#DarkGreen;line:green;text:red;fontSize=8pt;<b>foo</b>;end note
uiext->mp:create(uic)\nactivate mp


User -> mp: Choose write a script \n activate mp
create participant "sui : ScriptUI" as sui3 #lightblue  
mp->sui:create(uic) 

@enduml