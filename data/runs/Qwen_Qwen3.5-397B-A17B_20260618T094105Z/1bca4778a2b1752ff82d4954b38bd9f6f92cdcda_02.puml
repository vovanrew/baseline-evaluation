@startuml
' Configuration for visual style to match original diagram
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
hide empty members

package "Scm" {
    title "**Ski Championships Management**\n\nLast updated 15/10/2020
    
    ' --- Class Definitions ---

    class Event <<C>> {
        + id : int
        - location : string
        # startDate : Date
        ~ endDate : Date
        
        * create() : Event
        * update() 
        * delete() : bool
        _ list() : Event[]
        * export() : bool
        * import() : bool
    }

    class Competitor <<C>> {
        + id : int
        - lastName : string
        - firstName : string
        # birthDate : Date
        ~ bibNumber : int
        email : string
        photo : resource
        
        * create() : Competitor
        * update() 
        * delete() : bool
        _ list() : Competitor[]
    }

    class Result <<C>> {
        time : Time
        
        * create() : Result
        * delete() : bool
        _ list() : Result[]
    }

    class Run <<C>> {
        number : int
        time : Time
        
        Getters and setters
        getId() 
        
        Other methods...
        
        * create() : Run
        * delete() : bool
    }

    category Metadata <<A>> {
        <> id : int
        name : string
        description : string
        
        <yellow>create()
        <green>update()
        <red>delete() : bool
        <blue>_list() : Metadata
    }

    class Category <<C>> {}
    
    class Profile <<C>> {}


    ' --- Relationships ---

    %% Composition from top down
    Event o-- "*" Competitor : takes part >
    note right of this link: runs
    
