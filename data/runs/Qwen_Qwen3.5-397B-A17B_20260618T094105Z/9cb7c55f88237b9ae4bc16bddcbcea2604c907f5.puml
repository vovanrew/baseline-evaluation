}

class "Index" {
    +Render()
    +Home()
    +View()
    +Search(Query : String)
    +JoinEvent()
}

class "ReplyFeedback" {
    +Render()
    +Home()
    +SubmitReply(Description : String)
    +Cancel()
}

class "FeedBacks" {
    +Render()
    +Home()
    +View()
    +Reply()
}


