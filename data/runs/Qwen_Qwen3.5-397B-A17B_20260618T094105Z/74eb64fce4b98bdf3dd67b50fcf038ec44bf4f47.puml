@startuml
package "com" {
  package "qxcode" {
    class Car <<(C,#90EE90)>> {
      -gas : int
      -gasMax : int
      -km : int
      -pass : int
      -passMax : int
      
      +Car()
      +drive(km : int)
      +enter()
      +fuel(gas : int)
      +leave()
      +toString() : String
    }
  }
}
@enduml