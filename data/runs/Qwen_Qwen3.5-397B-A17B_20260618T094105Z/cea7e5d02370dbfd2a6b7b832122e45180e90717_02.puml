@startuml
participant "main" as main
participant "OsScheduler" as OsScheduler
participant "Semaphore" as Semaphore
participant "TaskA" as TaskA
participant "TaskB" as TaskB
participant "System" as System

main ->> OsScheduler : startOS
activate OsScheduler
    OsScheduler ->> TaskA : launch
    
        activate TaskA
        
            TaskA <-x Semaphore  : waitSemaphore
            
                activate Semaphore
                
                    Semaphore -r System   : callSystem
                    
                        activate System
                        
                            note right of System 
                                setJump(buf)
                                
                                    loop while(1){}
                                        selfref left #red:green:red:green;line:brown;text:black;bold;fontName:"Comic Sans MS";fontSize:20px;color:#98FB98;backgroundColor:white;borderWidth=3pt:borderStyle=dashed:borderLineColor=#ff6b47:textAlign=center
                                            <font color="black">setjmp</font><br/><i>(buf)</i></u>:<color red>**return** value = </color><font size="+5"><color blue>_longjump_()</color></font>;
                                        
                                    endloop
                                    
                            
                        
                    
                
            
        
    
    
deactivate TaskA


@enduml