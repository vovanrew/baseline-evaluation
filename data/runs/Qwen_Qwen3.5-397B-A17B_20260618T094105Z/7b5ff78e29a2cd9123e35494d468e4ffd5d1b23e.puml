@startuml
skinparam classAttributeIconSize 0
hide circle

class "app_translation\n((Translations))" <<I>> {
    label string
    description longText
    privacyPolicyExtensions longText
    createdAt createdAt
    updatedAt updatedAt
    appId foreignKey
    languageId foreignKey
}

class "language" <<T>> {}

class "app_action_button_translation\n((Translations))" <<I>> {
    label string
    createdAt createdAt
    updatedAt updatedAt
    appActionButtonId foreignKey
    languageId foreignKey
}

class "app_template\n(App templates)" <<T>> {
    id id
    template longText
    path string
    active bool
    appId foreignKey
    createdAt createdAt
    updatedAt updatedAt
}

class "integration" <<T>> {}

class "acl_role" <<T>> {}

class "custom_field_set" <<T>> {}

class "webhook" <<T>> {}

class "app_action_button\n(App action buttons)" <<T>> {
    id id
    entity string
    view string
    url string
    action string
    openNewTab bool
    label translated
    appId foreignKey
    createdAt createdAt
    updatedAt updatedAt
    translated json
}

class "app\n(Apps)" <<T>> {
    id id
    name string
    path string
    author string
    copyright string
    license string
    active bool
    configurable bool
    privacy string
    version string
    iconRaw blob
    icon string
    appSecret string
    modules list
    cookies list
    label translated
    description translated
    privacyPolicyExtensions translated
    integrationId foreignKey
    aclRoleId foreignKey
    createdAt createdAt
    updatedAt updatedAt
    translated json
}


' Relationships from top-level entities to 'app' or other targets
'app_translation' --> 'language' : ""
'app_translation' -down-> 'app' : ""

'app_action_button_translation' --> 'language' : ""
'app_action_button_translation' --|> 'app_action_button':"" 

'app_action_button' -> 'app' : "" 
'template_app_templates'-right--> 'apps_apps':'' 


