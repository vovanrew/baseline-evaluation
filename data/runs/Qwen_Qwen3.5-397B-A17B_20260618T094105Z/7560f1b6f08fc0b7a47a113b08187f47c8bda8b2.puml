@startuml
actor record
participant "configuration" as config #D3D8E6#000000<<rectangle>> 
participant ekf <<database>> #F5EBFF#000000
participant pathgenerator #C9BFFF#000000<<component>>  
participant display #FFE4CC#000000<<boundary>>   
participant diagnostics #DDA172#FFFFFF<<control>>  

== initialize ==
record ->>config : 1 Get initial configuration\n(returns default values)
activate config
deactivate config

box ""Initialize Objects"" LightGray
    note right of record: Create EKF instance for state estimation
    activate record
    
    rect rgb(240, 240, 240) {
        participant ":ekf_instance"\n(Estimated State:\nx,y,z,vx,vy,vz,\nor,qwqxqyqz)\nas eInstance
        
        ' Add internal structure to show what's being created
        rectangle "<b>EKF Internal Structure</b>"\nin eInstance {\n- Prediction Model\n- Measurement Update\n} \n        
        create object "#ffcccc:eStateObject": Estimated State Object in eInstance
        link -[hidden]- eStateObject --|> eInstance
    } 
    
    deactivate record    
end box 

loop iterate until stop signal received from user or system shutdown command issued by operator/administrator via GUI/control panel/etc... do
