@startuml
skinparam packageStyle rectangle
hide empty members

package "security" {
    folder auth <<auth>> {
        class "@Roles" as RolesDecorator #lightgray
        note right of RolesDecorator : type Role = 'ADMIN' | 'MITARBEITER' | 'KUNDE'
        
        link "-[hidden]->-" between RolesDecorator and AuthNote
        
        node "<type>Role\n= 'ADMIN'\n| 'MITARBEITER'\n| 'KUNDE'" as TypeNode #white;035A8B;line:green;text:black;fontColor:white;;bold::italic 
    }
}


