@startuml
skinparam packageStyle rectangle

package "common" {
    folder domain <<Folder>> {
        folder repository <<Folder>> {
            class FeatureConfigRepository #Ivory;Black<<Interface>>{
                + Future<FeatureConfig> fetch() 
            }
            
            note right of FeatureConfigRepository::fetch : uses
            
            usecase FetchFeatureConfigUseCase as UseCase1
        
            ' Define relationships within this scope first to avoid cross-scope issues later if needed for layout hints
            Repository --> Entity : uses
            UseCase1 -down-> ParamClass : uses
            UseCase1 ..|> BaseDomain.UseCases.BaseUseCase : extends/realizes (dashed line in original)
        
        }
    
        folder entities <<Folder>> {
             entity FeatureConfig  #LightGreen;DarkGreen<<Concrete Class>> {
                 o isPasswordSignInOptionEnabled : bool
                 o isDebugMenuEnabled : bool
             }
             
             
    
         }


         



     




      

















}















folder base <<Folder>> {
     folder domain2 [domain]   {  
           Folder usercases3[usecases]{   
               Interface IBaseUserCase[I]<Type, Params>{ call: Type;}     
               
              
                
                 
                  
                   
                    
                     
                      
                       
                        
                         
                          
                           
                            
                             
                              
                               
                                
                                 
                                  











































}}













@enduml