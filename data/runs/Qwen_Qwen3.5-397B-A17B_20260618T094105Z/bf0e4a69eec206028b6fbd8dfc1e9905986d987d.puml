@startuml
' Global settings to match the visual style of the provided MLD/UML diagram.
skinparam classAttributeIconSize 0
skinparam noteBackgroundColor #FFFFFF
skinparam noteBorderColor black
skinparam defaultFontName "Arial"

class Discipline {
    nom : string {key}
}

class Spécialité {
    nom : string {key}
}

