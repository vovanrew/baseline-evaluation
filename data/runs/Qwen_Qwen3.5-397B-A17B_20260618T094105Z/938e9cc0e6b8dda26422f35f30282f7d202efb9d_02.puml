@startuml
actor Operator
participant "«Boundary» MakerUI" as UI #D3D3F0
participant "«Control» Maker" as Control #E6E6FA
entity "«Entity» Request" as Req #EEEEE8
entity "«Entity» Passport" as Passp #EEEEFF

Operator -> UI : 1: Login\nactivate UI
    activate UI
    note right of UI 
        <b>alt</b><br/>[login invalid]
            return to operator<br/><font color=red>X</font>: Print \"Invalid login\"<br/></note>
    
    alt [user exists]
        
        loop n times
            
                if do Edit passport then
                    
                    pass credentials
                
                
            
            else
        
             print passport
    
         endif   
         
     endloop
     
     
     


@enduml