@startuml
skinparam classAttributeIconSize 0
package "Factory Method Persona" {
    abstract class Persona <<A>> #lightblue
}

abstract class Empleado <<A>> #lightblue
class Cliente <<C>> #palegreen
class Mecanico <<C>> #palegreen
class Oficinista <<C>> #palegreen
Persona <|-- Empleado : 
Cliente --|> Persona : 
Mecanico --|> Empleado : 
Oficinista --|> Empleado : 

interface PersonaFactoryMethod <<I>> #lightcyan{
+ crearPersona(id)
}
note right of PersonaFactoryMethod::crearPersona()
<font color=red><b>&lt;&lt;factory method&gt;</b></font>: crea una instancia de la clase concreta que se necesita según el id recibido como parámetro.
end note

class PersonaFactory <<C>> #palegreen
PersonaFactory -[hidden]-> PersonaFactoryMethod : extends
PersonaFactory ..> Cliente : «instancia»
PersonaFactory ..> Mecanico : «instancia»
PersonaFactory ..> Oficinista : «instancia»


@enduml