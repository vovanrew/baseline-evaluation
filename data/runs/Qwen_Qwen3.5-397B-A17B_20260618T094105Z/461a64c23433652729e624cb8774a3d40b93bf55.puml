@startuml
title 3.1.0 Get Participant Callback Details

skinparam sequenceMessageAlign center
skinparam lifelineStrategy solid
skinparam noteStyle handwritten
skinparam participantPadding 25
skinparam boxWidthIncrement -487
box "Central Services" #LightYellow
participant Central Service API as CSAPI
participant Participant Handler as PH
participant Participant DAO as PDOA
database Central Store as CS
end box
package ML_API_Adapter_Service {
    entity ML-API-ADAPTER as MLAIA
}


autonumber "<b>" "</b>." "" "#96DFFF" 

==Get Callback Details == 
CSAPI ->+PH : Fetch Callback details for Participant\n<b>Error code:</b><color:red> <u>3200</u></color>\n<font color=red size="1">Error Code Description here.</font> \n\#FFCCCB;| |  
activate PH   
note right of PH:<size=-1>{}</size>|  

group Validate DFSP [success]    
   alt Check if 'type' parameter is sent (Sent)      
      activate PH     
       group Retrieve callback endpoint by type       
         PH->PDOA:+Fetch Callback details for Participant and Type        
        loop For each Endpoint         
            PDOA-->CS:Get Endpoints            
             opt Condition           
                Note left of CS: isActive = true AND endPointTypeId=<TypeValue>             
               end              
              return Retrieved endpoints               
           end          
          deactivate PDOA                
     else No such condition exists in DB                  
        create error object ErrorObject                   
        destroy ErrorObject                 
     end                    
else check if 'type' paramter not Sent                     
loop retrieve all active callbacks                        
return retrieved list                      
deactivate PH                       
endif                         
elseif Validation failure/Error                            
