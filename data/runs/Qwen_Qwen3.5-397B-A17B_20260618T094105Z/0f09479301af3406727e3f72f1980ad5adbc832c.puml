@startuml
skinparam sequenceMessageAlign center

actor "참가자" as participant1
participant "깃헙 리포지토리\nGitHub Repository" as repository2 #D3D8FF
participant "운영자\nOperator" as operator4 #F9E7A6
database "데이터베이스\ndatabase" as db5 #B0CBEF


box PR 	#LightBlue 
	participant "" as github_action_gha_pr_participant  
end box 

rectangle GHA_PR {
    note right of participant1 :GHA 챌린지 완료 인증샷
    
  	github_action_gpr ->>repository2:PR 생성
   
   
	repository2->github_action_gha_pr_participant:이벤트 발생
	
	note left of github_action_gha_pr_participant:#bcebcf 라벨 추가: review-required</color> 
	
}



note over participant1 ,db5:<u><font color=red size="1">REVIEW 과정 </size></u>\n- 운영자가 리뷰를 진행합니다.\n - 기록을 확인하고 업데이트 합니다. \n - 참가자에게 이메일로 결과를 통보합니다.</i> 


group REVIEW <font color=#ffaaaa >리뷰 프로세스</color>{	
operator4-->operator4:리뷰
		
repositry_review <- operator4:nlabel add:review-completed		
repositry_review <-- operator4:d label delete:review-required		

comment on link repositry_review -->> operator4:"/ghasignoff"</color>"	

event_generation_rv<- operator4:event generation	


alt [record exists]
	db_record_update -->db5:update record
else[no records exist ]
	comment below event_generation_rv:no update required for this case
	end alt	
	
	group EMAIL_NOTIFICATIONS<font color = green ><u>Email Notifications Process:</u></color>{    
	email_notification_process()        
     }     
         
         function email_notifications(){             
             send_email_to_user(email_address,message_content);              
              log_sent_emails(log_entry_details );               
               return true;            
