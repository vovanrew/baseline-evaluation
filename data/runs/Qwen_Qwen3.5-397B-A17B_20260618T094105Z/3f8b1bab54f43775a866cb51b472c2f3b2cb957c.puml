@startuml
skinparam classAttributeIconSize 0

class "Brain" {
    pythons = []
    pips = []
    python_default
    python2_default
    python3_default
    pip_default
    pip2_default
    pip3_default
    visualisation = ""
    verbose = true
    report_obj = {}
    sites = {}
}

note top of Brain : 
|<b>Brain's attributes</b>|
python_default, python2_default, python3_default\npip_default, pip2_default, pip3_default\get stored into the Brain's report objects'\ndefaults = {}\n defaults.python \ndefaults.python2\ndefaults.python3\ndefaults.pip\ndefaults.pip2\ndefaults.pip3\nattributes, respectively.


class Base{
path=path
paths_all=Set
is_default=false
is_default2=false
is_default3=false
result_shell_ls
result_shell_version
result_shell_file_size
version
size
warnings=[]
report_obj={}
--
 get exists()
 analyse()
 report()}



class Python{
 result_shell_site_info
 result_shell_run_pip_as_module
 sys_path=[]
 pip_module_version
 pip_module_site_package_path
pips=[]
analyse()
 --
 analyse()}




class Pip{site_package_path
pythons=[]
---
analyse()
analyse_version()
report()}

class Site{ path=path
            pythons= Set
             pips= Set } 

Pip -up-|>Base  
Python-up-> | >Base  

' relationships between classes
"Pip"-->"Site":sites *
"Python"-right--> "*"|"Site"|:"*"
"Brain"-"*":"pips *" -->"Pip"
"Brain"-"*":"pythons "-->*"Python"
@enduml