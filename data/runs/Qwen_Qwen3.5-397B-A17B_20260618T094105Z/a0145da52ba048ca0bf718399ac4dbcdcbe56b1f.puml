@startuml
skinparam classAttributeIconSize 0
hide circle

package "Modulo-matrícula/Informática" {
    [Matrícula] <<C>> #lightgreen;line:green;text:black;bold;;{
        -id: Int
        -cliente: Client
        -tempo: Int
        -quadra: Turma
        
        +registraMatriicula(): Int
    }
    
    [Aluno] <<C>> #lightgreen;line:green;text:black;bold;;{
        -id: Int
        -nome: String
        -locaçao: List<Matricula>
        
       
    }
}


[ControleNúmeroMatricúla] <<I,I>> #purple;line:red;text:white;italic;;<<interface>>#white;line:#black{text:black}{ 
   #quantidadeDeMatrícula:Int
   
   
+registraMatriicula() :Int
    
  
}



[Turma]<<C,C>> #lightgray;line:#36454F;text:#2E8B57:bold;;{
-numero:int
-aluguel:Mátricula
-ginasio:Curso 

+getcontroleNúmeromatriculaa();
    

}




[Cursso]<</c,c/c/Curso>> #lightblue;line:#191970;text:#FFDAB9:bold;;{
-nome:String
-profesor:string
-quadra:list<Turmas>;
  

}





