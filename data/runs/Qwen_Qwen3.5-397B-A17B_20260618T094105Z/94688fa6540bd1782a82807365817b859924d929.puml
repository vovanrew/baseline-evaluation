@startuml
participant "Appelant" as A1
participant "Ligne Téléphonique" as L1
participant "Appelé" as C1

A1 ->> L1 : Décroche
activate A1
deactivate A1
L1 --> A1 : Tonalité
activate L1
deactivate L1
A1 ->> L1 : Numérotation
activate A1
deactivate A1
L1 --> A1 : Indication de sonnerie
activate L1
deactivate L1
L1 ->> C1 : Sonnerie
C1 ->> L1 : Décroche
L1 -->> A1 : Allô
@enduml