@startuml
title af sync strategy ReferencePage

participant "af_core" as A #90EE90
participant "af_haf" as B #ADFF2F
participant "camxhafadapter" as C #87CEFA
participant "af_haf_default_mixer" as D #4169E1
box Follower #FFE4B5
  participant "af_haf_follower" as E #DC143C
end box

== how the follower create ==
A->>B : af_haf_set_core_switch()
activate B
note right of B 
pAlgo->set_parameters\n type: AF_HAF_SET_PARAM_PEER_FOCUS_INFO
end note
D ->> E : af_default_mixer_set_parameters ()\n if !master:\npMixer->p_primary = pMixer-->p_follow_algo \nelse :\npMixer->p_primary=pMixer-->>active_also
return return from E to D
deactivate D
return return from B to A
deactivate B


== af process monitor ==
autonumber off
group alt [lens_mapping_method= FOLLOWER_LEGACY_MAPPING] or[lens mapping method=FOLLOWER_DIRECT MAPPING ]
    activate E
   autolabel on
     autonumbersuffix .a
    
      group opt checked with Lester for follow_monitor has no different for folloer_search current we use LEGACy ,and Direct maping require module calibration data
      
        end
        
         deactivate E
     
         
          else
            
            loop while condition met
                
                repeat until exit criteria satisfied
                    
                    break at specific point
                        
                        continue after interruption
                            
