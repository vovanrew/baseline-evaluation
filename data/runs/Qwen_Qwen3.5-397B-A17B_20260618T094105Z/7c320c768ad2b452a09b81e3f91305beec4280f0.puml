@startuml
actor "图书管理员" as Librarian
participant ": 读者\n<<Entity>>\n{white}" as Reader #LightBlue200
participant ": 借书记录\n<<Record>>\n{lightgray}" as BorrowingRecords #WhiteSmoke
database ": 图书馆数据库\n<<Database>>\n{}" as LibraryDB {
    participant ": 图书目录\n<<Table>>\n{orange}" as BookCatalogs #Orange150
}

Librarian -> Reader : 验证身份()
activate Reader
Reader --> Librarian : return true/false
deactivate Reader

alt if(已认证) then
    alt while((可借阅数量 > 待处理书籍)) do
        group <<Transaction>> 事务性操作 {
            activate Librarian
            
            box "<<AtomicOperation>>原子操作#96D8FF">>减少库存量与增加记录</box>" 
                partition "<color:red><b>[Critical Section]</b></font>\n临界区"{
                    note right of Librarian:<size=+4>**[Lock]**<u>Data Consistency Checkpoint!</u>* </note>
                    
