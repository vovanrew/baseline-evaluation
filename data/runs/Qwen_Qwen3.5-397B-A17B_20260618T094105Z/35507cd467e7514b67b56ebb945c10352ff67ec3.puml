@startuml
skinparam classAttributeIconSize 0

class "Creator" <<interface>> {
    + factoryMethod() : Product
}

class "ConcreteCreator" {
    - name : String = ""
    
    ConcreteCreator(name) 
    override factoryMethod():Product
    
}


