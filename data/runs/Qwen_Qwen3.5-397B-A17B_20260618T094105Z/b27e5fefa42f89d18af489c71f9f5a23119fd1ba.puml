@startuml
skinparam handwritten false
set namespaceSeparator none

class "Container" as Container {
  +__contains__(item)
}

class "Iterable" as Iterable {
  +__iter__()
}

class "Sized" as Sized {
  +__len__(item)
}

abstract class Collection <<A>> extends Container implements Iterable,Sized {}

interface Mapping<<A>>{
+ __getitem__(key) 
+ keys()  
+ items()   
+ values()    
+ get(key,default)     
 } 

 abstract MutableMapping<<A>>extends Mapping{}


MutableMapping --> dict : inherits from 


dict --|> MutableMapping



@enduml