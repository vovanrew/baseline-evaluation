@startuml
skinparam sequenceMessageAlign center
actor "" as User1
participant ":Chantier" as Chantier
participant "jmb:Artisan" as ArtisanJMB
participant "q:Qualif" as QualifQ
participant "real : Realiser" as RealiseReal

User1 ->> Chantier: getPayeArtisan(jmb)
activate Chantier
    Chantier->>ArtisanJMB: q = getQualif()
    activate ArtisanJMB
        return tauxH=getTauxH() 
    deactivate ArtisanJMB
    
    loop ForEach real
      alt [a == jmb]
          note right of Chantier #white;line:green;text:red\n<font color=red><b>a</b></font>\n==\n<b>jmb</b>: d=duree(real)\ndurée +=d;  
     end    
   end
   
return durée*tauxH   
deactivate Chantier


@enduml