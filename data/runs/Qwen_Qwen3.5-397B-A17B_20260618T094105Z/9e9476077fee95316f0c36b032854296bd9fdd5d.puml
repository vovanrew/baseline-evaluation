@startuml
title Sequence Diagram: Internal state synchronization
right header Authors: pw@zoi.de\nVersion: 0.1

package "Internal Service" {
    participant Sender
    participant IoTClient
    participant ShadowCallback
}

rectangle AWS Cloud #98FB98 {
    participant ShadowService
}

== client connection ==
Sender ->> IoTClient : connect()
activate IoTClient
IoTClient ->> ShadowCallback : on_connecet_wrapper()
ShadowCallback --> IoTClient 
deactivate IoTClient
note over ShadowCallback, ShadowService#LineOrange:red box
end note
IoTClient <-+ ShadowCallback : subscribe("AWS Shadow Topics")
IoTClient ->> ShadowService : subscribe()
activate ShadowService
ShadowService -->> IoTClient 

IoTClient ->> ShadowCallback : on_subscribe_wrapper()
activate ShadowCallback
ShadowCallback -[hidden]x ShadowCallback : request_desired_state()


== state retrival ==
shadowbox "#white:black;bold" as sb2 [[state retrieval]] {}
sb2 .. shadowbox "#black:white;" as sbb2 [[]]{}
sbb2 .u.[[#red][[#green]<b><color:green></color></b>[[]</font>] ]
SB2 <.. SBB2 


publish(myclient/shadow/get)



@enduml