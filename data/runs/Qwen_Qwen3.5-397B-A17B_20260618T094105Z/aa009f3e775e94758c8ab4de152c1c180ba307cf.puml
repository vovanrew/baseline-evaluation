@startuml
skinparam sequenceMessageAlign center
autonumber "<b>" 1 ""

box "Request help" #LightGray
    participant Farmer as f
    participant DREAM as d
    
    activate d
        f ->>d : Request help
        
        deactivate d 
            d -->f : Show help request creation form
            
            
        
        


    
    



activate d 

   f->>d: Provide topic and contents of the message
   
   
      alt [operation successful]  
          create note over d\nCreate help request \nendnote
      
      
          
  
       else[ operation failed ]     
       
           
          
         
             
              
               
                
                  
                   
                    
                     
                      
                       
                        
                         
                          
                           
                            
                             
                              
                               
                                
                                 
  
                                   
 
                                     
     
                                       
                                        
                                         
                                          
                                           
                                            
                                             
                                              
                                                
                                                 
                                                  
    
    
                                                   
    

                                                     
                                                      
                                                       
                                                        

                                                         
                                                          
                                                           
                                                             
                                                              
                                                               
                                                                
