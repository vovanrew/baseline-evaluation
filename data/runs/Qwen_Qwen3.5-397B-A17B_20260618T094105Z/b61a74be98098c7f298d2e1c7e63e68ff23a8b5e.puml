@startuml
actor Admin #white
participant "User" as User2 #white
box AccountManagement #LightBlue
    participant "" as A1 #WhiteSmoke
end box
box Broker #LightGreen
    participant "" as B1 #WhiteSmoke
end box
package Notifications {
}
database UAA #lightblue
queue EmailSender #pink


Admin ->A1 : WorkspaceInvitation 
note right of A1  :with email  
activate A1   
ref over A1   :save data to db    
deactivate A1     
return 200 response 

create event "new user invited event"#red;  

B1->Notifications:read event#green;line:red;text:green;dashed;fontSize=8px;color:black;arrowColor:#964d57;lineStyle:dotted;style:solid;backgroundcolor:white;border:none;;fontFamily:"Comic Sans MS";textAlignment:center;;;

alt [user accepts invitation]
     note left of Notifications: with email and senderId
     
     
    
        ref over Notifications: read info about sender
        
         activate Notifications      
          create new mail message        
           deactivate Notifications       
            alt[valid input ]               
                 generate access code                
                  return success              
               else[failure case]:error occurred            
                endif           
              end if         
       elseif[user rejects invite or does not respond within time limit set by admin then send reminder after certain period until maximum attempts reached which will result into account suspension for security reasons so please make sure you complete registration process before deadline expires otherwise your workspace may be deleted permanently without any prior notice thanks!]          
