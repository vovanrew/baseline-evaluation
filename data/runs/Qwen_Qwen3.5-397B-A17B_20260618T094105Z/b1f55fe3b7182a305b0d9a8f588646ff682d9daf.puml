@startuml
actor "顧客" as Customer
participant ":入力画面\n(ログイン)" as InputScreenLogin
database ":貸出コントローラ\n(通常処理用)" as LoanControllerNormal

Customer -> InputScreenLogin : 1 データ入力()
activate InputScreenLogin
opt [ ログイン成功 ]
    activate InputScreenLogin
    note right of InputScreenLogin: ユーザIDとパスワードが一致する。
    
    InputScreenLogin ->> LoanControllerNormal : 20 認証済みユーザ取得()\n[引数：なし]
    activate LoanControllerNormal
    
    alt [ 該当レコードあり ] 
        return """""""{id:"A",name:"山田太郎"}"""""""
        
        opt [ レンタル履歴がある場合のみ実行される ]
            loop [ ループ回数 = レンタル中のDVDの枚数分繰り返す ]
                InputScreenLoanHistory->>InputScreenLoanDetailDisplay:35 DVD情報表示要求（）\n［引数:DVD ID］
                
                group 詳細情報の生成・返却
                    participant ":出力データ作成クラス"\nas OutputDataCreationClass
                    
                    rect rgb(248, 249, 250) #lightyellow
                        box "#lightblue" Internal Classes
                            component "<b>:タイトルマスタ</b>\ntitleMaster"as titlemaster
                            
                            entity <&key>"<b>DVD在庫管理テーブル</b><br/>dvdStockManagementTable"<font color=red size=16>*</font> as dvdstockmanagementtable
                            
                            control "<b>:レンタル中一覧<br/></b>RentalListInUse"as RentalListInuse
                        endbox
                        
                        
                        create Control as rentalhistory
                
                    
                    InputScreenLoanDetailDisplay -->OutputDataCreationClass
            
            
                    break []
                        stop
                    else[]
                        par //並列に検索//
                            titlemaster <-[#green]- dvdstockmanagementtable:[タイル名、メーカー等]\n[DVD_IDで絞り込み]#line:green;line.bold;text:green;
                            loancontrollernormal<- [#orange]-RentalListInuse:[会員番号，氏名など]\n[dvd_id で絞込]#line:red;line.dashed;text:#ff7f00;;
                        endpar
                        


                    endif  
                    
                    
                    



endloop
        
else [ 該当レコードがない場合はエラーメッセージを表示して終了 ] 

return """{"error":"true","message":「存在しないユーザーです」}"""
stop
endif 


deactivate LoanControllerNormal
@enduml