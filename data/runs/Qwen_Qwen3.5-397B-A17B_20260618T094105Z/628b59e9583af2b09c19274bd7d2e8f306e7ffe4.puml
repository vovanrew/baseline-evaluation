@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center

actor Player as p1
box "Portal Service" LightGray
  participant TelnetServer as ts_top
  participant ConnectionManager as cm_top
  participant Middleware as mw_top
end box
participant WorldService as ws_right

