@startuml
skinparam classAttributeIconSize 0
hide circle

class ServiceFault {
    +code
    +description
}

interface ApiExceptionCodes <<enumeration>> {
    code
    description
    SERVICE_NETWORK_EXCEPTION
    SERVER_VALIDATE_EXCEPTION
    INTERNAL_SERVER_ERROR
}

abstract class RuntimeException {}

ServiceFault <|-- ServiceException : extends
RuntimeException <|-- InternalServerException : extends
InternalServerException --|> ApiExceptionCodes : uses
ApiExceptionCodes .. ServerValidateException : references
RuntimeError <-- ExceptionResolverFactory : creates
exception_resolver_factory --> exception_resolvers[] : manages
WSDLConfig *-- SoapFaultMappingExceptionHandlerRegistry : contains
SoapFaultDefinitionHandlerAdapter -up- WsdlConfigurationContextProvider : depends on > 
Wsdl11MessageDispatcher <-down-> MessageReceiverImplementationBase : implements >> 

note right of "message_dispatcher" #lightyellow\n<font color=black><b>Note:</b>\nHandles incoming SOAP messages</font></color>#end note


@enduml