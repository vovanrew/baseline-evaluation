@startuml
skinparam packageStyle rectangle

package "java" {
    folder time <<Rectangle>> {
        class LocalDate #90EE90<<Class>> 
    }
    
    folder util <<Rectangle>> {
        interface List #D8BFD8<<Interface>> 
        class URL #90EE90<<Class>> 
    }
}

folder org <<Rectangle>> {
    folder springframework <<Rectangle>> {
        folder hateoas <<Rectangle>> {
            class RepresentationModel #90EE90<<Class>> 
        }
    }
}

frame com <<Rectangle>> {
    frame acme <<Rectangle>> {
        frame filiale <<Rectangle>> {
            
            ' Entity classes in entity namespace
            node kunde_entity [kunde] {
                class Kunde #90EE90<<C>> 
                
                note right of Umsatzzahlungen : 1..* Umsatz\n(implies aggregation)
                class Umsatz #90EE90<<C>> 
                class Adresse #90EE90<<C>> 
                
                enum GeschlechtType #FFA57F<<E>> 
                enum FamilienstandType #FFA57F<<E>> 
                enum InteresseType #FFA57F<<E>> 
            }
            
            ' REST model - central component  
            rest_model = KlasseKundeModell
            
            card klasse_kundemodell ["«entity»\nKundeModel"] as KM {
               name : String
               email : String
               kategorie: Int
               hasNewsletter: Boolean
               geburtsdatum: java.time.LocalDate
               homepage: java.net.URL
               geschlecht: filialen.entity.GeschlechtTyp
               familienstand: filialen.entity.Familienstandtyp
               interessen: Liste<filiale.Interesse>
               
              -- Aggregations/Assoziationen -->
              
             *-- umsatz   // implizit durch Felddefinition? Oder explizite Assoziationslinie mit Multiplikatoren wie im Bild gezeigt werden lassen! Falls nötig hier hinzufügen falls nicht schon oben bei den Klassen definiert wurde via Notizen etc.! Hier direkt als Linien zeichnen wenn möglich sonst weglassend da redundant zur obigen Definition innerhalb des Packages selbst wo diese Beziehungen bereits visualisiert wurden mittels Pfeilen zwischen einzelnen Elementklassennamen ohne zusätzliche Beschriftung außer ggf Kardinalitäten/Multiplikatorangaben sofern vorhanden bzw erforderlich laut Originalbildvorlage ! Ansonsten einfach nur die existierenden Verbindungslinien übernehmen so gut es geht entsprechend ihrer Art und Richtung sowie eventuellen Labels/Beschriften daraufhinweisenden Textelemente daran angebracht sein sollten gemäss Vorlagendiagrammstrukturierungsvorgaben !!! 
            
           }   
           
