@startuml
skinparam sequenceMessageAlign center
autonumber "<b>[0]"

actor "ユーザ" as User1
participant "ブラウザ\n(HTML/CSS/JS)" as Browser1
control web_php_1 as "web.php" 
controller PersonController_1 as "PersonController"  
entity person_model_1 as "Person Model" 

User1 ->> Browser1 : 該当ページをリクエスト[person/find]
Browser1 ->> web_php_1 : GET [person/find]\nルーティング処理開始
activate web_php_1
    note right of web_php_1: Route::get('person/find',\n'App\Http\Controllers\\<br/>PersonController@index');
    
    alt ルート定義ありの場合
    
        activate PersonController_1
        
            opt ミドルウェア実行
            
                loop すべてのミドルウェアを実行
                
                    create participant middleware_stack as "<<Middleware>> \nmiddleware stack" #LightBlue
                    
                    
                    rect rgb(245, 238, 209)
                        MiddlewareStack --> WebPHP1 : $request を受け取り、$response を返す
                        
                        
                        


                
            
        
        



@enduml