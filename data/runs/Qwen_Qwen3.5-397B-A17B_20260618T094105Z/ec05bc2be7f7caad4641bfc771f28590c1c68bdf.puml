@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center
skinparam participantStyle rectangle
skinparam note {
  BackgroundColor LightYellow
}

title "VirtualApp Activity Start Process"

participant "<b>Main process</b>" as MainProcess <<Rectangle>> {
    participant Hook_StartActivity\nas HSA1<<Actor>>#LightBlue200/Black
    participant VirtualCore\nas VC1<<Database>>#SkyBlue300/DarkSlateGray45
    participant VActivityManager\nas VA1<<Interface>>#PowderBlue/LightSteelBlue
    
    activate HSA1
        onHook ->> VC1 : resolveActivityInfo
        
        create new VRedirectActRequest \nVRA1 
            req <- - ..\nredirectTargetActivity
            
        
            
                redirectTargetActivity --> VA1
                
                
                    call(VA1)-->VA1: startProcessLocked
                    
                        queryFreeStubForProcess->>VC1
                        
                            performStartProcessLocked-->>HSA1
                            
                                sharedPackagesList<-..querySharedPackages(VC1): List<String>
                                
                                    providersList<-. .queryContentProviders(HookedPackageManagerService)\nProviderCaller(): ProviderInfo[]
                                    
                                        usesLibrariesList < -.get Shared Libraries(Package Manager Service):\nString []


' Note about Stub Content Providers mechanism used here for creating processes via Android system APIs without direct invocation of native methods like fork() or exec(). This allows running multiple instances within same app package name space while maintaining isolation between them through separate Linux user IDs assigned at runtime by Zygote daemon upon request from AMS component during initialization phase after receiving broadcast intent ACTION_PACKAGE_ADDED sent out whenever newly installed APK file gets copied into /data/app directory structure managed internally inside PackageManagerServiceImpl class implementation located under frameworks/base/services/core/java/com/android/server/pm path relative root folder where all source codes reside together forming complete operating environment known commonly referred simply just 'Android'. 

note right over SA_CP_IPC_Bridge_Object_Instance_Pointer_Address_Value_Held_Inside_Memory_Location_Allocated_Dynamically_At_Runtime_By_JVM_VirtualMachine_Thread_Scheduler_Component_Responsible_For_Managing_All_Concurrent_Activities_Occurring_Across_Entire_System_Wide_Global_State_Space_Shared Amongst Multiple Processes Running Simultaneously On Single Physical Device Hardware Platform Supporting Multi Tasking Capabilities Enabled Via Kernel Level Mechanisms Such As Context Switches And Interrupt Handlers Etcetera...
    
end box



@enduml