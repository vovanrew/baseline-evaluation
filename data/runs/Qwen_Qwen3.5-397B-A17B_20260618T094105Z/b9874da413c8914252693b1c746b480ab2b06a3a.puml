@startuml
actor User
participant "executor:AnalysisExecutor" as executor #D3D3D3 
participant ":Analysis" as analysis #ADD8E6  
database ".CountryCaseAPIGetter" as caseApi #FFB6C1   
database ".CountryDeathAPIGetter" as deathApi #90EE90    
database ".CountryPopulationAPIGetter" as popApi 	#F5DEB3     
interface :APInformationGetter as apiInfo   #FFE4B5      
actor Covid API 

User -> +executor: runAnalsis()

opt [At least one country selected for analsy] {
    activate executor
    
	executor->+analysis: analyze{}
	
	opt CasesPerCapitaAnalys{
        par getCases(){
            activation on
            
			caseApi <-caseApi:getDataURL()\n\n\t<--\t[hidden]\n \t<-apiInfo:\tAPI Endpoint URL\n\t-->caseApi:[hidden]\n\t<-deathApi:<font color=red>API Call</font>\n\t-->popApi:[hidden]\n\t<-apiInfo: <b><u>API Information </u></b> 
            
        	deactivation off
        
            
        
     }else getDeaths(){
     	  activation on
      
     	 deatHApi <-deatHApi:getDataURL()\n\n\t<--[hidden]\n \t<-apiInfo:\tAPI Endpoint URL\n\t-->caseApi:[hidden]\n\t<-deathApi:<font color=red>API Call</font>\n\t-->popApi:[hidden]\n\t<-apiInfo: <b><u>API Information </u></b> 
        
          deactivate off
     
       else getTotalcases(){
       	 activation on
   
      	 totalcasetotalcaselaseApi <-totalcasetotallseApi:getDataURL()\n\n\t<-[hidden]\n \t<-apiInfo:\tAPI Endpoint URL\n\t-->caseApi:[hidden]\n\t<-deathApi:<font color=red>API Call</font>\n\t-->popApi:[hidden]\n\t<-apiInfo: <b><u>API Information </u></b> 
    
           deactivate off
  
       
         
          
           
             
              
               
                
                 
                  
                   
                    
                     
                      
                       
                        
                         
                          
                           
                            
                             
                              
                               
                                
                                 
  
}


