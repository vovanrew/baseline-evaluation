@startuml
skinparam classAttributeIconSize 0

class User {
    this.name = name
    this.age = age
    this.phoneNumber = phoneNumber
    this.email = email
    this.location = location
    this.photos = []
    this.interestedBy = []
    this.commented = []
    this.likes = []
    this.saved = []
}

User : constructor(name, age, phoneNumber, email, location) {}

package "Events" <<Folder>> {
    
    abstract class Events {
        this.tourName = tourName
        this.eventDate = eventDate
        this.location = location
        this.price = price
        this.likedBy = []
        this.attended = [] // created
        this.payments = []
        this.cancelledBy = []
        this.comments = []
        
        constructor(tourName, eventDate, location, price) {}
    }
    
    class TalkEvent
    
    class TourEvent
    
    ' Inheritance relationships within package
    TalkEvent --|> Events
    TourEvent --|> Events
}


