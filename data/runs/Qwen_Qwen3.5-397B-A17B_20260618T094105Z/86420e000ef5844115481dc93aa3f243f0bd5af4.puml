@startuml
participant "员工" as Employee
participant "主管" as Manager

loop 每周一
    activate Manager
    Employee ->> Manager : <b><font size=4 color="black">1</color></b>&nbsp;汇报
    
    deactivate Manager 
    activate Manager 
    
    Manager -->>Employee:<b><font size=4 color="black">2 </color></b>&nbsp;<font face = '微软雅黑' >工作安排</font>  
end loop


@enduml