@startuml
actor "门店人员" as StoreStaff1 at 0
participant "钉钉门店宝\n(DDStore)" as DDStore #LightBlue
database "报货中心\n(OrderCenter)" as OrderCenter #LightGreen

== 申报货物流程 ==
note right of StoreStaff1 : <b>步骤:</b>\n- 选择商品/数量\n- 提交订单数据
activate StoreStaff1
StoreStaff1 -> DDStore ++: submitOrderRequest() 
deactivate StoreStaff1 

group data validation <<internal>> over DDStore,OrderCenter
    note left of DDStore:<i>*校验规则*</i>: \n库存检查、格式验证等
    
    activate DDStore  
    alt orderValid? then    
        rect rgb(245,238,79) //黄色高亮区表示关键处理节点        
            box internalProcessing hidden            
                participant ""as InternalProc#YellowOrange                
            endbox
            
            loop retryOnFailure(max=3 times){               
               try{                  
                  callInternalValidation();                 
                 }catch(Exception e){                   
                   logError(e);                    
                    if(retryCount<maxRetries){                        
                        waitRandomTimeBetweenAttempts();                         
                         continue;                      
                     else throw new MaxRetryExceededException("Failed after retries");                     
              }}           
           next          
       endif       
   deactivate DDStore      
endif     
end group    

