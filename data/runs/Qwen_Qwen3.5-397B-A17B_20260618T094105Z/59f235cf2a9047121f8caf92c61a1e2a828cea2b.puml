@startuml
package "hotel" {
  package entity <<Rectangle>> {
    class Service <<entity>> {
      + id : int
      + name : String
      + price : int
      
      -- Methods --
      
      - toString() : String
      - getId():int 
      - setId(int) void
      - getName():String  
      - setName(String):void   
      - getPrice:int    
      - setPrice(Integer:void     
     }
   }
}


@enduml