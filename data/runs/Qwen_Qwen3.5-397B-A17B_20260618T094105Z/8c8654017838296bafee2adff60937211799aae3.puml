@startuml
title Cancel Offer

actor Merchant
participant "MarketContract" as MC {
}
database Inventory
rectangle Market

Merchant -> Market : Merchant calls settle()
MC -[hidden]->> Inventory 
note right of MC #DDDDDD;Inventory\n</b>;end note
activate MC
deactivate MC
MC --> Inventory : Market unlocks offered funds in inventory


@enduml