@startuml
skinparam classAttributeIconSize 0

class StaticFactory {
    + produce() : Product
}

abstract class Product <<A>> {
    void produce()
}

class ConcreteProduct1 extends Product {
    - name = "ConcreteProduct1"
    
    override void produce(): string 
        return this.name;
}

class ConcreteProduct2 extends Product {
    - name = "ConcreteProduct2"
    
    override void produce(): string 
        return this.name;
}

StaticFactory -->|creates | ConcreteProduct1
StaticFactory -->|creates | ConcreteProduct2

@enduml