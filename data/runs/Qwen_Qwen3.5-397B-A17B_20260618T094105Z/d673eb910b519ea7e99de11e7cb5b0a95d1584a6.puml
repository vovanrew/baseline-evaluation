@startuml
skinparam classAttributeIconSize 0

class "Proyecto" {
    Nombre : "1 Texto"
    Fecha de inicio : 1 Tiempo
    Fecha de fin : 0..1 Tiempo
} <<C>> 

note right of Proyecto::Nombre 
end note

class "Miembros del Equipo" {
    Nombre : 1 Texto
    Apellidos : 1 Texto
    Rol : 0..* Texto
} <<C>> 

note left of Miembros_del_Equipo::Rol 
end note

class "Lugar_de_Actuacion" {
    Nombre : 0..* Texto
    Coordenada_X : 1 Número
    Coordenada_Y : 1 Número
} <<C>> 

@enduml