```plantuml
@startuml

package "xxx" {
  interface Shape {
    void draw()
  }

  class Circle {
    void draw()
  }

  class Rectangle {
    void draw()
  }

  class Square {
    void draw()
  }

  Circle ..|> Shape : implement
  Rectangle ..|> Shape : implement
  Square ..|> Shape : implement
}

class ShapeFactory {
  Shape getShape()
}

class FactoryPatternDemo {
  void main()
}

ShapeFactory ..> Shape : create
FactoryPatternDemo ..> ShapeFactory : ask

@enduml
