```plantuml
@startuml

class Metric {
    resultCompare()
    sendNotification()
}

class ResultCompare {
    currentValue
    previousValue
    dataSetType
    --
    CmpMethods()
    --
    return
    --
    (-1;0;1)
}

class DataSet {
    value
    date
    dataSetType
    --
    getValue()
    getDate()
    getDataSetType()
    --
    return
    --
    return date to compare
    and info about metric type
}

class Notification {
    sendTo
    message
    --
    sendMethod()
    --
    return
    --
    send message
}

class SendMethod {
    sendMethod()
    --
    return
    --
    send method
}

class CmpMethods {
    cmpMethod()
    --
    return
    --
    select method
}

Metric ..> ResultCompare
Metric ..> Notification
ResultCompare --> DataSet : -
ResultCompare ..> CmpMethods
Notification ..> SendMethod

@enduml
```