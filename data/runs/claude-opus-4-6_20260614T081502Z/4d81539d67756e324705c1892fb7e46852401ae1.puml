@startuml
participant Control
participant Graph
participant "nodes[i]:Node" as Node
participant "ants[i]:Ant" as Ant

[-> Control
activate Control

Control -> Graph : getNodes()
activate Graph
Graph --> Control : nodes
deactivate Graph

loop [nodes]
    opt [nodes[i].getContent() instanceof FreeNode]
        Control -> Node : getAnts()
        activate Node
        Node --> Control : frms
        deactivate Node

        loop [fourmis]
            opt [ants[i] instanceof MovableAnt]
                Ant -> Ant : move()
                activate Ant
                deactivate Ant
            end
        end
    end
end

deactivate Control
@enduml