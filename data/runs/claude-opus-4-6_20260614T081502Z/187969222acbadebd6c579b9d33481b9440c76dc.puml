```plantuml
@startuml

title 类图

abstract class User {
  int id
  string name
  string github（github地址）
  string sex
  string picture
}

class Experimentscore {
}

class Login {
  int id
  int username（学生账号就是学号，老师账号是工号）
  string password
  int role（角色）
}

class Experimentcore {
  int id
  int studentId (与学生关联)
  int scoreitemId (与scoreitem关联)
}

class Teacher {
  int teacherNumber（工号）
  string office（办公室）
  string phone
}

class Student {
  int studentNumber（学号）
  string class（班级）
}

class Scoreitem {
  int id
  int complexScore（复杂度得分）
  int completeScore (完成度得分）
  int answerScore (答辩得分)
}

class TeacherCourse {
  int id
  int teacherId
  int courseId
}

class StudentCourse {
  int id
  int studentId
  int courseId
}

class Experiment {
  int id
  string name（实验名）
  Date date（实验发布时间）
  string github（实验的github地址）
  int courseId（与Course类的id关联）
}

class Course {
  int id
  int courseNum
  string name
  string term
  float credit（学分）
}

note right of TeacherCourse : "老师选课"类
note right of StudentCourse : "学生选课"类
note right of Scoreitem : 一个scoreitem实例就表示了一个\n学生的一个实验成绩

User <|-- Teacher
User <|-- Student

User "n" -- "n" Experimentscore

Student "1" -- "1" Scoreitem

Teacher "1" -- "n" TeacherCourse
Student "1" -- "n" StudentCourse

TeacherCourse "n" -- "1" Course
StudentCourse "n" -- "1" Course

Course "1" -- "n" Experiment

Experiment "1" -- "n" Scoreitem

Login "1" -- "1" User : >

@enduml
