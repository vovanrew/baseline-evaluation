```plantuml
@startuml

package "com" {
  package "iluwatar" {
    package "dependency" {
      package "injection" {

        class SimpleWizard {
          ~ tobacco : OldTobyTobacco
          + SimpleWizard()
          + smoke()
        }

        class App {
          + App()
          + {static} main(args : String[])
        }

        class AdvancedWizard {
          ~ tobacco : Tobacco
          + AdvancedWizard(tobacco : Tobacco)
          + smoke()
        }

        class GuiceWizard {
          ~ tobacco : Tobacco
          + GuiceWizard(tobacco : Tobacco)
          + smoke()
        }

        class RivendellTobacco {
          + RivendellTobacco()
        }

        class OldTobyTobacco {
          + OldTobyTobacco()
        }

        class SecondBreakfastTobacco {
          + SecondBreakfastTobacco()
        }

        interface Wizard {
          + smoke()
        }

        abstract class Tobacco {
          + Tobacco()
          + smoke(wizard : Wizard)
        }

        AdvancedWizard ..|> Wizard
        GuiceWizard ..|> Wizard
        SimpleWizard ..|> Wizard

        RivendellTobacco --|> Tobacco
        OldTobyTobacco --|> Tobacco
        SecondBreakfastTobacco --|> Tobacco

        SimpleWizard ..> OldTobyTobacco

        AdvancedWizard ..> Tobacco : "-tobacco"
        GuiceWizard ..> Tobacco : "-tobacco"
        SimpleWizard ..> Tobacco : "-tobacco"

      }
    }
  }
}

@enduml
