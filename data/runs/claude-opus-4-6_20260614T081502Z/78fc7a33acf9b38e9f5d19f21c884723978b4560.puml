    ...
    generated from IDL
  }

  class InterfaceDummy <<C>> #LightBlue {
    generated from IDL
  }

  class InterfaceImplementation <<C>> #LightBlue {
    concrete class implementing the interface
  }

  class InterfaceIPCProxy <<C>> #LightBlue {
    generated from IDL
  }

  InterfaceQMLAdapter --> Interface : provider
  InterfaceQMLAdapter --|> QMLAdapterBase
  InterfaceImplementationBase --|> Interface
  Interface --|> InterfaceBase
  InterfaceDummy --|> InterfaceImplementationBase
  InterfaceImplementation --|> InterfaceImplementationBase
  InterfaceIPCProxy --|> InterfaceImplementationBase
  InterfaceIPCProxy --|> IPCServiceAdapterBase
