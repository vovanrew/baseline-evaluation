```plantuml
@startuml

participant "UserController" as UC
participant "ThemeController" as TC
participant "CommentController" as CC

alt [successful]
    UC -> TC : login()
    TC --> UC : Success(save session)
else [no register]
    UC -> UC : register()
end

TC --> UC : list()
UC ..> CC : themeID
CC -> CC : list(themeID)

alt [your comments]
    CC -> CC : edit()
else [not your comments]
    CC -> CC : can't edit
end

CC -> CC : add()

UC -> UC : logOut()

@enduml
```