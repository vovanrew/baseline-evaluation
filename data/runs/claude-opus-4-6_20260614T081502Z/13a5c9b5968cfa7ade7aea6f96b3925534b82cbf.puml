```plantuml
@startuml

interface CarPart {
  + PrintPart()
  + AddPart(v interface{})
  + RemovePart(v interface{})
}

class Engine {
  Container: list.List
}

class Suspenstion {
  Container: list.List
}

class Car {
  Container: list.List
}

class CylinderBlock
class Sump
class Crankshaft
class Rod
class Absorber
class Damping
class Stabilizer
class Rack
class Lever
class Spring

Engine ..|> CarPart
Suspenstion ..|> CarPart
Car ..|> CarPart

Car ..> Engine
Car ..> Suspenstion

CylinderBlock --> Engine
Sump --> Engine
Crankshaft --> Engine
Rod --> Engine

Absorber --> Suspenstion
Damping --> Suspenstion
Stabilizer --> Suspenstion
Rack --> Suspenstion
Lever --> Suspenstion
Spring --> Suspenstion

@enduml
