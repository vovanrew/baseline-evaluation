```plantuml
@startuml
title login by token

actor 学术袁
participant "App客户端" as App
participant "后台服务器" as Server

学术袁 -> App : 启动
App -> App : 检测本地登录信息

alt 有本地记录
    alt token有效
        App -> Server : token自动登陆
    else token无效
        App -> 学术袁 : 提示登录
        学术袁 -> App : 输入手机号+密码
        App -> Server : 手机号+密码登录
        Server -> App : 返回新的token
        App -> App : token保存
    end
else 无本地记录
    App -> 学术袁 : 提示输入手机号
    App -> Server : 请求发送验证码
    Server -> App : 返回验证码
    学术袁 -> App : 输入验证码
    App -> Server : 请求后台验证

    alt 已注册
        App -> 学术袁 : 提示登录
        学术袁 -> App : 输入手机号+密码
        App -> Server : 手机号+密码登录
        Server -> App : 返回新的token
        App -> App : token保存
    else 未注册
        App -> 学术袁 : 提示注册
        学术袁 -> App : 输入两次密码
        App -> Server : 请求注册
        Server -> App : 返回新的token
        App -> App : token保存
    end
end

@enduml
```