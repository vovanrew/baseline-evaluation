package "dao" {
  interface DAO {
    find(id : int) : T
    create(T obj) : T
    update(T obj) : T
    delete(T obj) : boolean
  }

  class AnswerDao {
    # OfferDao()
    + getInstance() : QuestionDao
    + LazyHolder()
