package "php" {
    package "SPL" {
        interface "ArrayAccess" {
            + offsetExists (offset)
            + offsetGet (offset)
            + offsetSet (offset, value)
            + offsetUnset (offset)
        }

        interface "Countable" {
            + count()
        }

        interface "Iterator" {
            + current()
            + next ()
            + key ()
            + valid ()
            + rewind ()
        }

        class "SplFixedArray" {
        }
    }
}

package "Digitick" {
    package "Foundation" {
        package "Collection" {
            interface "InterfaceCollection" {
                + addAll(InterfaceCollection elementCollection)
                + clear()
                + contains(element)
                + containsAll(InterfaceCollection elementCollection)
                + isEmpty()
                + removeAll(interfaceCollection elementCollection)
                + size()
                + toArray()
            }

            interface "InterfaceSet" {
                + add(element)
                + get(element)
                + remove(element)
            }

            interface "InterfaceList" {
                + add(offset, element)
                + remove(offset)
                + get(offset)
                + set(offset, element)
                + indexOf(element)
                + subList(fromIndex, toIndex)
            }

            abstract class "TraitCollection" <<(A,#grey)>> {
                - indexOf(element, collectionObject)
                - contains(element, collectionObject)
            }

            abstract class "AbstractObjectSet" <<(A,#grey)>> {
                ~ storageArray
                ~ nextAvailableOffset
                + set(element, data)
            }

            abstract class "AbstractScalarSet" <<(A,#grey)>> {
                ~ {static} DEFAULT_SIZE
                ~ nextAvailableOffset
                ~ storageArray
                + increaseSize(quantity=1)
                + decreaseSize(quantity=1)
                + shift(fromOffset)
                + removeOffset(offset)
            }

            abstract class "TraitTypedCollection" <<(A,#grey)>> {
                ~ CLASSORTYPENAME
                - checkelementType(element)
            }

            abstract class "AbstractList" <<(A,#grey)>> {
            }

            class "BaseObjectSet" <<(C,#grey)>> {
            }

            abstract class "AbstractTypedScalarSet" <<(A,#grey)>> {
            }

