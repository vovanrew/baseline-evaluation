@startuml

class GeographicPlaceNameSourceDetail {
  -sourceUrl
  -country
  -stateProvince
  -higherGeographicPlaces
  -recordedOn
}

class CollectingEvent {
  -dwcVerbatimLatitude
  -dwcVerbatimLongitude
  -dwcVerbatimLocality
  -verbatimEventDateTime
  -geographicPlaceNameSource
  -collectors
  -attachments
}

class GeoreferenceAssertion {
  -dwcDecimalLatitude
  -dwcDecimalLongitude
  -dwcCoordinateUncertaintyInMeters
  -georeferencedBy
  -dwcGeoreferenceVerificationStatus
}

class MaterialSample {
  -materialSampleName
  -dwcCatalogueNumber[not unique]
  -dwcOtherCatalogNumbers
  -preparedBy
  -preparationDate
}

class Determination {
  -scientificName
  -determinationDate
}

class PreparationType {
  -name
  -description
}

class MaterialSampleType {
  -name
  -description
}

class StorageUnit {
  -name
  -type
}

CollectingEvent "1" -- "1" GeographicPlaceNameSourceDetail
CollectingEvent "1" -- "0..*" GeoreferenceAssertion
CollectingEvent "0..1" -- "0..*" MaterialSample
MaterialSample "1" -- "0..*" Determination
MaterialSample "0..1" -- "0..*" PreparationType
MaterialSample "0..1" -- "0..*" MaterialSampleType
MaterialSample "0..1" -- "0..*" StorageUnit
MaterialSample "0..*" -[dashed,#red]-> MaterialSample

@enduml
